@{
    ViewData["Title"] = "Sayfa Bulunamadı";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Sayfa Bulunamadı</title>
    <link rel="shortcut icon" type="image/x-icon" href="/adminThema/assets/img/favicon.ico" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            background: #0d0d14;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', system-ui, sans-serif;
            overflow: hidden;
            position: relative;
        }

            /* Arka plan ızgara */
            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background-image: linear-gradient(rgba(255,107,0,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,107,0,.04) 1px, transparent 1px);
                background-size: 60px 60px;
                pointer-events: none;
            }

            /* Parlama efekti */
            body::after {
                content: '';
                position: fixed;
                top: -20%;
                left: 50%;
                transform: translateX(-50%);
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(255,107,0,.12) 0%, transparent 70%);
                pointer-events: none;
            }

        .container {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 24px;
        }

        /* 404 büyük yazı */
        .error-number {
            font-family: 'Syne', sans-serif;
            font-size: clamp(8rem, 20vw, 14rem);
            font-weight: 800;
            line-height: 1;
            background: linear-gradient(135deg, #ff6b00 0%, #ff9500 50%, #ffb347 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            position: relative;
            display: inline-block;
            filter: drop-shadow(0 0 40px rgba(255,107,0,.3));
            animation: pulse 3s ease-in-out infinite;
        }

        @@keyframes pulse {
            0%, 100%

        {
            filter: drop-shadow(0 0 40px rgba(255,107,0,.3));
        }

        50% {
            filter: drop-shadow(0 0 60px rgba(255,107,0,.5));
        }

        }

        /* Gezegen / Astronot ikonu */
        .astronaut {
            font-size: 4rem;
            display: block;
            margin: -10px auto 20px;
            animation: float 4s ease-in-out infinite;
        }

        @@keyframes float {
            0%, 100%

        {
            transform: translateY(0) rotate(-5deg);
        }

        50% {
            transform: translateY(-20px) rotate(5deg);
        }

        }

        h1 {
            font-family: 'Syne', sans-serif;
            font-size: clamp(1.4rem, 4vw, 2rem);
            font-weight: 700;
            color: #fff;
            margin-bottom: 14px;
            letter-spacing: -.5px;
        }

        p {
            font-size: .95rem;
            color: rgba(255,255,255,.5);
            line-height: 1.7;
            max-width: 380px;
            margin: 0 auto 36px;
        }

        /* Butonlar */
        .btn-group {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 13px 28px;
            border-radius: 14px;
            font-size: .9rem;
            font-weight: 600;
            text-decoration: none;
            transition: all .25s ease;
            cursor: pointer;
            border: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, #ff6b00, #ff9500);
            color: #fff;
            box-shadow: 0 8px 24px rgba(255,107,0,.35);
        }

            .btn-primary:hover {
                transform: translateY(-3px);
                box-shadow: 0 14px 32px rgba(255,107,0,.5);
                color: #fff;
            }

        .btn-secondary {
            background: rgba(255,255,255,.07);
            color: rgba(255,255,255,.8);
            border: 1px solid rgba(255,255,255,.12);
        }

            .btn-secondary:hover {
                background: rgba(255,255,255,.12);
                color: #fff;
                transform: translateY(-3px);
            }

        /* Yıldızlar */
        .stars {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }

        .star {
            position: absolute;
            width: 2px;
            height: 2px;
            background: #fff;
            border-radius: 50%;
            animation: twinkle var(--d) ease-in-out infinite;
            opacity: 0;
        }

        @@keyframes twinkle {
            0%, 100%

        {
            opacity: 0;
            transform: scale(1);
        }

        50% {
            opacity: var(--o);
            transform: scale(1.5);
        }

        }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            max-width: 320px;
            margin: 0 auto 28px;
            color: rgba(255,255,255,.2);
            font-size: .75rem;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: rgba(255,255,255,.1);
            }
    </style>
</head>
<body>

    <!-- Yıldız efekti -->
    <div class="stars" id="stars"></div>

    <div class="container">
        <div class="error-number">404</div>

        <span class="astronaut">🧑‍🚀</span>

        <h1>Kaybolup Gittiniz!</h1>

        <p>
            Aradığınız sayfa bu evrende mevcut değil.<br />
            Belki silinmiş, taşınmış ya da hiç var olmamış olabilir.
        </p>

        <div class="divider">ne yapmak istersiniz?</div>

        <div class="btn-group">
            <a href="/" class="btn btn-primary">
                <i class="fas fa-home"></i> Ana Sayfaya Dön
            </a>
            <a href="javascript:history.back()" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Geri Git
            </a>
        </div>
    </div>

    <script>
        // Yıldız oluştur
        var starsContainer = document.getElementById('stars');
        for (var i = 0; i < 80; i++) {
            var star = document.createElement('div');
            star.className = 'star';
            star.style.left    = Math.random() * 100 + '%';
            star.style.top     = Math.random() * 100 + '%';
            star.style.setProperty('--d', (2 + Math.random() * 4) + 's');
            star.style.setProperty('--o', (0.3 + Math.random() * 0.7).toFixed(2));
            star.style.animationDelay = (Math.random() * 5) + 's';
            starsContainer.appendChild(star);
        }
    </script>
</body>
</html>