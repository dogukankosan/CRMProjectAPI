@inject CRMProjectUI.APIService.CompanyApiService CompanyService
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    var company = await CompanyService.GetCompanyAsync();
    string apiBase = Config["ApiSettings:BaseUrl"] ?? "";
    string? userPicture = User.FindFirst("Picture")?.Value;
    string avatarSrc = string.IsNullOrEmpty(userPicture)
        ? "/adminThema/assets/img/user.png"
        : $"{apiBase}{userPicture}";
    string fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Kullanıcı";

    // IsAdmin: 0=User, 1=Admin, 2=SuperAdmin
    int isAdminValue = int.TryParse(User.FindFirst("IsAdmin")?.Value, out int av) ? av : 0;
    bool isUser = isAdminValue == 0;
    bool isAdmin = isAdminValue >= 1;
    bool isSuperAdmin = isAdminValue == 2;
    bool isAdminOrSuperAdmin = isAdmin;

    string roleBadgeClass = isSuperAdmin ? "superadmin" : isAdmin ? "admin" : "user";
    string roleText = isSuperAdmin ? "Süper Admin" : isAdmin ? "Admin" : "Kullanıcı";

    string whatsappPhone = !string.IsNullOrEmpty(company?.Phone)
        ? new string(company.Phone.Where(char.IsDigit).ToArray()) : "";
    string whatsappPhone2 = !string.IsNullOrEmpty(company?.Phone2)
        ? new string(company.Phone2.Where(char.IsDigit).ToArray()) : "";

    string faviconUrl = string.IsNullOrEmpty(company?.FaviconPath)
        ? "/adminThema/assets/img/favicon.ico"
        : $"{apiBase}{company.FaviconPath}";
    string logoUrl = string.IsNullOrEmpty(company?.LogoPath)
        ? "/adminThema/assets/img/logo.png"
        : $"{apiBase}{company.LogoPath}";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, shrink-to-fit=no" name="viewport">
    <title>@(company?.MetaTitle ?? company?.WebSiteTitle ?? "Yönetim Paneli")</title>

    @if (!string.IsNullOrEmpty(company?.MetaDescription))
    {
        <meta name="description" content="@company.MetaDescription">
    }
    @if (!string.IsNullOrEmpty(company?.MetaKeywords))
    {
        <meta name="keywords" content="@company.MetaKeywords">
    }
    @if (!string.IsNullOrEmpty(company?.CanonicalUrl))
    {
        <link rel="canonical" href="@company.CanonicalUrl" />
    }
    <meta name="robots" content="index, follow">
    <meta name="googlebot" content="index, follow">

    <meta property="og:locale" content="tr_TR">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="@company?.CompanyName">
    <meta property="og:title" content="@(company?.MetaTitle ?? company?.WebSiteTitle ?? company?.CompanyName)">
    @if (!string.IsNullOrEmpty(company?.MetaDescription))
    {
        <meta property="og:description" content="@company.MetaDescription">
    }
    @if (!string.IsNullOrEmpty(company?.WebSiteLink))
    {
        <meta property="og:url" content="@company.WebSiteLink">
    }
    <meta property="og:image" content="@logoUrl">
    <meta property="og:image:alt" content="@company?.CompanyName Logo">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="@(company?.MetaTitle ?? company?.WebSiteTitle ?? company?.CompanyName)">
    @if (!string.IsNullOrEmpty(company?.MetaDescription))
    {
        <meta name="twitter:description" content="@company.MetaDescription">
    }
    <meta name="twitter:image" content="@logoUrl">

    <script type="application/ld+json">
        {
            "@@context": "https://schema.org",
            "@@type": "Organization",
            "name": "@company?.CompanyName",
            "url": "@company?.WebSiteLink",
            "logo": "@logoUrl"
            @if (!string.IsNullOrEmpty(company?.MetaDescription))
            {
                        @:,"description": "@company.MetaDescription"
            }
            @if (company?.FoundedYear.HasValue == true)
            {
                        @:,"foundingDate": "@company.FoundedYear"
            }
            ,"contactPoint": {
                "@@type": "ContactPoint",
                "telephone": "@company?.Phone",
                "email": "@company?.Email",
                "contactType": "customer service",
                "availableLanguage": "Turkish"
            }
            ,"address": {
                "@@type": "PostalAddress",
                "streetAddress": "@company?.Address",
                "addressCountry": "TR"
            }
            @{
                        var socialLinks = new List<string>();
                        if (!string.IsNullOrEmpty(company?.InstagramLink)) socialLinks.Add($"\"{company.InstagramLink}\"");
                        if (!string.IsNullOrEmpty(company?.LinkedinLink)) socialLinks.Add($"\"{company.LinkedinLink}\"");
                        if (!string.IsNullOrEmpty(company?.YoutubeLink)) socialLinks.Add($"\"{company.YoutubeLink}\"");
            }
            @if (socialLinks.Any())
            {
                        @:,"sameAs": [@Html.Raw(string.Join(",", socialLinks))]
            }
        }
    </script>

    <link rel="shortcut icon" type="image/x-icon" href="@faviconUrl" />
    <link rel="apple-touch-icon" href="@faviconUrl" />

    <link rel="stylesheet" href="~/adminThema/assets/css/app.min.css">
    <link rel="stylesheet" href="~/adminThema/assets/css/style.css">
    <link rel="stylesheet" href="~/adminThema/assets/css/components.css">
    <link rel="stylesheet" href="~/adminThema/assets/css/custom.css">
    <link rel="stylesheet" href="~/adminThema/assets/assets/bundles/datatables/datatables.min.css">
    <link rel="stylesheet" href="~/adminThema/assets/assets/bundles/datatables/DataTables-1.10.16/css/dataTables.bootstrap4.min.css">
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        .whatsapp-link {
            color: #25D366;
            transition: all 0.3s ease;
        }

        .navbar-nav .dropdown.dropdown-list-toggle {
            position: relative;
        }

        .whatsapp-link:hover {
            color: #128C7E;
            transform: scale(1.1);
        }

        .dropdown-list-content a:hover,
        .dropdown-list-content a:hover *,
        .dropdown-list-content a:focus,
        .dropdown-list-content a:focus *,
        [class*="theme-"] .navbar .dropdown-list-content a:hover,
        [class*="theme-"] .navbar .dropdown-list-content a:hover * {
            color: unset !important;
            background: #f8fafd !important;
            text-decoration: none !important;
        }

        .social-link {
            transition: all 0.3s ease;
            margin-left: 8px;
        }

            .social-link:hover {
                transform: scale(1.15);
            }

            .social-link.instagram:hover {
                color: #E4405F;
            }

            .social-link.linkedin:hover {
                color: #0A66C2;
            }

            .social-link.youtube:hover {
                color: #FF0000;
            }

        .footer-divider {
            border-left: 1px solid #dee2e6;
            height: 20px;
            margin: 0 15px;
            display: inline-block;
            vertical-align: middle;
        }

        .user-avatar-nav {
            width: 54px !important;
            height: 54px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(255,255,255,.85);
            box-shadow: 0 3px 8px rgba(0,0,0,.3);
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .user-avatar-nav:hover {
                transform: scale(1.12);
                box-shadow: 0 5px 15px rgba(0,0,0,.4);
                cursor: pointer;
            }

        .role-badge {
            display: inline-block;
            font-size: .65rem;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 10px;
            margin-left: 6px;
            vertical-align: middle;
        }

            .role-badge.superadmin {
                background: #e53e3e;
                color: #fff;
            }

            .role-badge.admin {
                background: #667eea;
                color: #fff;
            }

            .role-badge.user {
                background: #e2e8f0;
                color: #4a5568;
            }

        @@media (max-width: 768px) {
            .main-navbar.sticky {
                top: 30px !important;
            }
        }
        /* ── DUYURU POPUP ── */
        #annPopupOverlay {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: rgba(0,0,0,.55);
            align-items: center;
            justify-content: center;
        }

            #annPopupOverlay.open {
                display: flex;
            }

        .ann-popup {
            background: #fff;
            border-radius: 16px;
            width: 520px;
            max-width: 95vw;
            box-shadow: 0 20px 60px rgba(0,0,0,.25);
            overflow: hidden;
            animation: annSlideIn .3s ease;
        }

        @@keyframes annSlideIn {
            from {
                transform: translateY(-30px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .ann-popup-header {
            padding: 16px 20px;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .ann-popup-badge {
            font-size: .68rem;
            font-weight: 700;
            padding: 3px 9px;
            border-radius: 20px;
            margin-left: 8px;
        }

            .ann-popup-badge.p1 {
                background: #f0fdf4;
                color: #16a34a;
            }

            .ann-popup-badge.p2 {
                background: #fffbeb;
                color: #d97706;
            }

            .ann-popup-badge.p3 {
                background: #fef2f2;
                color: #dc2626;
            }

        .ann-popup-body {
            padding: 20px;
            max-height: 55vh;
            overflow-y: auto;
            font-size: .87rem;
            color: #4a4f5e;
            line-height: 1.6;
        }

        .ann-popup-files {
            padding: 10px 20px;
            border-top: 1px solid #f1f5f9;
            background: #f8fafd;
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .ann-popup-file-link {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: .73rem;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 7px;
            padding: 4px 10px;
            color: #2563eb;
            text-decoration: none;
            transition: background .15s;
        }

            .ann-popup-file-link:hover {
                background: #eff6ff;
                text-decoration: none;
            }

        .ann-popup-footer {
            padding: 14px 20px;
            border-top: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            flex-wrap: wrap;
        }

        .ann-popup-nav {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .78rem;
            color: #94a3b8;
        }

        .ann-popup-nav-btn {
            width: 28px;
            height: 28px;
            border-radius: 7px;
            border: 1px solid #e2e8f0;
            background: #f8fafd;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: .72rem;
            transition: all .15s;
        }

            .ann-popup-nav-btn:hover {
                background: #eff6ff;
                border-color: #2563eb;
                color: #2563eb;
            }

            .ann-popup-nav-btn:disabled {
                opacity: .3;
                cursor: not-allowed;
            }

        .ann-btn-dismiss {
            padding: 7px 14px;
            border-radius: 8px;
            border: 1.5px solid #e2e8f0;
            background: #fff;
            font-size: .78rem;
            font-weight: 600;
            color: #64748b;
            cursor: pointer;
            transition: all .15s;
        }

            .ann-btn-dismiss:hover {
                border-color: #94a3b8;
                color: #475569;
            }

        .ann-btn-ok {
            padding: 7px 18px;
            border-radius: 8px;
            border: none;
            background: #2563eb;
            color: #fff;
            font-size: .78rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .15s;
        }

            .ann-btn-ok:hover {
                background: #1d4ed8;
            }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <script>
        (function () {
            var theme = localStorage.getItem('sidebar-color');
            if (theme) document.body.classList.add('theme-' + theme);
            if (localStorage.getItem('layout-color') === '2') document.body.classList.add('dark');
            if (localStorage.getItem('mini-sidebar') === 'true') document.body.classList.add('sidebar-mini');
        })();
    </script>
    <div class="loader"></div>
    <div id="app">
        <div class="main-wrapper main-wrapper-1">
            <div class="navbar-bg"></div>

            @* ── NAVBAR ── *@
            <nav class="navbar navbar-expand-lg main-navbar sticky">
                <div class="form-inline mr-auto">
                    <ul class="navbar-nav mr-3">
                        <li>
                            <a href="#" data-toggle="sidebar" class="nav-link nav-link-lg collapse-btn">
                                <i data-feather="align-justify"></i>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="nav-link nav-link-lg fullscreen-btn">
                                <i data-feather="maximize"></i>
                            </a>
                        </li>
                    </ul>
                </div>
                <ul class="navbar-nav navbar-right">
                    @* Bildirimler *@
                    <li class="dropdown dropdown-list-toggle">
                        <a href="#" data-toggle="dropdown" class="nav-link notification-toggle nav-link-lg">
                            <i data-feather="bell" class="bell"></i>
                            <span id="myNotifBadge" style="display:none; position:absolute; top:6px; right:2px; background:#ef4444; color:#fff !important; font-size:.6rem; font-weight:700; min-width:16px; height:16px; padding:0 4px; border-radius:8px; display:flex; align-items:center; justify-content:center; line-height:1; z-index:10;"></span>
                        </a>
                        <div class="dropdown-menu dropdown-list dropdown-menu-right pullDown" style="width:340px;">
                            <div class="dropdown-header">
                                <i class="fas fa-ticket-alt mr-1"></i> Üzerimdeki Açık Ticketlar
                            </div>
                            <div class="dropdown-list-content dropdown-list-icons" id="myNotifList">
                                <div class="text-center p-3" style="color:#94a3b8; font-size:.82rem;">
                                    <i class="fas fa-spinner fa-spin mr-1"></i> Yükleniyor...
                                </div>
                            </div>
                            <div class="dropdown-footer text-center">
                                <a href="/AdminTicket/Liste">Tüm Ticketlar <i class="fas fa-chevron-right"></i></a>
                            </div>
                        </div>
                    </li>
                    <li class="dropdown dropdown-list-toggle">
                        <a href="#" data-toggle="dropdown" class="nav-link notification-toggle nav-link-lg">
                            <i data-feather="message-square"></i>
                            <span id="companyNotifBadge" style="display:none; position:absolute; top:6px; right:2px; background:#7c3aed; color:#fff !important; font-size:.6rem; font-weight:700; min-width:16px; height:16px; padding:0 4px; border-radius:8px; display:flex; align-items:center; justify-content:center; line-height:1; z-index:10;"></span>
                        </a>
                        <div class="dropdown-menu dropdown-list dropdown-menu-right pullDown" style="width:360px;">
                            <div class="dropdown-header">
                                <i class="fas fa-comments mr-1"></i> Firma Yorumları & Dosyaları
                            </div>
                            <div class="dropdown-list-content dropdown-list-icons" id="companyNotifList">
                                <div class="text-center p-3" style="color:#94a3b8; font-size:.82rem;">
                                    <i class="fas fa-spinner fa-spin mr-1"></i> Yükleniyor...
                                </div>
                            </div>
                            <div class="dropdown-footer text-center">
                                <a href="/AdminTicket/Liste">Tüm Ticketlar <i class="fas fa-chevron-right"></i></a>
                            </div>
                        </div>
                    </li>
                    @* Kullanıcı Menüsü *@
                    <li class="dropdown">
                        <a href="#" data-toggle="dropdown" class="nav-link dropdown-toggle nav-link-lg nav-link-user">
                            @if (!string.IsNullOrEmpty(userPicture))
                            {
                                <img alt="@fullName" src="@avatarSrc" class="user-avatar-nav" />
                            }
                            else
                            {
                                string initials = string.Concat(
                                fullName.Split(' ')
                                .Where(w => w.Length > 0)
                                .Take(2)
                                .Select(w => w[0].ToString().ToUpper()));
                                if (string.IsNullOrEmpty(initials))
                                    initials = fullName.Length >= 1 ? fullName[0].ToString().ToUpper() : "?";

                                <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;color:#fff !important;font-weight:700;font-size:.85rem;border:2px solid rgba(255,255,255,.3);">
                                    @initials
                                </div>
                            }
                        </a>
                        <div class="dropdown-menu dropdown-menu-right pullDown">
                            <div class="dropdown-title">
                                Merhaba, @fullName
                                <span class="role-badge @roleBadgeClass">@roleText</span>
                            </div>
                            <a href="/AdminKullanici/Profil" class="dropdown-item has-icon">
                                <i class="fas fa-user"></i> Profilim
                            </a>
                            <div class="dropdown-divider"></div>
                            <form asp-action="Logout" asp-controller="Auth" method="post" style="margin:0;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="dropdown-item has-icon text-danger"
                                        style="background:none;border:none;width:100%;text-align:left;cursor:pointer;padding:.25rem 1.5rem;">
                                    <i class="fas fa-sign-out-alt"></i> Çıkış Yap
                                </button>
                            </form>
                        </div>
                    </li>
                </ul>
            </nav>

            @* ── SIDEBAR ── *@
            <div class="main-sidebar sidebar-style-2">
                <aside id="sidebar-wrapper">
                    <div class="sidebar-brand">
                        <a href="/">
                            <img alt="@company?.CompanyName Logo" src="@logoUrl" class="header-logo" />
                            <br />
                            <span class="logo-name">@company?.ShortCompanyName</span>
                        </a>
                        @if (!string.IsNullOrEmpty(company?.Slogan))
                        {
                            <div style="font-size:9px;color:#888;margin-top:-15px;text-transform:none;">
                                @company.Slogan
                            </div>
                        }
                    </div>
                    <hr />
                    <ul class="sidebar-menu">
                        <li>
                            <a href="/" class="nav-link">
                                <i data-feather="monitor"></i><span>Anasayfa</span>
                            </a>
                        </li>

                        <li class="dropdown">
                            <a href="#" class="menu-toggle nav-link has-dropdown">
                                <i data-feather="life-buoy"></i><span>Destek Talepleri</span>
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="nav-link" href="/AdminTicket/Liste">Aktif Talepler</a></li>
                                <li><a class="nav-link" href="/AdminTicket/Ekle">Yeni Talep Oluştur</a></li>
                            </ul>
                        </li>

                        <li class="dropdown">
                            <a href="#" class="menu-toggle nav-link has-dropdown">
                                <i data-feather="book-open"></i><span>Bilgi Bankası</span>
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="nav-link" href="/AdminBilgiBankasi/Liste">Dökümanlar</a></li>
                                @if (isAdmin)
                                {
                                    <li><a class="nav-link" href="/AdminBilgiBankasi/Ekle">Yeni Makale</a></li>
                                }
                            </ul>
                        </li>

                        @if (isAdmin)
                        {
                            <li class="dropdown">
                                <a href="#" class="menu-toggle nav-link has-dropdown">
                                    <i data-feather="users"></i><span>Müşteriler</span>
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="nav-link" href="/AdminMusteri/Liste">Müşteri Listesi</a></li>
                                </ul>
                            </li>
                        }

                        <li class="dropdown">
                            <a href="#" class="menu-toggle nav-link has-dropdown">
                                <i data-feather="bar-chart-2"></i><span>Raporlar</span>
                            </a>
                            <ul class="dropdown-menu">
                                @if (isSuperAdmin || isAdmin)
                                {
                                    <li><a class="nav-link" href="/AdminTicket/BenimRaporom">Performansım</a></li>
                                }
                                @if (isSuperAdmin)
                                {
                                    <li><a class="nav-link" href="/AdminTicket/Rapor">Ticket Analizi</a></li>
                                }
                                @if (isUser)
                                {
                                    <li><a class="nav-link" href="/AdminTicket/UserRapor">Analizlerim</a></li>
                                }
                                <li>
                                    <a class="nav-link" href="/AdminTicket/TumTalepler">
                                        @if (isUser)
                                        {
                                            <text>Tüm Taleplerim</text>
                                        }
                                        else
                                        {

                                            <text>Tüm Talepler</text>
                                        }
                                    </a>
                                </li>
                            </ul>
                        </li>
                        @if (isAdmin)
                        {
                            <li class="dropdown">
                                <a href="#" class="menu-toggle nav-link has-dropdown">
                                    <i data-feather="bell"></i><span>Duyurular</span>
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="nav-link" href="/AdminDuyuru/Liste">Duyuru Listesi</a></li>
                                    <li><a class="nav-link" href="/AdminDuyuru/Ekle">Yeni Duyuru</a></li>
                                </ul>
                            </li>
                        }
                        @if (isSuperAdmin)
                        {
                            <li class="dropdown">
                                <a href="#" class="menu-toggle nav-link has-dropdown">
                                    <i data-feather="briefcase"></i><span>Şirket Bilgileri</span>
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="nav-link" href="/AdminSirket/Liste">Şirket Tanımı</a></li>
                                </ul>
                            </li>
                            <li class="dropdown">
                                <a href="#" class="menu-toggle nav-link has-dropdown">
                                    <i data-feather="settings"></i><span>Ayarlar</span>
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="nav-link" href="/AdminMail/Ayarlar">Mail Ayarları</a></li>
                                    <li>
                                        <a class="nav-link" href="/AdminHataLog/Liste">
                                            <i class="fas fa-bug mr-1" style="font-size:.75rem;color:#ef4444;"></i>Hata Logları
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </aside>
            </div>

            @* ── ANA İÇERİK ── *@
            <div class="main-content">
                <section class="section">
                    <!-- ── DUYURU POPUP ── -->
                    <div id="annPopupOverlay">
                        <div class="ann-popup">
                            <div class="ann-popup-header">
                                <div style="display:flex;align-items:center;">
                                    <i class="fas fa-bullhorn" style="color:#2563eb;margin-right:8px;"></i>
                                    <span style="font-weight:700;font-size:.95rem;color:#0f1117;" id="annPopupTitle"></span>
                                    <span class="ann-popup-badge" id="annPopupBadge"></span>
                                </div>
                                <span style="font-size:.72rem;color:#94a3b8;" id="annPopupMeta"></span>
                            </div>
                            <div class="ann-popup-body" id="annPopupBody"></div>
                            <div class="ann-popup-files" id="annPopupFiles" style="display:none;"></div>
                            <div class="ann-popup-footer">
                                <div class="ann-popup-nav">
                                    <button class="ann-popup-nav-btn" id="annPrevBtn" onclick="annNavigate(-1)">
                                        <i class="fas fa-chevron-left"></i>
                                    </button>
                                    <span id="annNavInfo"></span>
