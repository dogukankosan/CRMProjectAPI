                                '</div>' +
                            '</a>';
                    });

                    list.innerHTML = html;
                })
                .catch(function() {
                    var list = document.getElementById('companyNotifList');
                    if (list) list.innerHTML = '<div style="padding:20px;text-align:center;color:#94a3b8;font-size:.8rem;"><i class="fas fa-exclamation-circle mr-1"></i>Yüklenemedi</div>';
                });
      
        }, 1000);
 
        
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        var __companyId = '@(User.FindFirst("CompanyId")?.Value ?? "0")';
        var __userId    = '@(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0")';
        var __isAdmin   = @(isAdminOrSuperAdmin ? "true" : "false");
        var __apiBase   = '@(Config["ApiSettings:BaseUrl"] ?? "")';

        function playNotifSound() {
            try {
                var ctx = new (window.AudioContext || window.webkitAudioContext)();

                function playTone(freq, startTime, duration, volume) {
                    var osc = ctx.createOscillator();
                    var gain = ctx.createGain();
                    osc.connect(gain);
                    gain.connect(ctx.destination);
                    osc.frequency.setValueAtTime(freq, startTime);
                    osc.type = 'sine';
                    gain.gain.setValueAtTime(0, startTime);
                    gain.gain.linearRampToValueAtTime(volume, startTime + 0.02);
                    gain.gain.setValueAtTime(volume, startTime + duration - 0.05);
                    gain.gain.exponentialRampToValueAtTime(0.001, startTime + duration);
                    osc.start(startTime);
                    osc.stop(startTime + duration);
                }

                playTone(1046, ctx.currentTime,        0.18, 1.0); // Do
                playTone(1318, ctx.currentTime + 0.2,  0.18, 0.9); // Mi
                playTone(1568, ctx.currentTime + 0.4,  0.28, 1.0); // Sol

            } catch(e) {}
        }

        var ticketConnection = new signalR.HubConnectionBuilder()
            .withUrl(__apiBase + '/hubs/ticket')
            .withAutomaticReconnect()
            .build();

        ticketConnection.start().then(function() {
            if (__isAdmin) {
                ticketConnection.invoke('JoinGroup', 'admins');
            }
            if (__companyId && __companyId !== '0') {
                ticketConnection.invoke('JoinGroup', 'customer_' + __companyId);
            }
        }).catch(function(err) {
            console.error('SignalR bağlantı hatası:', err);
        });

             ticketConnection.on('TicketCreated', function(data) {
            playNotifSound();
            refreshMyNotifications();
            Swal.fire({
                toast: true, position: 'top-end', icon: 'info',
                title: 'Yeni Ticket: ' + data.ticketNo,
                text: data.title,
                showConfirmButton: false, timer: 5000, timerProgressBar: true
            });
            // refreshTable sadece admin listesinde tanımlıysa çağır
            if (typeof refreshTable === 'function') refreshTable();
        });

        ticketConnection.on('TicketUpdated', function(data) {
            playNotifSound();
            refreshMyNotifications();
            Swal.fire({
                toast: true, position: 'top-end', icon: 'info',
                title: 'Ticket Güncellendi',
                text: data.ticketNo ? ('#' + data.ticketNo) : '',
                showConfirmButton: false, timer: 4000, timerProgressBar: true
            });
            if (typeof refreshTable === 'function') refreshTable();
        });

        ticketConnection.on('CommentAdded', function(data) {
            playNotifSound();
            refreshCompanyNotifications();
            Swal.fire({
                toast: true, position: 'top-end', icon: 'info',
                title: 'Yeni Yorum',
                showConfirmButton: false, timer: 4000, timerProgressBar: true
            });
        });

        ticketConnection.on('FileAdded', function(data) {
            playNotifSound();
            refreshCompanyNotifications();
            Swal.fire({
                toast: true, position: 'top-end', icon: 'info',
                title: 'Yeni Dosya Eklendi',
                showConfirmButton: false, timer: 4000, timerProgressBar: true
            });
        });
                // ── DUYURU POPUP ──
        var __announcements  = [];
        var __annIndex       = 0;
        var __annApiBase     = '@(Config["ApiSettings:BaseUrl"] ?? "")';
        var __annJwtToken    = '@(User.FindFirst("JwtToken")?.Value ?? "")';

        function loadAnnouncements() {
            fetch('/Notification/Announcements')
                .then(function(r){ return r.json(); })
                .then(function(data) {
                    if (!data || !data.length) return;
                    __announcements = data;
                    __annIndex = 0;
                    annRender();
                    document.getElementById('annPopupOverlay').classList.add('open');
                })
                .catch(function(){});
        }

        function annRender() {
            var ann  = __announcements[__annIndex];
            if (!ann) return;

            // Başlık
            document.getElementById('annPopupTitle').textContent = ann.title;

            // Öncelik badge
            var badge = document.getElementById('annPopupBadge');
            var pLabels = { 1:'Normal', 2:'Önemli', 3:'Kritik' };
            badge.textContent  = pLabels[ann.priority] || 'Normal';
            badge.className    = 'ann-popup-badge p' + ann.priority;

            // Meta
            document.getElementById('annPopupMeta').textContent =
                new Date(ann.createdDate).toLocaleDateString('tr-TR');

            // İçerik (HTML — Quill ile yazıldı)
            document.getElementById('annPopupBody').innerHTML = ann.content || '';

            // Dosyalar
            var filesDiv = document.getElementById('annPopupFiles');
            if (ann.files && ann.files.length > 0) {
                filesDiv.style.display = 'flex';
                filesDiv.innerHTML = '';
                ann.files.forEach(function(f) {
                    var a = document.createElement('a');
                    a.href = '/AdminDuyuru/Dosya/' + f.id;
                    a.target = '_blank';
                    a.download = '';
                    a.className = 'ann-popup-file-link';
                    a.innerHTML = '<i class="fas fa-file" style="font-size:.65rem;"></i>' + f.originalFileName;
                    filesDiv.appendChild(a);
                });
            } else {
                filesDiv.style.display = 'none';
            }

            // Navigasyon
            var total = __announcements.length;
            document.getElementById('annNavInfo').textContent =
                total > 1 ? (__annIndex + 1) + ' / ' + total : '';
            document.getElementById('annPrevBtn').disabled = __annIndex === 0;
            document.getElementById('annNextBtn').disabled = __annIndex === total - 1;
        }

        function annNavigate(dir) {
            var newIdx = __annIndex + dir;
            if (newIdx < 0 || newIdx >= __announcements.length) return;
            __annIndex = newIdx;
            annRender();
        }

        function annClose() {
            document.getElementById('annPopupOverlay').classList.remove('open');
        }

        function annDismiss() {
            var ann = __announcements[__annIndex];
            if (!ann) return;

            fetch('/Notification/DuyuruKapat/' + ann.id, { method: 'POST' })
                .then(function(){})
                .catch(function(){});

            __announcements.splice(__annIndex, 1);

            if (__announcements.length === 0) {
                annClose();
                return;
            }
            if (__annIndex >= __announcements.length)
                __annIndex = __announcements.length - 1;
            annRender();
        }

        // SignalR — yeni duyuru gelince popup'a ekle
        ticketConnection.on('AnnouncementCreated', function(data) {
            playNotifSound();
            // Listeyi yenile
            fetch('/Notification/Announcements')
                .then(function(r){ return r.json(); })
                .then(function(list) {
                    if (!list || !list.length) return;
                    __announcements = list;
                    __annIndex = 0;
                    annRender();
                    document.getElementById('annPopupOverlay').classList.add('open');
                })
                .catch(function(){});

            Swal.fire({
                toast: true, position: 'top-end', icon: 'info',
                title: 'Yeni Duyuru',
                text: data.title,
                showConfirmButton: false, timer: 4000, timerProgressBar: true
            });
        });

        // Sayfa açılınca duyuruları yükle
        // Sayfa açılınca duyuruları yükle
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                loadAnnouncements();
            }, 2000);
        });
        function refreshMyNotifications() {
            fetch('/Notification/MyNotifications')
                .then(function(r){ return r.json(); })
                .then(function(data) {
                    var list  = document.getElementById('myNotifList');
                    var badge = document.getElementById('myNotifBadge');
                    if (!badge) return;

                    if (!data || !data.tickets || data.tickets.length === 0) {
                        badge.style.display = 'none';
                        if (list) list.innerHTML =
                            '<div style="padding:24px;text-align:center;">' +
                            '<div style="width:44px;height:44px;border-radius:50%;background:#f0fdf4;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">' +
                            '<i class="fas fa-check" style="color:#10b981;font-size:1.1rem;"></i></div>' +
                            '<div style="font-size:.82rem;font-weight:600;color:#0f1117;">Harika!</div>' +
                            '<div style="font-size:.75rem;color:#94a3b8;margin-top:3px;">Üzerinizde açık ticket yok</div>' +
                            '</div>';
                        return;
                    }

                    badge.textContent = data.count > 9 ? '9+' : data.count;
                    badge.style.display = 'flex';

                    if (!list) return;
                    var prioMap = {
                        4: { color:'#ef4444', bg:'#fef2f2', icon:'fa-fire' },
                        3: { color:'#f59e0b', bg:'#fffbeb', icon:'fa-arrow-up' },
                        2: { color:'#3b82f6', bg:'#eff6ff', icon:'fa-minus' },
                        1: { color:'#94a3b8', bg:'#f1f5f9', icon:'fa-arrow-down' }
                    };

                    var html = '';
                    data.tickets.forEach(function(t) {
                        var p         = prioMap[t.priority] || prioMap[2];
                        var waitH     = t.waitingHours || 0;
                        var waitColor = waitH > 48 ? '#ef4444' : waitH > 24 ? '#f59e0b' : '#94a3b8';
                        var waitTxt   = waitH > 0 ? waitH + ' sa önce' : 'Az önce';
                        html +=
                            '<a href="/AdminTicket/Detay/' + t.id + '" style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-bottom:1px solid #f1f5f9;text-decoration:none;transition:background .15s;" onmouseover="this.style.background=\'#f8fafd\'" onmouseout="this.style.background=\'\'">'+
                                '<div style="width:36px;height:36px;border-radius:10px;background:' + p.bg + ';display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
                                    '<i class="fas ' + p.icon + '" style="color:' + p.color + ';font-size:.8rem;"></i>' +
                                '</div>' +
                                '<div style="flex:1;min-width:0;">' +
                                    '<div style="display:flex;align-items:center;justify-content:space-between;gap:6px;">' +
                                        '<span style="font-size:.75rem;font-family:monospace;font-weight:700;color:' + p.color + ';">' + t.ticketNo + '</span>' +
                                        '<span style="font-size:.68rem;color:' + waitColor + ';white-space:nowrap;">' + waitTxt + '</span>' +
                                    '</div>' +
                                    '<div style="font-size:.78rem;font-weight:600;color:#0f1117;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;">' + (t.title.length > 38 ? t.title.substring(0,38) + '…' : t.title) + '</div>' +
                                    '<div style="font-size:.7rem;color:#94a3b8;margin-top:2px;">' +
                                        '<i class="fas fa-building" style="font-size:.6rem;margin-right:3px;"></i>' + (t.customerName || '') +
                                    '</div>' +
                                '</div>' +
                            '</a>';
                    });
                    list.innerHTML = html;
                })
                .catch(function(){});
        }

        function refreshCompanyNotifications() {
            fetch('/Notification/CompanyNotifications')
                .then(function(r){ return r.json(); })
                .then(function(data) {
                    var list  = document.getElementById('companyNotifList');
                    var badge = document.getElementById('companyNotifBadge');
                    if (!badge) return;

                    if (!data || data.totalCount === 0) {
                        badge.style.display = 'none';
                        if (list) list.innerHTML =
                            '<div style="padding:24px;text-align:center;">' +
                            '<div style="width:44px;height:44px;border-radius:50%;background:#f0fdf4;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;">' +
                            '<i class="fas fa-check" style="color:#10b981;font-size:1.1rem;"></i></div>' +
                            '<div style="font-size:.82rem;font-weight:600;color:#0f1117;">Yeni aktivite yok</div>' +
                            '<div style="font-size:.75rem;color:#94a3b8;margin-top:3px;">Firma ticketlarında son aktivite bulunmuyor</div>' +
                            '</div>';
                        return;
                    }

                    badge.textContent = data.totalCount > 9 ? '9+' : data.totalCount;
                    badge.style.display = 'flex';

                    if (!list) return;
                    var html = '';

                    (data.comments || []).forEach(function(c) {
                        html +=
                            '<a href="/AdminTicket/Detay/' + c.ticketID + '" style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-bottom:1px solid #f1f5f9;text-decoration:none;transition:background .15s;" onmouseover="this.style.background=\'#f8fafd\'" onmouseout="this.style.background=\'\'">'+
                                '<div style="width:36px;height:36px;border-radius:10px;background:#eff6ff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
                                    '<i class="fas fa-comment-alt" style="color:#2563eb;font-size:.8rem;"></i>' +
                                '</div>' +
                                '<div style="flex:1;min-width:0;">' +
                                    '<div style="display:flex;align-items:center;justify-content:space-between;gap:6px;">' +
                                        '<span style="font-size:.75rem;font-family:monospace;font-weight:700;color:#2563eb;">' + c.ticketNo + '</span>' +
                                        '<span style="font-size:.68rem;color:#94a3b8;white-space:nowrap;">' + (c.elapsedText || '') + '</span>' +
                                    '</div>' +
                                    '<div style="font-size:.78rem;font-weight:600;color:#0f1117;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;">' + (c.title || '') + '</div>' +
                                    '<div style="font-size:.7rem;color:#94a3b8;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' +
                                        '<i class="fas fa-user" style="font-size:.6rem;margin-right:3px;"></i>' + (c.userFullName || '') +
                                        ' — ' + (c.shortComment || '') +
                                    '</div>' +
                                '</div>' +
                            '</a>';
                    });

                    (data.files || []).forEach(function(f) {
                        html +=
                            '<a href="/AdminTicket/Detay/' + f.ticketID + '" style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-bottom:1px solid #f1f5f9;text-decoration:none;transition:background .15s;" onmouseover="this.style.background=\'#f8fafd\'" onmouseout="this.style.background=\'\'">'+
                                '<div style="width:36px;height:36px;border-radius:10px;background:#fffbeb;display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
                                    '<i class="fas fa-paperclip" style="color:#f59e0b;font-size:.8rem;"></i>' +
                                '</div>' +
                                '<div style="flex:1;min-width:0;">' +
                                    '<div style="display:flex;align-items:center;justify-content:space-between;gap:6px;">' +
                                        '<span style="font-size:.75rem;font-family:monospace;font-weight:700;color:#f59e0b;">' + f.ticketNo + '</span>' +
                                        '<span style="font-size:.68rem;color:#94a3b8;white-space:nowrap;">' + (f.elapsedText || '') + '</span>' +
                                    '</div>' +
                                    '<div style="font-size:.78rem;font-weight:600;color:#0f1117;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;">' + (f.title || '') + '</div>' +
                                    '<div style="font-size:.7rem;color:#94a3b8;margin-top:2px;">' +
                                        '<i class="fas fa-file" style="font-size:.6rem;margin-right:3px;"></i>' + (f.originalFileName || '') +
                                        ' · ' + (f.uploadedByName || '') +
                                    '</div>' +
                                '</div>' +
                            '</a>';
                    });

                    list.innerHTML = html;
                })
                .catch(function(){});
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
