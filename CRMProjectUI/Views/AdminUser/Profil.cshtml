    };

    function formatPhoneNumber(digits, code) {
        var cfg = phoneFormats[code] || phoneFormats["_default"];
        var clean = digits.replace(/\D/g, '').substring(0, cfg.max);
        var result = '';
        var pos = 0;
        for (var i = 0; i < cfg.pattern.length; i++) {
            if (pos >= clean.length) break;
            var part = clean.substr(pos, cfg.pattern[i]);
            if (part) result += part + ' ';
            pos += cfg.pattern[i];
        }
        return result.trim();
    }

    // ── Telefon Init ──
    document.addEventListener('DOMContentLoaded', function () {
        var select = document.getElementById('phoneCountryCode');
        var input  = document.getElementById('inputPhone');
        if (!select || !input) return;

        var current = input.value.trim();
        if (current) {
            // Uzundan kısaya sırala — +964 ile +9 çakışmasın
            var codes = Object.keys(phoneFormats)
                .filter(function (k) { return k !== '_default'; })
                .sort(function (a, b) { return b.length - a.length; });
            for (var i = 0; i < codes.length; i++) {
                if (current.startsWith(codes[i])) {
                    select.value = codes[i];
                    var digits = current.substring(codes[i].length).replace(/\D/g, '');
                    input.value = formatPhoneNumber(digits, codes[i]);
                    break;
                }
            }
        }

        select.addEventListener('change', function () {
            input.value = '';
            input.focus();
        });

        input.addEventListener('input', function (e) {
            var code = select.value;
            var cfg  = phoneFormats[code] || phoneFormats["_default"];
            if (e.inputType === 'deleteContentBackward' || e.inputType === 'deleteContentForward') return;
            var digits = this.value.replace(/\D/g, '').substring(0, cfg.max);
            this.value = formatPhoneNumber(digits, code);
        });
    });

    // ── Fotoğraf Önizleme ──
    document.getElementById('PictureFile').addEventListener('change', function () {
        var file = this.files[0];
        if (!file) return;

        if (file.size > 5 * 1024 * 1024) {
            Swal.fire({ icon: 'error', title: 'Hata!', text: 'Dosya 5MB\'dan büyük olamaz' });
            this.value = '';
            return;
        }

        var reader = new FileReader();
        reader.onload = function (e) {
            var src = e.target.result;
            var ring = document.querySelector('.avatar-ring');
            ring.classList.remove('no-image');
            document.getElementById('avatarInner').innerHTML =
                '<img src="' + src + '" style="width:100%;height:100%;object-fit:cover;" />';

            var thumb = document.getElementById('picThumb');
            var ph    = document.getElementById('picThumbPlaceholder');
            if (thumb) {
                thumb.src = src;
            } else if (ph) {
                ph.outerHTML = '<img src="' + src + '" class="pic-thumb" id="picThumb" alt="Profil" />';
            }

            document.getElementById('picFileName').textContent = file.name;
        };
        reader.readAsDataURL(file);
    });

    // ── Hero isim / baş harf canlı güncelle ──
    document.getElementById('inputFullName').addEventListener('input', function () {
        var val = this.value.trim();
        document.getElementById('heroName').textContent = val || 'Kullanıcı';

        var avatarImg = document.querySelector('#avatarInner img');
        if (!avatarImg) {
            var ini = val.split(' ').filter(Boolean).slice(0, 2)
                .map(function (w) { return w[0].toUpperCase(); }).join('') || '?';
            var ph     = document.getElementById('avatarPlaceholder');
            var cardPh = document.getElementById('picThumbPlaceholder');
            if (ph)     ph.textContent     = ini;
            if (cardPh) cardPh.textContent = ini;
        }
    });

    document.getElementById('inputEmail').addEventListener('input', function () {
        document.getElementById('heroEmail').textContent = this.value;
    });

    // ── Şifre göster/gizle ──
    function togglePass(inputId, iconId) {
        var inp = document.getElementById(inputId);
        var ico = document.getElementById(iconId);
        if (inp.type === 'password') {
            inp.type = 'text';
            ico.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            inp.type = 'password';
            ico.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }

    // ── Şifre güç göstergesi ──
    document.getElementById('newPass').addEventListener('input', function () {
        var val  = this.value;
        var fill = document.getElementById('strengthFill');
        var text = document.getElementById('strengthText');
        if (!val) { fill.style.width = '0%'; text.textContent = ''; return; }

        var score = 0;
        if (val.length >= 6)              score++;
        if (val.length >= 10)             score++;
        if (/[A-Z]/.test(val))            score++;
        if (/[0-9]/.test(val))            score++;
        if (/[^A-Za-z0-9]/.test(val))     score++;

        var configs = [
            { w: '20%',  bg: '#ff4757', label: 'Çok zayıf', color: '#ff4757' },
            { w: '40%',  bg: '#ff6b00', label: 'Zayıf',     color: '#ff6b00' },
            { w: '60%',  bg: '#ffa502', label: 'Orta',       color: '#ffa502' },
            { w: '80%',  bg: '#2ed573', label: 'Güçlü',      color: '#2ed573' },
            { w: '100%', bg: '#1e90ff', label: 'Çok güçlü',  color: '#1e90ff' }
        ];
        var c = configs[score - 1] || configs[0];
        fill.style.width      = c.w;
        fill.style.background = c.bg;
        text.textContent      = c.label;
        text.style.color      = c.color;
    });

    // ── Şifre eşleşme ──
    function checkMatch() {
        var p1 = document.getElementById('newPass').value;
        var p2 = document.getElementById('confirmPass').value;
        document.getElementById('passMatchError').style.display = (p2 && p1 !== p2) ? 'block' : 'none';
    }
    document.getElementById('confirmPass').addEventListener('input', checkMatch);
    document.getElementById('newPass').addEventListener('input', checkMatch);

    // ── Form Submit ──
    document.getElementById('profilForm').addEventListener('submit', function (e) {
        var p1     = document.getElementById('newPass').value;
        var p2     = document.getElementById('confirmPass').value;
        var select = document.getElementById('phoneCountryCode');
        var input  = document.getElementById('inputPhone');
            var digits = input.value.replace(/\D/g, '');

    // ── Telefon zorunlu kontrol ──
    if (digits.length === 0) {
        e.preventDefault();
        input.focus();
        Swal.fire({
            icon: 'warning',
            title: 'Eksik Alan!',
            text: 'Lütfen telefon numaranızı giriniz.'
        });
        return false;
    }

    // ── Minimum rakam sayısı ──
    var cfg = phoneFormats[select.value] || phoneFormats['_default'];
    if (digits.length < cfg.max) {
        e.preventDefault();
        input.focus();
        Swal.fire({
            icon: 'warning',
            title: 'Geçersiz Numara!',
            text: 'Telefon numarası eksik görünüyor. Lütfen kontrol ediniz.'
        });
        return false;
    }

        if (p1 && p1 !== p2) {
            e.preventDefault();
            document.getElementById('passMatchError').style.display = 'block';
            document.getElementById('confirmPass').focus();
            return false;
        }

        // Telefonu birleştir — boşsa temizle
        if (select && input) {
            var digits = input.value.replace(/\D/g, '');
            if (digits.length > 0) {
                input.value = select.value + ' ' + input.value.trim();
            } else {
                input.value = '';
            }
        }

        document.getElementById('submitBtn').disabled          = true;
        document.getElementById('btnText').style.display       = 'none';
        document.getElementById('btnSpinner').style.display    = 'inline';
    });

    // ── Resim Sil ──
    function resimSil() {
        Swal.fire({
            title: 'Emin misiniz?',
            text: 'Profil fotoğrafınız silinecek!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="fas fa-trash"></i> Evet, Sil',
            cancelButtonText: 'İptal'
        }).then(function (result) {
            if (!result.isConfirmed) return;

            fetch('/AdminKullanici/ResimSilProfil', {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value,
                    'Content-Type': 'application/json'
                }
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.success) {
                    var ini = document.getElementById('heroName').textContent.trim()
                        .split(' ').filter(Boolean).slice(0, 2)
                        .map(function (w) { return w[0].toUpperCase(); }).join('') || '?';

                    var ring = document.querySelector('.avatar-ring');
                    ring.classList.add('no-image');
                    document.getElementById('avatarInner').innerHTML =
                        '<span class="avatar-placeholder" id="avatarPlaceholder">' + ini + '</span>';

                    var thumb = document.getElementById('picThumb');
                    if (thumb) {
                        thumb.outerHTML =
                            '<div class="pic-thumb-placeholder" id="picThumbPlaceholder">' + ini + '</div>';
                    }

                    var btn = document.getElementById('btnResimSil');
                    if (btn) btn.style.display = 'none';

                    Swal.fire({
                        icon: 'success',
                        title: 'Silindi!',
                        text: 'Profil fotoğrafınız silindi.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    Swal.fire({ icon: 'error', title: 'Hata!', text: data.message });
                }
            })
            .catch(function () {
                Swal.fire({ icon: 'error', title: 'Bağlantı Hatası', text: 'Sunucuya ulaşılamadı.' });
            });
        });
    }
</script>
