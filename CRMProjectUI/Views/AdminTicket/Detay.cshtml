{
    <div id="assignModal" class="td-modal">
        <div class="td-modal-box">
            <div class="td-modal-header">
                <h6>
                    <i class="fas fa-user-check mr-2" style="color:var(--purple);"></i>
                    Ticket Devret
                </h6>
                <button onclick="closeAssignModal()"
                        style="border:none;background:none;font-size:1.1rem;color:var(--ink-soft);cursor:pointer;">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="td-modal-body">
                <div>
                    <label class="td-label">Atanacak Kişi</label>
                    <select id="assignUserSelect" class="td-select">
                        <option value="">Seçiniz...</option>
                        @foreach (var u in adminUsers)
                        {
                            <option value="@u.ID" selected="@(Model.AssignedToUserID == u.ID)">
