<div id="tempData"
     data-success="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMsg ?? ""))"
     data-error="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(errorMsg ?? ""))"
     data-warn="@Html.Raw(System.Text.Json.JsonSerializer.Serialize(warnMsg ?? ""))">
</div>
@section Scripts {
<script>
          var ticketId = @Model.ID;
        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        window.addEventListener('load', function () {
            var s = '@Html.Raw(successMsg?.Replace("'", "\\'") ?? "")';
            var e = '@Html.Raw(errorMsg?.Replace("'", "\\'") ?? "")';
            var w = '@Html.Raw(warnMsg?.Replace("'", "\\'") ?? "")';

            if (s && s.trim() !== '') Swal.fire({ icon:'success', title:'Başarılı!', text:s, timer:2500, showConfirmButton:false });
            if (e && e.trim() !== '') Swal.fire({ icon:'error',   title:'Hata!',     text:e });
            if (w && w.trim() !== '') Swal.fire({ icon:'warning', title:'Uyarı',     text:w, timer:3000 });
        });

        // ── YORUM COUNTER ──
        function updateCommentCounter(el) {
            document.getElementById('commentCounter').textContent = el.value.length + ' / 4000';
        }

        // ── YORUM FORM ──
        document.getElementById('commentForm')?.addEventListener('submit', function(e) {
            var val = document.getElementById('commentInput').value.trim();
            if (!val) {
                e.preventDefault();
                Swal.fire({ icon:'warning', title:'Boş Yorum', text:'Yorum alanı boş olamaz.' });
                return;
            }
            var btn = document.getElementById('commentBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Ekleniyor...';
        });

        // ── DOSYA YÜKLEME ──
        function submitFileForm() {
            var input = document.getElementById('fileInput');
            if (!input.files || input.files.length === 0) return;
            var file = input.files[0];
            if (file.size > 20 * 1024 * 1024) {
                Swal.fire({ icon:'warning', title:'Dosya Çok Büyük', text:'Maks. 20MB yükleyebilirsiniz.' });
                input.value = '';
                return;
            }
            document.getElementById('fileUploadForm').submit();
        }

        function onFileDrop(e) {
            e.preventDefault();
            e.currentTarget.style.borderColor = 'var(--border)';
            var files = e.dataTransfer.files;
            if (files.length > 0) {
                var dt = new DataTransfer();
                dt.items.add(files[0]);
                document.getElementById('fileInput').files = dt.files;
                submitFileForm();
            }
        }

        @if (Model.Status == 1 && Model.TakenInProgressDate.HasValue)
        {
                <text>
                (function() {
                    var taken  = new Date('@Model.TakenInProgressDate.Value.ToString("o")');
                    var now    = new Date();
                    var diff   = Math.floor((now - taken) / 60000);
                    if (diff < 0) diff = 0;
                    var h = Math.floor(diff / 60);
                    var m = diff % 60;
                    var display = h > 0 ? h + ' sa ' + m + ' dk' : m + ' dk';
                    var el = document.getElementById('workingDuration');
                    if (el) el.textContent = display;
                })();
                </text>
        }

        // ── ÖN İZLEME ──
        function previewFile(fileId, fileName, type) {
            var url = '/AdminTicket/Dosya/' + fileId;
            document.getElementById('previewTitle').textContent = fileName;
            document.getElementById('previewDownloadLink').href = url;

            var content = document.getElementById('previewContent');
            content.innerHTML = '<div style="padding:40px;color:#94a3b8;"><i class="fas fa-spinner fa-spin" style="font-size:2rem;"></i></div>';
            document.getElementById('previewModal').style.display = 'flex';

            if (type === 'image') {
                var img = new Image();
                img.onload = function() {
                    content.innerHTML = '';
                    content.appendChild(img);
                };
                img.onerror = function() {
                    content.innerHTML = '<div style="padding:30px;color:#ef4444;font-size:.85rem;">Görsel yüklenemedi.</div>';
                };
                img.src = url;
                img.style.cssText = 'max-width:100%;max-height:75vh;object-fit:contain;display:block;';
            } else if (type === 'pdf') {
                content.innerHTML = '<iframe src="' + url + '#toolbar=1" style="width:100%;height:75vh;border:none;display:block;"></iframe>';
            } else {
                content.innerHTML = '<div style="padding:40px;text-align:center;color:#94a3b8;"><i class="fas fa-file" style="font-size:3rem;opacity:.3;display:block;margin-bottom:12px;"></i><p style="font-size:.85rem;">Bu dosya türü önizlenemiyor.</p></div>';
            }
        }

        function closePreviewModal(e) {
            if (!e || e.target === document.getElementById('previewModal')) {
                document.getElementById('previewModal').style.display = 'none';
                document.getElementById('previewContent').innerHTML = '';
            }
        }

        function closePreview() {
            var modal = document.getElementById('previewModal');
            if (modal) modal.style.display = 'none';
            var content = document.getElementById('previewContent');
            if (content) content.innerHTML = '';
        }

        // ── ESC ──
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closePreview();
        });
</script>
}