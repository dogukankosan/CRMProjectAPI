                    <i class="fas fa-exchange-alt mr-2" style="color:var(--success);"></i>
                    Durum Değiştir
                </h6>
                <button onclick="closeStatusModal()"
                        style="border:none;background:none;font-size:1.1rem;color:var(--ink-soft);cursor:pointer;">
                    <i class="fas fa-times"></i>
                </button>
