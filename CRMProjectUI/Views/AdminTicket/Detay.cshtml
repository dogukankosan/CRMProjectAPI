                        <option value="1" selected="@(Model.Status == 1)">İşlemde</option>
                        <option value="2" selected="@(Model.Status == 2)">Başarılı Kapandı ✅</option>
                        <option value="3" selected="@(Model.Status == 3)">Çözülemedi ❌</option>
                        <option value="4" selected="@(Model.Status == 4)">Müşteri Bize Dönecek</option>
                        <option value="5" selected="@(Model.Status == 5)">Müşteriye Geri Döneceğiz</option>
