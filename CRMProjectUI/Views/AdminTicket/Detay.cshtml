                    </label>
                    <textarea id="solutionInput" class="td-textarea" rows="3" placeholder="Çözüm açıklaması..."></textarea>
                </div>
                <div id="workingMinGroup" style="display:none;">
                    <label class="td-label">
                        Çalışma Süresi <small style="font-weight:400;">(dakika)</small>
