@{
    ViewData["Title"] = "Performans Raporun";
    Layout = "~/Views/Shared/_adminLayout.cshtml";
    string apiBase = ViewBag.ApiBase ?? "";
}

<style>
    /* ── HEADER ── */
    .perf-header {
        background: linear-gradient(135deg, #1a1f2e 0%, #232940 60%, #1a1f2e 100%);
        border-radius: 18px;
        padding: 28px 32px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
    }

        .perf-header::before {
            content: '';
            position: absolute;
            top: -80px;
            right: -40px;
            width: 220px;
            height: 220px;
            background: radial-gradient(circle, rgba(16,185,129,.25) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .perf-header::after {
            content: '';
            position: absolute;
            bottom: -60px;
            left: 60px;
            width: 180px;
            height: 180px;
            background: radial-gradient(circle, rgba(99,102,241,.2) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

    .perf-header-left {
        position: relative;
        z-index: 1;
    }

    .perf-header h3 {
        color: #fff;
        font-weight: 800;
        font-size: 1.4rem;
        margin: 0 0 4px;
    }

    .perf-header p {
        color: rgba(255,255,255,.55);
        margin: 0;
        font-size: .88rem;
    }

    .perf-header-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: 3px solid rgba(255,255,255,.2);
        object-fit: cover;
        position: relative;
        z-index: 1;
        flex-shrink: 0;
    }

    .perf-header-avatar-placeholder {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #10b981, #6366f1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 1.3rem;
        font-weight: 800;
        border: 3px solid rgba(255,255,255,.2);
        position: relative;
        z-index: 1;
        flex-shrink: 0;
    }

    /* ── STAT KARTLARI ── */
    .pstat {
        border-radius: 14px;
        padding: 18px 20px;
        border: none;
        transition: transform .2s, box-shadow .2s;
        position: relative;
        overflow: hidden;
    }

        .pstat:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 28px rgba(0,0,0,.12) !important;
        }

    .pstat-icon {
        width: 44px;
        height: 44px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 12px;
    }

    .pstat-val {
        font-size: 1.9rem;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 3px;
    }

    .pstat-label {
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .5px;
        opacity: .65;
    }

    .pstat-sub {
        font-size: .73rem;
        opacity: .5;
        margin-top: 5px;
    }

    .ps-green {
        background: linear-gradient(135deg,#f0fdf4,#dcfce7);
        color: #166534;
    }

    .ps-blue {
        background: linear-gradient(135deg,#eff6ff,#dbeafe);
        color: #1e40af;
    }

    .ps-red {
        background: linear-gradient(135deg,#fef2f2,#fee2e2);
        color: #991b1b;
    }

    .ps-orange {
        background: linear-gradient(135deg,#fff7ed,#fed7aa);
        color: #9a3412;
    }

    .ps-purple {
        background: linear-gradient(135deg,#f5f3ff,#ede9fe);
        color: #5b21b6;
    }

    .ps-teal {
        background: linear-gradient(135deg,#f0fdfa,#ccfbf1);
        color: #134e4a;
    }

    .ps-green .pstat-icon {
        background: rgba(22,163,74,.15);
        color: #16a34a;
    }

    .ps-blue .pstat-icon {
        background: rgba(37,99,235,.15);
        color: #2563eb;
    }

    .ps-red .pstat-icon {
        background: rgba(220,38,38,.15);
        color: #dc2626;
    }

    .ps-orange .pstat-icon {
        background: rgba(234,88,12,.15);
        color: #ea580c;
    }

    .ps-purple .pstat-icon {
        background: rgba(124,58,237,.15);
        color: #7c3aed;
    }

    .ps-teal .pstat-icon {
        background: rgba(20,184,166,.15);
        color: #14b8a6;
    }

    /* ── DÖNEM KART ── */
    .period-box {
        background: #f7f8fc;
        border-radius: 12px;
        padding: 16px 18px;
    }

        .period-box .period-title {
            font-weight: 700;
            font-size: .88rem;
            color: #0f1117;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

    .period-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

        .period-row span:first-child {
            font-size: .78rem;
            color: #6b7280;
        }

        .period-row span:last-child {
            font-weight: 700;
            font-size: .88rem;
        }

    .mini-bar {
        height: 5px;
        background: #e2e8f0;
        border-radius: 3px;
        overflow: hidden;
        margin-top: 8px;
    }

    .mini-bar-fill {
        height: 100%;
        border-radius: 3px;
        background: linear-gradient(90deg, #10b981, #6366f1);
        transition: width .8s ease;
    }

    /* ── CHART KART ── */
    .chart-card {
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        background: #fff;
        padding: 20px 22px;
        margin-bottom: 24px;
    }

    .chart-title {
        font-weight: 700;
        font-size: .92rem;
        color: #0f1117;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .chart-title i {
            color: #6366f1;
        }

    /* ── TABLO ── */
    .rpt-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .84rem;
    }

        .rpt-table th {
            background: #f7f8fc;
            padding: 9px 12px;
            text-align: left;
            font-weight: 700;
            font-size: .72rem;
            color: #4a4f5e;
            text-transform: uppercase;
            letter-spacing: .4px;
            border-bottom: 2px solid #e2e8f0;
        }

        .rpt-table td {
            padding: 9px 12px;
            border-bottom: 1px solid #f1f5f9;
            color: #0f1117;
            vertical-align: middle;
        }

        .rpt-table tr:last-child td {
            border-bottom: none;
        }

        .rpt-table tr:hover td {
            background: #f8fafd;
        }

    /* ── BADGE ── */
    .rbadge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 2px 9px;
        border-radius: 20px;
        font-size: .73rem;
        font-weight: 700;
    }

    .rb-success {
        background: #dcfce7;
        color: #166534;
    }

    .rb-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .rb-warning {
        background: #fef9c3;
        color: #854d0e;
    }

    .rb-info {
        background: #dbeafe;
        color: #1e40af;
    }

    .rb-purple {
        background: #ede9fe;
        color: #5b21b6;
    }

    .rb-gray {
        background: #f1f5f9;
        color: #475569;
    }

    /* ── AKTİF TİCKET KART ── */
    .ticket-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        margin-bottom: 8px;
        background: #fff;
        transition: background .15s;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
    }

        .ticket-row:hover {
            background: #f8fafd;
            text-decoration: none;
            color: inherit;
        }

    .ticket-priority-bar {
        width: 4px;
        border-radius: 2px;
        align-self: stretch;
        flex-shrink: 0;
    }

    .ticket-row-info {
        flex: 1;
        min-width: 0;
    }

    .ticket-row-no {
        font-family: monospace;
        font-size: .75rem;
        color: #6366f1;
        font-weight: 700;
    }

    .ticket-row-title {
        font-weight: 600;
        font-size: .85rem;
        color: #0f1117;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ticket-row-meta {
        font-size: .72rem;
        color: #9ca3af;
        margin-top: 2px;
    }

    /* ── LOADING ── */
    #rLoading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 0;
        color: #6b7280;
    }

    #rContent {
        display: none;
    }

    /* ── WAITING BADGE ── */
    .waiting-hot {
        color: #dc2626;
        font-weight: 700;
    }

    .waiting-warm {
        color: #ea580c;
        font-weight: 600;
    }

    .waiting-ok {
        color: #16a34a;
    }
</style>

<div class="section-body">

    <!-- HEADER -->
    <div class="perf-header" id="perfHeader">
        <div class="perf-header-left">
            <h3><i class="fas fa-chart-bar mr-2"></i>Kişisel Performans Raporum</h3>
            <p id="perfSubtitle">Veriler yükleniyor...</p>
        </div>
        <div id="perfAvatar"></div>
    </div>

    <!-- LOADING -->
    <div id="rLoading">
        <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;"></div>
        <p>Performans verileri hazırlanıyor...</p>
    </div>

    <!-- İÇERİK -->
    <div id="rContent">

        <!-- ── GENEL STAT KARTLARI ── -->
        <div class="row mb-2" id="statRow"></div>

        <!-- ── DÖNEM KARŞILAŞTIRMASI ── -->
        <div class="chart-card">
            <div class="chart-title"><i class="fas fa-calendar-check"></i> Dönem Bazlı Performans</div>
            <div class="row" id="periodRow"></div>
        </div>

        <!-- ── GRAFİKLER ── -->
        <div class="row">
            <div class="col-md-8">
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-chart-bar"></i> Son 30 Gün — Günlük Kapanan Ticketlar</div>
                    <canvas id="dailyChart" height="110"></canvas>
                </div>
            </div>
            <div class="col-md-4">
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-chart-pie"></i> Öncelik Dağılımı</div>
                    <canvas id="priorityChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-7">
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-chart-line"></i> Aylık Trend (Son 12 Ay)</div>
                    <canvas id="monthlyChart" height="130"></canvas>
                </div>
            </div>
            <div class="col-md-5">
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-layer-group"></i> Logo Ürün Dağılımı</div>
                    <canvas id="productChart" height="130"></canvas>
                </div>
            </div>
        </div>

        <!-- ── AKTİF TİCKETLAR ── -->
        <div class="chart-card">
            <div class="chart-title">
                <i class="fas fa-fire"></i>
                Üzerimdeki Açık Ticketlar
                <span class="rbadge rb-warning ml-2" id="activeCount">0</span>
            </div>
            <div id="activeTicketsList">
                <p class="text-muted text-center py-3">Yükleniyor...</p>
            </div>
        </div>

        <!-- ── SON ÇÖZÜLENLER + EN UZUN ── -->
        <div class="row">
            <div class="col-md-8">
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-check-circle text-success"></i> Son Kapattığım Ticketlar</div>
                    <div class="table-responsive">
                        <table class="rpt-table">
                            <thead>
                                <tr>
                                    <th>Ticket No</th>
                                    <th>Başlık</th>
                                    <th>Firma</th>
                                    <th>Ürün</th>
                                    <th>Süre</th>
                                    <th>Sonuç</th>
                                    <th>Kapanış</th>
                                </tr>
                            </thead>
                            <tbody id="recentTable"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="chart-card">
                    <div class="chart-title"><i class="fas fa-hourglass-end text-danger"></i> En Uzun Süren (Top 5)</div>
                    <div id="longestList"></div>
                </div>
            </div>
        </div>

    </div><!-- /rContent -->
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        var apiBase = '@apiBase';

        function minDisplay(min) {
            min = Math.round(min || 0);
            if (!min) return '—';
            if (min < 60) return min + ' dk';
            var h = Math.floor(min / 60), m = min % 60;
            return m ? h + ' sa ' + m + ' dk' : h + ' sa';
        }
        function fmtDate(d) {
            if (!d) return '—';
            // Timezone kaymasını önlemek için sonuna Z ekleme, direkt string parse et
            var parts = d.substring(0, 10).split('-');
            if (parts.length === 3) return parts[2] + '.' + parts[1] + '.' + parts[0];
            return new Date(d).toLocaleDateString('tr-TR', { day:'2-digit', month:'2-digit', year:'numeric' });
        }
        function successBadge(rate) {
            rate = Math.round(rate || 0);
            var cls = rate >= 80 ? 'rb-success' : rate >= 50 ? 'rb-warning' : 'rb-danger';
            return '<span class="rbadge ' + cls + '">' + rate + '%</span>';
        }
        function priorityColor(p) {
            return { 1:'#9ca3af', 2:'#3b82f6', 3:'#f59e0b', 4:'#ef4444' }[p] || '#6b7280';
        }
        function statusBadge(s) {
            if (s === 2) return '<span class="rbadge rb-success">✅ Çözüldü</span>';
            if (s === 3) return '<span class="rbadge rb-danger">❌ Çözülemedi</span>';
            if (s === 0) return '<span class="rbadge rb-warning">⏳ Beklemede</span>';
            if (s === 1) return '<span class="rbadge rb-info">🔧 İşlemde</span>';
            if (s === 4) return '<span class="rbadge rb-gray">📞 Müşteri Dönecek</span>';
            if (s === 5) return '<span class="rbadge rb-gray">📤 Biz Döneceğiz</span>';
            return '<span class="rbadge rb-gray">' + s + '</span>';
        }

        fetch('/AdminTicket/AdminReport')
            .then(function(r) { return r.json(); })
            .then(function(json) {
                var d = json.data;
                if (!d) {
                    document.getElementById('rLoading').innerHTML =
                        '<i class="fas fa-exclamation-triangle fa-2x text-danger mb-3"></i><p>Rapor verisi boş geldi.</p>';
                    return;
                }
                renderHeader(d.generalStats);
                renderStats(d.generalStats);
                renderPeriods(d.generalStats);
                renderActiveTickets(d.activeTickets);
                renderRecentTable(d.recentResolved);
                renderLongest(d.longestTickets);
                renderDailyChart(d.dailyTrend);
                renderMonthlyChart(d.monthlyTrend);
                renderPriorityChart(d.priorityDist);
                renderProductChart(d.productDist);
                document.getElementById('rLoading').style.display = 'none';
                document.getElementById('rContent').style.display = 'block';
                document.getElementById('perfSubtitle').textContent =
                    'Son güncelleme: ' + new Date().toLocaleString('tr-TR');
            })
            .catch(function(err) {
                console.error('HATA:', err);
                document.getElementById('rLoading').innerHTML =
                    '<i class="fas fa-exclamation-triangle fa-2x text-danger mb-3"></i><p>Rapor yüklenemedi: ' + err.message + '</p>';
            });

        function renderHeader(s) {
            if (!s) return;
            document.getElementById('activeCount').textContent = s.ActiveCount || 0;
        }

         function renderStats(s) {
            if (!s) return;

            // null değerleri 0'a çevir
            function n(v) { return v ?? 0; }

            var cards = [
                { label: 'Toplam Atanan', value: n(s.TotalAssigned),                       sub: 'Tüm zamanlar',   cls: 'ps-blue',   icon: 'fa-inbox' },
                { label: 'Toplam Çözdüm', value: n(s.TotalResolved),                       sub: 'Başarılı',        cls: 'ps-green',  icon: 'fa-check-circle' },
                { label: 'Çözülemedi',    value: n(s.TotalFailed),                         sub: 'Kapalı',          cls: 'ps-red',    icon: 'fa-times-circle' },
                { label: 'Aktif Ticket',  value: n(s.ActiveCount),                         sub: 'Şu an üzerimde',  cls: 'ps-orange', icon: 'fa-fire' },
                { label: 'Ort. Süre',     value: minDisplay(n(s.AvgWorkingMinute)),        sub: 'Genel ortalama',  cls: 'ps-purple', icon: 'fa-clock' },
                { label: 'Başarı Oranı',  value: Math.round(n(s.SuccessRate)) + '%',      sub: 'Çözülen/Kapanan', cls: 'ps-teal',   icon: 'fa-trophy' },
            ];

            var html = '';
            cards.forEach(function(c) {
                html += '<div class="col-md-2 col-sm-4 col-6 mb-3">' +
                    '<div class="pstat ' + c.cls + ' shadow-sm">' +
                    '<div class="pstat-icon"><i class="fas ' + c.icon + '"></i></div>' +
                    '<div class="pstat-val">' + c.value + '</div>' +
                    '<div class="pstat-label">' + c.label + '</div>' +
                    '<div class="pstat-sub">' + c.sub + '</div>' +
                    '</div></div>';
            });
            document.getElementById('statRow').innerHTML = html;
        }

        function renderPeriods(s) {
            if (!s) return;
            var periods = [
                { label: '🌅 Bugün',    assigned: s.TodayAssigned,     resolved: s.TodayResolved,     avgMin: s.TodayAvgMinute },
                { label: '📅 Bu Hafta', assigned: s.ThisWeekAssigned,  resolved: s.ThisWeekResolved,  avgMin: null },
                { label: '🗓 Bu Ay',    assigned: s.ThisMonthAssigned, resolved: s.ThisMonthResolved, avgMin: s.ThisMonthAvgMinute },
                { label: '📆 Bu Yıl',   assigned: s.ThisYearAssigned,  resolved: s.ThisYearResolved,  avgMin: null }
            ];
            var html = '';
            periods.forEach(function(p) {
                var rate = p.assigned > 0 ? Math.round((p.resolved / p.assigned) * 100) : 0;
                html += '<div class="col-md-3 col-6 mb-3">' +
                    '<div class="period-box">' +
                    '<div class="period-title">' + p.label + '</div>' +
                    '<div class="period-row"><span>Alınan</span><span style="color:#2563eb;">' + (p.assigned || 0) + '</span></div>' +
                    '<div class="period-row"><span>Kapattım</span><span style="color:#16a34a;">' + (p.resolved || 0) + '</span></div>' +
                    (p.avgMin !== null ? '<div class="period-row"><span>Ort. Süre</span><span style="color:#7c3aed;">' + minDisplay(p.avgMin) + '</span></div>' : '') +
                    '<div class="mini-bar"><div class="mini-bar-fill" style="width:' + rate + '%;"></div></div>' +
                    '<div style="font-size:.7rem;color:#9ca3af;margin-top:4px;">Tamamlama: ' + rate + '%</div>' +
                    '</div></div>';
            });
            document.getElementById('periodRow').innerHTML = html;
        }

        function renderActiveTickets(list) {
            if (!list || !list.length) {
                document.getElementById('activeTicketsList').innerHTML =
                    '<p class="text-muted text-center py-4"><i class="fas fa-check-circle mr-2 text-success"></i>Harika! Üzerinde açık ticket yok.</p>';
                return;
            }
            var html = '';
            list.forEach(function(t) {
                var waitH = t.WaitingHours || 0;
                var waitCls = waitH > 48 ? 'waiting-hot' : waitH > 24 ? 'waiting-warm' : 'waiting-ok';
                var waitTxt = waitH + ' sa' + (waitH > 48 ? ' ⚠️' : '');
                html += '<a href="/AdminTicket/Detay/' + t.ID + '" class="ticket-row d-flex">' +
                    '<div class="ticket-priority-bar" style="background:' + priorityColor(t.Priority) + ';"></div>' +
                    '<div class="ticket-row-info">' +
                    '<div class="ticket-row-no">' + t.TicketNo + '</div>' +
                    '<div class="ticket-row-title">' + t.Title + '</div>' +
                    '<div class="ticket-row-meta">' +
                    (t.CustomerName || '') + ' · ' + (t.LogoProductName || '—') +
                    (t.CreatedByName ? ' · ' + t.CreatedByName : '') +
                    '</div></div>' +
                    '<div class="text-right flex-shrink-0">' +
                    statusBadge(t.Status) +
                    '<div class="mt-1 ' + waitCls + '" style="font-size:.72rem;">' + waitTxt + '</div>' +
                    '</div></a>';
            });
            document.getElementById('activeTicketsList').innerHTML = html;
        }

        function renderRecentTable(list) {
            if (!list || !list.length) {
                document.getElementById('recentTable').innerHTML =
                    '<tr><td colspan="7" class="text-center text-muted py-4">Henüz kapatılmış ticket yok</td></tr>';
                return;
            }
            var html = '';
            list.forEach(function(t) {
                html += '<tr>' +
                    '<td><span style="font-family:monospace;font-size:.75rem;color:#6366f1;font-weight:700;">' + t.TicketNo + '</span></td>' +
                    '<td style="max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="' + t.Title + '">' + t.Title + '</td>' +
                    '<td><small>' + (t.CustomerName || '—') + '</small></td>' +
                    '<td><small>' + (t.LogoProductName || '—') + '</small></td>' +
                    '<td>' + minDisplay(t.WorkingMinute) + '</td>' +
                    '<td>' + statusBadge(t.Status) + '</td>' +
                    '<td><small>' + fmtDate(t.ClosedDate) + '</small></td>' +
                    '</tr>';
            });
            document.getElementById('recentTable').innerHTML = html;
        }

        function renderLongest(list) {
            if (!list || !list.length) {
                document.getElementById('longestList').innerHTML = '<p class="text-muted text-center py-3">Veri yok</p>';
                return;
            }
            var html = '';
            var colors = ['#ef4444','#f97316','#f59e0b','#84cc16','#10b981'];
            list.forEach(function(t, i) {
                html += '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">' +
                    '<div style="width:26px;height:26px;border-radius:50%;background:' + colors[i] + ';color:#fff;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;flex-shrink:0;">' + (i+1) + '</div>' +
                    '<div style="flex:1;min-width:0;">' +
                    '<div style="font-size:.78rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + t.Title + '</div>' +
                    '<div style="font-size:.7rem;color:#9ca3af;">' + (t.CustomerName || '') + ' · ' + fmtDate(t.ClosedDate) + '</div>' +
                    '</div>' +
                    '<div style="font-weight:700;color:#dc2626;font-size:.82rem;flex-shrink:0;">' + minDisplay(t.WorkingMinute) + '</div>' +
                    '</div>';
            });
            document.getElementById('longestList').innerHTML = html;
        }

        function renderDailyChart(data) {
            if (!data || !data.length) return;
            var labels   = data.map(function(d) { return new Date(d.Date).toLocaleDateString('tr-TR',{day:'2-digit',month:'2-digit'}); });
            var resolved = data.map(function(d) { return d.Resolved || 0; });
            var failed   = data.map(function(d) { return d.Failed || 0; });
            new Chart(document.getElementById('dailyChart'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Çözüldü',    data: resolved, backgroundColor: 'rgba(16,185,129,.75)', borderRadius: 5, borderSkipped: false },
                        { label: 'Çözülemedi', data: failed,   backgroundColor: 'rgba(239,68,68,.65)',  borderRadius: 5, borderSkipped: false }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top', labels: { font: { size: 11 } } } },
                    scales: {
                        x: { stacked: true, grid: { display: false } },
                        y: { stacked: true, beginAtZero: true, grid: { color: '#f1f5f9' } }
                    }
                }
            });
        }

        function renderMonthlyChart(data) {
            if (!data || !data.length) return;
            var monthNames = ['','Oca','Şub','Mar','Nis','May','Haz','Tem','Ağu','Eyl','Eki','Kas','Ara'];
            var labels   = data.map(function(d) { return monthNames[d.Month] + ' ' + d.Year; });
            var resolved = data.map(function(d) { return d.Resolved || 0; });
            var failed   = data.map(function(d) { return d.Failed || 0; });
            var avgMin   = data.map(function(d) { return Math.round((d.AvgMinute || 0) / 60 * 10) / 10; });
            new Chart(document.getElementById('monthlyChart'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Çözüldü',       data: resolved, backgroundColor: 'rgba(16,185,129,.75)', borderRadius: 5, yAxisID: 'y' },
                        { label: 'Çözülemedi',    data: failed,   backgroundColor: 'rgba(239,68,68,.65)',  borderRadius: 5, yAxisID: 'y' },
                        { label: 'Ort. Süre (sa)', data: avgMin,  type: 'line', borderColor: '#6366f1', backgroundColor: 'rgba(99,102,241,.1)', fill: true, tension: .4, pointRadius: 3, yAxisID: 'y2' }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top', labels: { font: { size: 11 } } } },
                    scales: {
                        x: { grid: { display: false } },
                        y: { beginAtZero: true, grid: { color: '#f1f5f9' }, position: 'left' },
                        y2: { beginAtZero: true, position: 'right', grid: { display: false }, ticks: { color: '#6366f1' } }
                    }
                }
            });
        }

        function renderPriorityChart(data) {
            if (!data || !data.length) return;
            var priorityLabels = { 1:'Düşük', 2:'Normal', 3:'Yüksek', 4:'Kritik' };
            var colors = ['#9ca3af','#3b82f6','#f59e0b','#ef4444'];
            new Chart(document.getElementById('priorityChart'), {
                type: 'doughnut',
                data: {
                    labels: data.map(function(d){ return priorityLabels[d.Priority] || d.Priority; }),
                    datasets: [{ data: data.map(function(d){ return d.Total; }), backgroundColor: colors, borderWidth: 2, borderColor: '#fff' }]
                },
                options: {
                    responsive: true, cutout: '65%',
                    plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } }
                }
            });
        }

        function renderProductChart(data) {
            if (!data || !data.length) return;
            var colors = ['#6366f1','#10b981','#f59e0b','#ef4444','#3b82f6','#8b5cf6','#14b8a6'];
            new Chart(document.getElementById('productChart'), {
                type: 'bar',
                data: {
                    labels: data.map(function(d){ return d.LogoProductName || 'Bilinmiyor'; }),
                    datasets: [{
                        label: 'Toplam',
                        data: data.map(function(d){ return d.Total || 0; }),
                        backgroundColor: colors,
                        borderRadius: 5
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                        y: { grid: { display: false } }
                    }
                }
            });
        }
    </script>
}