@model List<CRMProjectUI.Models.TicketListDto>
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    ViewData["Title"] = "Destek Talepleri";
    Layout = "~/Views/Shared/_adminLayout.cshtml";

    string apiBase = Config["ApiSettings:BaseUrl"] ?? "";
    bool isSuperAdmin = User.IsInRole("SuperAdmin");
    bool isAdmin = User.IsInRole("Admin");
    bool isUser = User.IsInRole("User");
    bool isStaff = isSuperAdmin || isAdmin;
    int callerUserId = int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out int cuid) ? cuid : 0;
    // Başarılı (2) hariç tüm kayıtlar
    var filtered = Model?.Where(x => x.Status != 2 && x.Status != 3 && x.Status != 6).ToList()
                   ?? new List<CRMProjectUI.Models.TicketListDto>();

    int total = filtered.Count;
    int beklemede = filtered.Count(x => x.Status == 0);
    int islemde = filtered.Count(x => x.Status == 1);
    int cozemedi = filtered.Count(x => x.Status == 3);
    int musteriBekle = filtered.Count(x => x.Status == 4);
    int bizDonecek = filtered.Count(x => x.Status == 5);
    int acik = filtered.Count(x => x.Status == 0 || x.Status == 1);

    string? successMsg = TempData["Success"] as string;
    string? errorMsg = TempData["Error"] as string;

    var adminUsers = ViewBag.AdminUsers as List<CRMProjectUI.Models.UserListDto>
                     ?? new List<CRMProjectUI.Models.UserListDto>();
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

