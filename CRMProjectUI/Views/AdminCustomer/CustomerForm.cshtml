    function initSinglePhone(inputId, selectId) {
        var input  = document.getElementById(inputId);
        var select = document.getElementById(selectId);
        if (!input || !select) return;

        var currentValue = input.value.trim();
        if (currentValue) {
            for (var code in phoneFormats) {
                if (code !== '_default' && currentValue.startsWith(code)) {
                    select.value = code;
                    break;
                }
            }
        }

        function updateFormatted() {
            var code       = select.value;
            var codeDigits = code.replace(/\D/g, '');
            var digits     = input.value.replace(/\D/g, '');
            if (digits.startsWith(codeDigits)) digits = digits.substring(codeDigits.length);
            input.value = formatPhoneNumber(digits, code);
        }

        select.addEventListener('change', function () {
            input.value = this.value + ' ';
            input.focus();
        });

        input.addEventListener('input', function (e) {
            var code       = select.value;
            var codeDigits = code.replace(/\D/g, '');
            if ((e.inputType === 'deleteContentBackward' || e.inputType === 'deleteContentForward') &&
                input.value.replace(/\D/g, '') === codeDigits) {
                input.value = code + ' ';
                return;
            }
            updateFormatted();
        });

        input.addEventListener('focus', function () {
            setTimeout(function () {
                input.setSelectionRange(input.value.length, input.value.length);
            }, 0);
        });

        if (!currentValue || !currentValue.startsWith('+')) {
            input.value = select.value + ' ';
        } else {
            updateFormatted();
        }
    }

