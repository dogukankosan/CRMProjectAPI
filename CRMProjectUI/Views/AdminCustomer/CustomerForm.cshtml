        "+86":  { max: 11, pattern: [3, 4, 4] },
        "+91":  { max: 10, pattern: [4, 3, 3] },
        "+81":  { max: 10, pattern: [3, 4, 3] },
        "+82":  { max: 10, pattern: [3, 3, 4] },
