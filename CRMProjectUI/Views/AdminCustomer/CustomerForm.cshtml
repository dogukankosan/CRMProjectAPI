                                                       autocomplete="new-password"
                                                       data-real="@Model.SQLPassword"
                                                       placeholder="@(isEdit && !string.IsNullOrEmpty(Model.SQLPassword) ? "••••••••" : "")" />
                                                <div class="input-group-append">
                                                    <button type="button" class="btn btn-outline-secondary"
                                                            onclick="togglePassword('sqlPass', this)">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                    @if (isEdit && !string.IsNullOrEmpty(Model.SQLPassword))
                                                    {
                                                        <button type="button" class="btn btn-outline-danger"
                                                                onclick="clearPassword('sqlPass', 'sqlPassHidden')"
                                                                title="Şifreyi Sil">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                            
                                            <input type="hidden" id="sqlPassHidden" name="SQLPassword" value="@Model.SQLPassword" />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>BulutERP Kullanıcı Adı</label>
                                            <input asp-for="BulutERPUsername" class="form-control" maxlength="256" />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>BulutERP Şifresi</label>
                                            <div class="input-group">
                                                <input type="password" class="form-control" maxlength="256" id="bulutErpPass"
                                                       autocomplete="new-password"
                                                       data-real="@Model.BulutERPPassword"
                                                       placeholder="@(isEdit && !string.IsNullOrEmpty(Model.BulutERPPassword) ? "••••••••" : "")" />
                                                <div class="input-group-append">
                                                    <button type="button" class="btn btn-outline-secondary"
                                                            onclick="togglePassword('bulutErpPass', this)">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                    @if (isEdit && !string.IsNullOrEmpty(Model.BulutERPPassword))
                                                    {
                                                        <button type="button" class="btn btn-outline-danger"
                                                                onclick="clearPassword('bulutErpPass', 'bulutErpPassHidden')"
                                                                title="Şifreyi Sil">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                            <input type="hidden" id="bulutErpPassHidden" name="BulutERPPassword" value="@Model.BulutERPPassword" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SÖZLEŞME -->
                        @if (showContractSection)
                        {
                            <div class="card card-section">
                                <div class="card-header text-white" style="background: linear-gradient(135deg,#667eea 0%,#764ba2 100%);">
                                    <h6><i class="fas fa-file-contract"></i> Sözleşme Bilgileri</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Sözleşme Başlangıç <span class="required-star">*</span></label>
                                                <input type="date" name="ContractStartDate" id="ContractStartDate"
                                                       class="form-control"
                                                       value="@Model.ContractStartDate?.ToString("yyyy-MM-dd")" />
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label>Sözleşme Bitiş <span class="required-star">*</span></label>
                                                <input type="date" name="ContractEndDate" id="ContractEndDate"
                                                       class="form-control"
                                                       value="@Model.ContractEndDate?.ToString("yyyy-MM-dd")" />
                                            </div>
                                        </div>
                                        @if (isSuperAdmin)
                                        {
                                            <!-- Dosya yükleme sadece SuperAdmin -->
                                            <div class="col-md-4">
                                                @if (!string.IsNullOrEmpty(Model.ContractPath))
                                                {
                                                    <div class="form-group" id="existingContractBox">
                                                        <label>Mevcut Sözleşme</label>
                                                        <div class="d-flex align-items-center">
                                                            <a href="@($"{apiBase}{Model.ContractPath}")" target="_blank" class="btn btn-sm btn-outline-primary">
                                                                <i class="fas fa-file mr-1"></i> Görüntüle
                                                            </a>
                                                            <button type="button" class="btn btn-sm btn-outline-danger ml-2"
                                                                    onclick="removeContract()">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                                @if (!ViewData.ModelState.IsValid && !isEdit)
                                                {
                                                    <div class="alert alert-warning py-2 mt-2">
                                                        <i class="fas fa-exclamation-triangle mr-1"></i>
                                                        Hata nedeniyle sözleşme dosyasını tekrar seçmeniz gerekebilir.
                                                    </div>
                                                }
                                                <input type="hidden" asp-for="ContractPath" id="contractPathHidden" />
                                                <div class="form-group">
                                                    <label>Sözleşme Dosyası <small class="text-muted">(PDF, Word, Excel, Görsel)</small></label>
                                                    <div class="custom-file">
                                                        <input type="file" class="custom-file-input" id="ContractFile"
                                                               name="ContractFile"
                                                               accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png"
                                                               onchange="handleContractFile(this)" />
                                                        <label class="custom-file-label" for="ContractFile" id="contractFileLabel">
                                                            @(string.IsNullOrEmpty(Model.ContractPath) ? "Dosya seçiniz..." : "Yeni dosya seçiniz...")
                                                        </label>
                                                    </div>
                                                    <small class="text-muted">Max 10MB</small>
                                                    <div id="contractPreview" class="mt-2" style="display:none;">
                                                        <div class="alert alert-info py-2 mb-0 d-flex align-items-center justify-content-between">
                                                            <span>
                                                                <i id="contractFileIcon" class="fas fa-file mr-2"></i>
                                                                <span id="contractFileName"></span>
                                                                <small class="text-muted ml-1" id="contractFileSize"></small>
                                                            </span>
                                                            <button type="button" class="btn btn-sm btn-link text-danger p-0"
                                                                    onclick="clearContractFile()">
                                                                <i class="fas fa-times"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <!-- Admin yeni kayıt: dosya alanı yok, ContractPath hidden -->
                                            <input type="hidden" name="ContractPath" value="" />
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            @* Admin düzenleme: sözleşme bölümü gizli, mevcut değerleri koru *@
                            <input type="hidden" name="ContractStartDate" value="@Model.ContractStartDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="ContractEndDate" value="@Model.ContractEndDate?.ToString("yyyy-MM-dd")" />
                            <input type="hidden" name="ContractPath" value="@Model.ContractPath" />
                        }

                        <!-- NOTLAR & DURUM -->
                        <div class="card card-section">
                            <div class="card-header bg-light">
                                <h6><i class="fas fa-sticky-note"></i> Notlar & Durum</h6>
                            </div>
                            <div class="card-body">
                                <div class="form-group">
                                    <label>İç Notlar <small class="text-muted">(Müşteri görmez)</small></label>
                                    <textarea asp-for="InternalNotes" class="form-control" rows="3"
                                              placeholder="Sadece iç kullanım için notlar..."></textarea>
                                </div>

                                @if (isSuperAdmin || !isEdit)
                                {
                                    <div class="form-group">
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" id="hasMaintenanceContract"
                                                   name="HasMaintenanceContract" value="true"
                                                   @(Model.HasMaintenanceContract ? "checked" : "") />
                                            <label class="custom-control-label" for="hasMaintenanceContract">
                                                <i class="fas fa-tools mr-1"></i> Bakım Anlaşmalı
                                            </label>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <input type="hidden" name="HasMaintenanceContract" value="@(Model.HasMaintenanceContract ? "true" : "false")" />
                                    <div class="form-group">
                                        <span class="badge badge-@(Model.HasMaintenanceContract ? "success" : "secondary") p-2">
                                            <i class="fas fa-tools mr-1"></i>
                                            @(Model.HasMaintenanceContract ? "Bakım Anlaşmalı" : "Bakım Anlaşması Yok")
                                        </span>
                                    </div>
                                }
                                <div class="form-group">
                                    <label>Durum</label>
                                    @if (canEditStatus)
                                    {
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" class="custom-control-input" id="statusSwitch"
                                                   @(isActive ? "checked" : "") />
                                            <label class="custom-control-label" for="statusSwitch">
                                                <span id="statusText">@(isActive ? "Aktif" : "Pasif")</span>
                                            </label>
                                        </div>
                                    }
                                    else
                                    {
                                        @* Admin düzenleme: sadece görür, değiştiremez *@
                                        <div>
                                            <span class="badge badge-@(isActive ? "success" : "secondary") p-2">
                                                <i class="fas fa-circle mr-1"></i> @(isActive ? "Aktif" : "Pasif")
                                            </span>
                                            <input type="hidden" name="Status" value="@(isActive ? "1" : "0")" />
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="text-right mt-4">
                            <a asp-action="Liste" asp-controller="AdminMusteri" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times"></i> İptal
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                                <i class="fas fa-save"></i> @(isEdit ? "Güncelle" : "Kaydet")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="savedIl" value="@Model.Il" />
<input type="hidden" id="savedIlce" value="@Model.CityDistrictID" />
<input type="hidden" id="currentCustomerId" value="@Model.ID" />

<div id="tempDataMessages"
     data-success="@TempData["Success"]"
     data-error="@TempData["Error"]">
</div>

<script>
    // ==================== ÜLKE KODLARI ====================
    var countryList = [
        ["+90","🇹🇷 Türkiye (+90)"],
        ["+93","🇦🇫 Afganistan (+93)"],
        ["+355","🇦🇱 Arnavutluk (+355)"],
        ["+213","🇩🇿 Cezayir (+213)"],
        ["+54","🇦🇷 Arjantin (+54)"],
        ["+61","🇦🇺 Avustralya (+61)"],
        ["+43","🇦🇹 Avusturya (+43)"],
        ["+973","🇧🇭 Bahreyn (+973)"],
        ["+32","🇧🇪 Belçika (+32)"],
        ["+55","🇧🇷 Brezilya (+55)"],
        ["+359","🇧🇬 Bulgaristan (+359)"],
        ["+86","🇨🇳 Çin (+86)"],
        ["+45","🇩🇰 Danimarka (+45)"],
        ["+20","🇪🇬 Mısır (+20)"],
        ["+358","🇫🇮 Finlandiya (+358)"],
        ["+33","🇫🇷 Fransa (+33)"],
        ["+49","🇩🇪 Almanya (+49)"],
        ["+30","🇬🇷 Yunanistan (+30)"],
        ["+852","🇭🇰 Hong Kong (+852)"],
        ["+36","🇭🇺 Macaristan (+36)"],
        ["+91","🇮🇳 Hindistan (+91)"],
        ["+62","🇮🇩 Endonezya (+62)"],
        ["+98","🇮🇷 İran (+98)"],
        ["+964","🇮🇶 Irak (+964)"],
        ["+353","🇮🇪 İrlanda (+353)"],
        ["+972","🇮🇱 İsrail (+972)"],
        ["+39","🇮🇹 İtalya (+39)"],
        ["+81","🇯🇵 Japonya (+81)"],
        ["+962","🇯🇴 Ürdün (+962)"],
        ["+7","🇰🇿 Kazakistan (+7)"],
        ["+965","🇰🇼 Kuveyt (+965)"],
        ["+961","🇱🇧 Lübnan (+961)"],
        ["+60","🇲🇾 Malezya (+60)"],
        ["+52","🇲🇽 Meksika (+52)"],
        ["+31","🇳🇱 Hollanda (+31)"],
        ["+64","🇳🇿 Yeni Zelanda (+64)"],
        ["+47","🇳🇴 Norveç (+47)"],
        ["+92","🇵🇰 Pakistan (+92)"],
        ["+48","🇵🇱 Polonya (+48)"],
        ["+351","🇵🇹 Portekiz (+351)"],
        ["+974","🇶🇦 Katar (+974)"],
        ["+40","🇷🇴 Romanya (+40)"],
        ["+7","🇷🇺 Rusya (+7)"],
        ["+966","🇸🇦 Suudi Arabistan (+966)"],
        ["+65","🇸🇬 Singapur (+65)"],
        ["+27","🇿🇦 Güney Afrika (+27)"],
        ["+82","🇰🇷 Güney Kore (+82)"],
        ["+34","🇪🇸 İspanya (+34)"],
        ["+46","🇸🇪 İsveç (+46)"],
        ["+41","🇨🇭 İsviçre (+41)"],
        ["+886","🇹🇼 Tayvan (+886)"],
        ["+66","🇹🇭 Tayland (+66)"],
        ["+380","🇺🇦 Ukrayna (+380)"],
        ["+971","🇦🇪 BAE (+971)"],
        ["+44","🇬🇧 İngiltere (+44)"],
        ["+1","🇺🇸 ABD (+1)"]
    ];

    function buildCountryOptions(currentVal) {
        return countryList.map(function(c) {
            var selected = (c[0] === currentVal) ? ' selected' : '';
            return '<option value="' + c[0] + '"' + selected + '>' + c[1] + '</option>';
        }).join('');
    }

    function fillCountrySelects() {
        ['countryCode1', 'countryCode2', 'countryCodeOfficial'].forEach(function(id) {
            var el = document.getElementById(id);
            if (!el) return;
            var currentVal = el.value || '+90';
            el.innerHTML = buildCountryOptions(currentVal);
        });
    }

    document.addEventListener('DOMContentLoaded', function () {
        fillCountrySelects();
        initCharCounters();
        initPhoneInputs();
        initVknTcToggle();
        initStatusSwitch();
        initContractDateValidation();
        initCityDistrictCascade();

        var el      = document.getElementById('tempDataMessages');
        var success = el.getAttribute('data-success');
        var error   = el.getAttribute('data-error');
        if (success) Swal.fire({ icon: 'success', title: 'Başarılı!', text: success, timer: 3000, showConfirmButton: false });
        if (error)   Swal.fire({ icon: 'error',   title: 'Hata!',     text: error,   timer: 4000, showConfirmButton: true });
    });

    // ==================== MÜŞTERİ TİPİ ====================
    function selectCustomerType(type, el) {
        document.getElementById('CustomerType').value = type;
        document.querySelectorAll('.customer-type-btn').forEach(function(b) { b.classList.remove('active'); });
        el.classList.add('active');
        if (type === 'Kurumsal') { toggleVknTc('vkn'); } else { toggleVknTc('tc'); }
    }

    // ==================== VKN / TC TOGGLE ====================
    function initVknTcToggle() {
        var tc   = document.getElementById('TC').value;
        var type = document.getElementById('CustomerType').value;
        toggleVknTc((tc && tc.trim().length > 0) ? 'tc' : (type === 'Bireysel' ? 'tc' : 'vkn'));
        document.getElementById('btnVkn').disabled = true;
        document.getElementById('btnTc').disabled  = true;
    }

    function toggleVknTc(type) {
        var vknGroup = document.getElementById('vknInputGroup');
        var tcGroup  = document.getElementById('tcInputGroup');
        var btnVkn   = document.getElementById('btnVkn');
        var btnTc    = document.getElementById('btnTc');
        if (type === 'vkn') {
            vknGroup.style.display = 'block';
            tcGroup.style.display  = 'none';
            btnVkn.classList.add('active');
            btnTc.classList.remove('active');
            document.getElementById('TC').value = '';
        } else {
            vknGroup.style.display = 'none';
            tcGroup.style.display  = 'block';
            btnTc.classList.add('active');
            btnVkn.classList.remove('active');
            document.getElementById('VKN').value = '';
        }
    }

    // ==================== MÜŞTERİ KODU KONTROL ====================
    function checkCustomerCode(code) {
        if (!code || code.trim().length === 0) return;
        var currentId = document.getElementById('currentCustomerId').value;
        fetch('/AdminMusteri/KodKontrol?code=' + encodeURIComponent(code.trim()) + '&excludeId=' + currentId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var warning = document.getElementById('customerCodeWarning');
                var input   = document.getElementById('CustomerCode');
                if (data.exists) {
                    warning.style.display = 'block';
                    input.classList.add('is-invalid');
                } else {
                    warning.style.display = 'none';
                    input.classList.remove('is-invalid');
                }
            })
            .catch(function() {});
    }

    // ==================== İL/İLÇE CASCADE ====================
    function initCityDistrictCascade() {
        var savedIl        = document.getElementById('savedIl').value;
        var savedIlce      = document.getElementById('savedIlce').value;
        var districtSelect = document.getElementById('districtSelect');

        if (savedIl && districtSelect.options.length <= 1) {
            loadDistricts(savedIl, savedIlce);
        }

        document.getElementById('citySelect').addEventListener('change', function () {
            loadDistricts(this.value, null);
        });
    }

    function loadDistricts(il, selectDistrictId) {
        var districtSelect = document.getElementById('districtSelect');
        districtSelect.innerHTML = '<option value="">Yükleniyor...</option>';
        districtSelect.disabled  = true;

        if (!il) {
            districtSelect.innerHTML = '<option value="">Önce il seçiniz...</option>';
            districtSelect.disabled  = false;
            return;
        }

        fetch('/AdminMusteri/Ilceler/' + encodeURIComponent(il))
            .then(function(r) {
                if (!r.ok) throw new Error('Sunucu hatası');
                return r.json();
            })
            .then(function(data) {
                districtSelect.innerHTML = '<option value="">İlçe Seçiniz...</option>';
                data.forEach(function(item) {
                    var opt         = document.createElement('option');
                    opt.value       = item.id;
                    opt.textContent = item.displayText;
                    if (selectDistrictId && String(item.id) === String(selectDistrictId)) {
                        opt.selected = true;
                    }
                    districtSelect.appendChild(opt);
                });
            })
            .catch(function() {
                districtSelect.innerHTML = '<option value="">Hata oluştu, tekrar deneyin</option>';
            })
            .finally(function() {
                districtSelect.disabled = false;
            });
    }

