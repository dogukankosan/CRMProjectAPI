        "+32":  { max: 9,  pattern: [3, 3, 3] },
        "+34":  { max: 9,  pattern: [3, 3, 3] },
        "+40":  { max: 10, pattern: [3, 3, 4] },
        "+41":  { max: 9,  pattern: [2, 3, 4] },
        "+43":  { max: 10, pattern: [3, 3, 4] },
        "+45":  { max: 8,  pattern: [2, 2, 2, 2] },
        "+46":  { max: 10, pattern: [3, 3, 4] },
        "+47":  { max: 8,  pattern: [2, 2, 2, 2] },
        "+48":  { max: 9,  pattern: [3, 3, 3] },
        "+60":  { max: 10, pattern: [3, 3, 4] },
        "+61":  { max: 9,  pattern: [3, 3, 3] },
        "+62":  { max: 11, pattern: [3, 4, 4] },
        "+64":  { max: 9,  pattern: [3, 3, 3] },
        "+65":  { max: 8,  pattern: [4, 4] },
        "+66":  { max: 9,  pattern: [3, 3, 3] },
        "+92":  { max: 10, pattern: [3, 3, 4] },
        "+98":  { max: 10, pattern: [3, 3, 4] },
        "+351": { max: 9,  pattern: [3, 3, 3] },
        "+353": { max: 9,  pattern: [3, 3, 3] },
        "+358": { max: 10, pattern: [3, 3, 4] },
        "+380": { max: 9,  pattern: [2, 3, 4] },
        "+961": { max: 8,  pattern: [3, 3, 2] },
        "+962": { max: 9,  pattern: [2, 3, 4] },
        "+964": { max: 10, pattern: [3, 3, 4] },
        "+965": { max: 8,  pattern: [4, 4] },
        "+972": { max: 9,  pattern: [2, 3, 4] },
        "+973": { max: 8,  pattern: [4, 4] },
        "+974": { max: 8,  pattern: [4, 4] },
        "+852": { max: 8,  pattern: [4, 4] },
        "+886": { max: 9,  pattern: [3, 3, 3] },
        "_default": { max: 15, pattern: [3, 3, 3, 3, 3] }
    };

    function formatPhoneNumber(number, code) {
        var config     = phoneFormats[code] || phoneFormats._default;
        var digitsOnly = number.replace(/\D/g, '').substring(0, config.max);
        var formatted  = code + ' ';
        var pos        = 0;
        for (var i = 0; i < config.pattern.length; i++) {
            var len  = config.pattern[i];
            if (pos >= digitsOnly.length) break;
            var part = digitsOnly.substr(pos, len);
            if (part.length > 0) { formatted += part + ' '; pos += len; }
        }
        return formatted.trim();
    }

    function initPhoneInputs() {
