    function validateVknInput(input) {
        var errorEl = document.getElementById('vknError');
        var errorText = errorEl.querySelector('span') || errorEl;

        if (input.value.length === 0) {
            errorEl.style.display = 'none';
            input.classList.remove('is-invalid');
        } else if (input.value.length !== 10) {
            errorEl.style.display = 'block';
            errorEl.innerHTML = '<i class="fas fa-exclamation-circle mr-1"></i> VKN 10 haneli olmalıdır.';
            input.classList.add('is-invalid');
