    function initCharCounters() {
        document.querySelectorAll('[data-counter]').forEach(function(el) {
            var counterId = el.getAttribute('data-counter');
            var max       = parseInt(el.getAttribute('data-max'), 10);
            var counter   = document.getElementById(counterId);
            if (!counter) return;
            function update() {
                var len = el.value.length;
                counter.textContent = len;
                var wrapper = counter.closest('.char-counter');
                if (wrapper) {
                    wrapper.classList.remove('warning', 'danger');
                    if      (len >= max * .90) wrapper.classList.add('danger');
                    else if (len >= max * .75) wrapper.classList.add('warning');
                }
            }
            el.addEventListener('input', update);
            update();
        });
    }

