    // ==================== TC ALGORİTMA KONTROLÜ ====================
     function validateTC(tc) {
        if (tc.length !== 11) return false;
        if (tc[0] === '0') return false;
        var digits = tc.split('').map(Number);
        var sum10 = digits.slice(0, 10).reduce(function(a, b) { return a + b; }, 0);
        if (sum10 % 10 !== digits[10]) return false;
        var oddSum  = digits[0] + digits[2] + digits[4] + digits[6] + digits[8];
        var evenSum = digits[1] + digits[3] + digits[5] + digits[7];
        if ((oddSum * 7 - evenSum) % 10 !== digits[9]) return false;
        return true;
    }


        // ==================== VKN ALGORİTMA KONTROLÜ ====================
    function validateVKN(vkn) {
        if (vkn.length !== 10) return false;
        var digits = vkn.split('').map(Number);
        var lastDigit = digits[9];
        var tmp = new Array(9);
        for (var i = 0; i < 9; i++) {
            tmp[i] = (digits[i] + (9 - i)) % 10;
        }
        var sum = 0;
        for (var i = 0; i < 9; i++) {
            if (tmp[i] !== 0) {
                var multiplied = tmp[i] * Math.pow(2, 9 - i);
                var mod = multiplied % 9;
                sum += (mod === 0) ? 9 : mod;
            }
        }
        return (10 - (sum % 10)) % 10 === lastDigit;
    }
