@model CRMProjectUI.Models.CustomerDto
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    string apiBase = Config["ApiSettings:BaseUrl"] ?? "";
}
@removeTagHelper Microsoft.AspNetCore.Mvc.TagHelpers.OptionTagHelper, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = Model.ID > 0 ? "Müşteri Düzenle" : "Yeni Müşteri";
    Layout = "~/Views/Shared/_adminLayout.cshtml";
    bool isEdit = Model.ID > 0;
    string imp = string.IsNullOrEmpty(Model.Importance) ? "" : Model.Importance;
    bool isSuperAdmin = ViewBag.IsSuperAdmin == true;

    // SuperAdmin → edit'te modelden oku, yeni kayıtta true | Admin → her zaman true
    bool isActive = isEdit ? Model.Status == 1 : true;

    var cityList = ViewBag.Cities as List<CRMProjectUI.Models.CitySelectDto> ?? new List<CRMProjectUI.Models.CitySelectDto>();
    var districtList = ViewBag.Districts as List<CRMProjectUI.Models.DistrictSelectDto> ?? new List<CRMProjectUI.Models.DistrictSelectDto>();
    var logoProducts = ViewBag.LogoProducts as List<CRMProjectUI.Models.LogoProductDto> ?? new List<CRMProjectUI.Models.LogoProductDto>();

    // Admin yeni kayıtta önem derecesi ve ticket'a müdahale edebilir
    bool canEditImportance = isSuperAdmin || !isEdit;
    bool canEditTicket = isSuperAdmin || !isEdit;
    // Admin yeni kayıtta sözleşme tarihlerini girebilir ama dosya yükleyemez
    bool showContractSection = isSuperAdmin || !isEdit;
    // Durum switch: sadece SuperAdmin
    bool canEditStatus = isSuperAdmin;
}
<style>
    .loading-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.5);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }

        .loading-overlay.show {
            display: flex;
        }

    .char-counter {
        font-size: .8rem;
    }

        .char-counter.warning {
            color: #ffc107;
        }

        .char-counter.danger {
            color: #dc3545;
        }

    .required-star {
        color: #dc3545;
        font-weight: bold;
    }

    .phone-input-group {
        display: flex;
        gap: 10px;
    }

        .phone-input-group select {
            width: 130px;
            flex-shrink: 0;
        }

        .phone-input-group input {
            flex: 1;
        }

    .card-section {
        margin-bottom: 1.5rem;
    }

        .card-section .card-header h6 {
            margin-bottom: 0;
        }

    .importance-radio {
        display: none;
    }

    .importance-label {
        display: inline-block;
        padding: 8px 16px;
        margin: 4px;
        border-radius: 20px;
        cursor: pointer;
        transition: all .3s;
        border: 2px solid transparent;
    }

    .importance-radio:checked + .importance-label {
        transform: scale(1.05);
        box-shadow: 0 4px 15px rgba(0,0,0,.2);
    }

    .importance-vip {
        background: linear-gradient(135deg,#667eea,#764ba2);
        color: #fff;
    }

    .importance-onemli {
        background: linear-gradient(135deg,#f093fb,#f5576c);
        color: #fff;
    }

    .importance-normal {
        background: linear-gradient(135deg,#4facfe,#00f2fe);
        color: #fff;
    }

    .importance-dusuk {
        background: linear-gradient(135deg,#a8edea,#fed6e3);
        color: #333;
    }

    .importance-radio:checked + .importance-vip {
        border-color: #764ba2;
    }

    .importance-radio:checked + .importance-onemli {
        border-color: #f5576c;
    }

    .importance-radio:checked + .importance-normal {
        border-color: #00f2fe;
    }

    .importance-radio:checked + .importance-dusuk {
        border-color: #fed6e3;
    }

    .customer-type-btn {
        padding: 12px 24px;
        border-radius: 10px;
        cursor: pointer;
        transition: all .3s;
        border: 2px solid #dee2e6;
        background: white;
    }

        .customer-type-btn:hover {
            border-color: #007bff;
        }

        .customer-type-btn.active {
            border-color: #007bff;
            background: #e7f1ff;
            box-shadow: 0 4px 10px rgba(0,123,255,.2);
        }

        .customer-type-btn i {
            font-size: 24px;
            margin-bottom: 5px;
        }

    .logo-product-checkbox {
        display: inline-block;
        margin: 5px;
    }

        .logo-product-checkbox input {
            display: none;
        }

        .logo-product-checkbox label {
            display: inline-block;
            padding: 8px 16px;
            border: 2px solid #dee2e6;
            border-radius: 8px;
            cursor: pointer;
            transition: all .2s;
            background: white;
        }

            .logo-product-checkbox label:hover {
                border-color: #007bff;
                background: #f8f9fa;
            }

        .logo-product-checkbox input:checked + label {
            border-color: #28a745;
            background: #d4edda;
            color: #155724;
        }

    .vkn-tc-toggle {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
    }

        .vkn-tc-toggle .btn {
            flex: 1;
        }

            .vkn-tc-toggle .btn.active {
                box-shadow: 0 0 0 3px rgba(0,123,255,.25);
            }

    .ticket-input-group {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ticket-btn {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1px solid #dee2e6;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 1rem;
        font-weight: bold;
        transition: background .15s;
        flex-shrink: 0;
    }

        .ticket-btn:hover {
            background: #e9ecef;
        }

        .ticket-btn.plus {
            color: #28a745;
        }

        .ticket-btn.minus {
            color: #dc3545;
        }

    #customerCodeWarning {
        display: none;
    }
</style>

<div class="loading-overlay" id="loadingOverlay">
    <div class="text-center text-white">
        <div class="spinner-border" style="width:3rem;height:3rem;" role="status">
            <span class="sr-only">Yükleniyor...</span>
        </div>
        <p class="mt-2">Kaydediliyor...</p>
    </div>
</div>

<div class="section-body">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4>
                        <i class="fas @(isEdit ? "fa-edit" : "fa-plus-circle") mr-2"></i>
                        @(isEdit ? "Müşteri Düzenle" : "Yeni Müşteri Ekle")
                    </h4>
                    <a asp-action="Liste" asp-controller="AdminMusteri" class="btn btn-sm btn-secondary">
                        <i class="fas fa-arrow-left"></i> Listeye Dön
                    </a>
                </div>
                <div class="card-body">
                    <form asp-action="@(isEdit ? "Duzenle" : "Ekle")"
                          asp-controller="AdminMusteri"
                          asp-route-id="@(isEdit ? Model.ID.ToString() : null)"
                          method="post" enctype="multipart/form-data" id="customerForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ID" />
                        <input type="hidden" asp-for="CreatedBy" />
                        <input type="hidden" asp-for="CreatedDate" />
                        <input type="hidden" id="statusHidden" name="Status" value="@(isActive ? "1" : "0")" />

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <strong><i class="fas fa-exclamation-triangle"></i> Lütfen hataları düzeltin:</strong>
                                <ul class="mb-0 mt-2">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        <!-- MÜŞTERİ TİPİ -->
                        <div class="card card-section">
                            <div class="card-header bg-primary text-white">
                                <h6><i class="fas fa-user-tag"></i> Müşteri Tipi <span class="required-star">*</span></h6>
                            </div>
                            <div class="card-body">
                                <div class="row justify-content-center">
                                    <div class="col-auto">
                                        <div class="customer-type-btn text-center @(Model.CustomerType == "Bireysel" ? "" : "active")"
                                             onclick="selectCustomerType('Kurumsal', this)">
                                            <i class="fas fa-building d-block text-primary"></i>
                                            <strong>Kurumsal</strong>
                                            <small class="d-block text-muted">Şirket / Firma</small>
                                        </div>
                                    </div>
                                    <div class="col-auto">
                                        <div class="customer-type-btn text-center @(Model.CustomerType == "Bireysel" ? "active" : "")"
                                             onclick="selectCustomerType('Bireysel', this)">
                                            <i class="fas fa-user d-block text-success"></i>
                                            <strong>Bireysel</strong>
                                            <small class="d-block text-muted">Şahıs</small>
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden" asp-for="CustomerType" id="CustomerType" />
                            </div>
                        </div>

                        <!-- TEMEL BİLGİLER -->
                        <div class="card card-section">
                            <div class="card-header bg-info text-white">
                                <h6><i class="fas fa-info-circle"></i> Temel Bilgiler</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Müşteri Kodu <span class="required-star">*</span></label>
                                            <input asp-for="CustomerCode" class="form-control" maxlength="20"
                                                   placeholder="MUS-0001" required
                                                   id="CustomerCode" onblur="checkCustomerCode(this.value)" />
                                            <small class="text-muted">Benzersiz, max 20 karakter</small>
                                            <div id="customerCodeWarning" class="text-danger mt-1">
                                                <i class="fas fa-exclamation-circle mr-1"></i>
                                                Bu müşteri kodu sistemde zaten kayıtlıdır!
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Müşteri / Firma Adı <span class="required-star">*</span></label>
                                            <input asp-for="CustomerName" class="form-control" maxlength="300" required
                                                   data-counter="cntCustomerName" data-max="300" />
                                            <small class="text-muted float-right char-counter">
                                                <span id="cntCustomerName">0</span>/300
                                            </small>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Kısa Ad</label>
                                            <input asp-for="ShortName" class="form-control" maxlength="50"
                                                   data-counter="cntShortName" data-max="50" />
                                            <small class="text-muted float-right char-counter">
                                                <span id="cntShortName">0</span>/50
                                            </small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-5">
                                        <div class="form-group">
                                            <label>VKN / TC Kimlik No <span class="required-star">*</span></label>
                                            <div class="vkn-tc-toggle">
                                                <button type="button" class="btn btn-outline-primary" id="btnVkn"
                                                        onclick="toggleVknTc('vkn')" disabled>
                                                    <i class="fas fa-building mr-1"></i> VKN
                                                </button>
                                                <button type="button" class="btn btn-outline-success" id="btnTc"
                                                        onclick="toggleVknTc('tc')" disabled>
                                                    <i class="fas fa-user mr-1"></i> TC
                                                </button>
                                            </div>
                                            <div id="vknInputGroup">
                                                <input asp-for="VKN" class="form-control" maxlength="10"
                                                       placeholder="10 haneli VKN"
                                                       oninput="this.value=this.value.replace(/\D/g,''); validateVknInput(this)"
                                                       id="VKN" />
                                                <div id="vknError" class="text-danger mt-1" style="display:none; font-size:.8rem;">
                                                    <i class="fas fa-exclamation-circle mr-1"></i>
                                                    VKN 10 haneli olmalıdır.
                                                </div>
                                                <small class="text-muted">Vergi Kimlik Numarası (10 hane)</small>
                                            </div>
                                            <div id="tcInputGroup" style="display:none;">
                                                <input asp-for="TC" class="form-control" maxlength="11"
                                                       placeholder="11 haneli TC"
                                                       oninput="this.value=this.value.replace(/\D/g,''); validateTcInput(this)"
                                                       id="TC" />
                                                <div id="tcError" class="text-danger mt-1" style="display:none; font-size:.8rem;">
                                                    <i class="fas fa-exclamation-circle mr-1"></i>
                                                    <span id="tcErrorText">TC 11 haneli olmalıdır.</span>
                                                </div>
                                                <small class="text-muted">TC Kimlik Numarası (11 hane)</small>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ÖNEM DERECESİ -->
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Önem Derecesi <span class="required-star">*</span></label>
                                            <div class="mt-2">
                                                @if (canEditImportance)
                                                {
                                                    <!-- SuperAdmin veya Admin yeni kayıt: düzenleyebilir -->
                                                    <input type="radio" name="Importance" value="VIP" id="impVip" class="importance-radio" @(imp == "VIP" ? "checked" : "") />
                                                    <label for="impVip" class="importance-label importance-vip">   <i class="fas fa-crown mr-1"></i>VIP    </label>

                                                    <input type="radio" name="Importance" value="Önemli" id="impOnemli" class="importance-radio" @(imp == "Önemli" ? "checked" : "") />
                                                    <label for="impOnemli" class="importance-label importance-onemli"><i class="fas fa-star  mr-1"></i>Önemli </label>

                                                    <input type="radio" name="Importance" value="Normal" id="impNormal" class="importance-radio" @(imp == "Normal" ? "checked" : "") />
                                                    <label for="impNormal" class="importance-label importance-normal"><i class="fas fa-check mr-1"></i>Normal </label>

                                                    <input type="radio" name="Importance" value="Düşük" id="impDusuk" class="importance-radio" @(imp == "Düşük" ? "checked" : "") />
                                                    <label for="impDusuk" class="importance-label importance-dusuk"> <i class="fas fa-minus mr-1"></i>Düşük  </label>
                                                }
                                                else
                                                {
                                                    <!-- Admin düzenleme: sadece görür, değiştiremez -->
                                                    <input type="radio" name="_Importance" value="VIP" id="impVip" class="importance-radio" disabled @(imp == "VIP" ? "checked" : "") />
                                                    <label for="impVip" class="importance-label importance-vip">   <i class="fas fa-crown mr-1"></i>VIP    </label>

                                                    <input type="radio" name="_Importance" value="Önemli" id="impOnemli" class="importance-radio" disabled @(imp == "Önemli" ? "checked" : "") />
                                                    <label for="impOnemli" class="importance-label importance-onemli"><i class="fas fa-star  mr-1"></i>Önemli </label>

                                                    <input type="radio" name="_Importance" value="Normal" id="impNormal" class="importance-radio" disabled @(imp == "Normal" ? "checked" : "") />
                                                    <label for="impNormal" class="importance-label importance-normal"><i class="fas fa-check mr-1"></i>Normal </label>

                                                    <input type="radio" name="_Importance" value="Düşük" id="impDusuk" class="importance-radio" disabled @(imp == "Düşük" ? "checked" : "") />
                                                    <label for="impDusuk" class="importance-label importance-dusuk"> <i class="fas fa-minus mr-1"></i>Düşük  </label>

                                                    <input type="hidden" name="Importance" value="@imp" />
                                                }
                                            </div>
                                        </div>
                                    </div>

                                    <!-- DESTEK TALEBİ -->
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>Destek Talebi Sayısı</label>
                                            <div class="ticket-input-group">
                                                @if (canEditTicket)
                                                {
                                                    <button type="button" class="ticket-btn minus" onclick="changeTicket(-1)">−</button>
                                                    <input name="TicketCount" type="number" class="form-control text-center"
                                                           min="0" id="TicketCount" style="max-width:80px;"
                                                           value="@(isEdit? Model.TicketCount: 100)" />
                                                    <button type="button" class="ticket-btn plus" onclick="changeTicket(1)">+</button>
                                                }
                                                else
                                                {
                                                    <input name="TicketCount" type="number" class="form-control text-center"
                                                           min="0" id="TicketCount" style="max-width:80px;"
                                                           value="@(isEdit? Model.TicketCount: 100)" readonly />
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- YETKİLİ KİŞİ -->
                        <div class="card card-section">
                            <div class="card-header bg-success text-white">
                                <h6><i class="fas fa-user-tie"></i> Yetkili Kişi Bilgileri</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Yetkili Adı Soyadı <span class="required-star">*</span></label>
                                            <input asp-for="OfficialName" class="form-control" maxlength="100" required />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Ünvanı <span class="required-star">*</span></label>
                                            <input asp-for="OfficialTitle" class="form-control" maxlength="50"
                                                   placeholder="Genel Müdür, Satın Alma Sorumlusu vb." required />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Yetkili Telefon <span class="required-star">*</span></label>
                                            <div class="phone-input-group">
                                                <select class="form-control" id="countryCodeOfficial">
                                                    <option value="+90">🇹🇷 Türkiye (+90)</option>
                                                    <option value="+93">🇦🇫 Afganistan (+93)</option>
                                                    <option value="+355">🇦🇱 Arnavutluk (+355)</option>
                                                    <option value="+213">🇩🇿 Cezayir (+213)</option>
                                                    <option value="+54">🇦🇷 Arjantin (+54)</option>
                                                    <option value="+61">🇦🇺 Avustralya (+61)</option>
                                                    <option value="+43">🇦🇹 Avusturya (+43)</option>
                                                    <option value="+32">🇧🇪 Belçika (+32)</option>
                                                    <option value="+55">🇧🇷 Brezilya (+55)</option>
                                                    <option value="+86">🇨🇳 Çin (+86)</option>
                                                    <option value="+45">🇩🇰 Danimarka (+45)</option>
                                                    <option value="+20">🇪🇬 Mısır (+20)</option>
                                                    <option value="+358">🇫🇮 Finlandiya (+358)</option>
                                                    <option value="+33">🇫🇷 Fransa (+33)</option>
                                                    <option value="+49">🇩🇪 Almanya (+49)</option>
                                                    <option value="+30">🇬🇷 Yunanistan (+30)</option>
                                                    <option value="+91">🇮🇳 Hindistan (+91)</option>
                                                    <option value="+62">🇮🇩 Endonezya (+62)</option>
                                                    <option value="+98">🇮🇷 İran (+98)</option>
                                                    <option value="+964">🇮🇶 Irak (+964)</option>
                                                    <option value="+353">🇮🇪 İrlanda (+353)</option>
                                                    <option value="+972">🇮🇱 İsrail (+972)</option>
                                                    <option value="+39">🇮🇹 İtalya (+39)</option>
                                                    <option value="+81">🇯🇵 Japonya (+81)</option>
                                                    <option value="+7">🇰🇿 Kazakistan (+7)</option>
                                                    <option value="+965">🇰🇼 Kuveyt (+965)</option>
                                                    <option value="+961">🇱🇧 Lübnan (+961)</option>
                                                    <option value="+60">🇲🇾 Malezya (+60)</option>
                                                    <option value="+52">🇲🇽 Meksika (+52)</option>
                                                    <option value="+31">🇳🇱 Hollanda (+31)</option>
                                                    <option value="+64">🇳🇿 Yeni Zelanda (+64)</option>
                                                    <option value="+47">🇳🇴 Norveç (+47)</option>
                                                    <option value="+92">🇵🇰 Pakistan (+92)</option>
                                                    <option value="+48">🇵🇱 Polonya (+48)</option>
                                                    <option value="+351">🇵🇹 Portekiz (+351)</option>
                                                    <option value="+974">🇶🇦 Katar (+974)</option>
                                                    <option value="+40">🇷🇴 Romanya (+40)</option>
                                                    <option value="+7">🇷🇺 Rusya (+7)</option>
                                                    <option value="+966">🇸🇦 Suudi Arabistan (+966)</option>
                                                    <option value="+65">🇸🇬 Singapur (+65)</option>
                                                    <option value="+27">🇿🇦 Güney Afrika (+27)</option>
                                                    <option value="+82">🇰🇷 Güney Kore (+82)</option>
                                                    <option value="+34">🇪🇸 İspanya (+34)</option>
                                                    <option value="+46">🇸🇪 İsveç (+46)</option>
                                                    <option value="+41">🇨🇭 İsviçre (+41)</option>
                                                    <option value="+66">🇹🇭 Tayland (+66)</option>
                                                    <option value="+380">🇺🇦 Ukrayna (+380)</option>
                                                    <option value="+971">🇦🇪 BAE (+971)</option>
                                                    <option value="+44">🇬🇧 İngiltere (+44)</option>
                                                    <option value="+1">🇺🇸 ABD (+1)</option>
                                                </select>
                                                <input asp-for="OfficialPhone" id="OfficialPhone" class="form-control" maxlength="20" required />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Yetkili E-posta <span class="required-star">*</span></label>
                                            <input asp-for="OfficialEmail" class="form-control" type="email" maxlength="150" required />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- İLETİŞİM -->
                        <div class="card card-section">
                            <div class="card-header bg-warning">
                                <h6><i class="fas fa-address-book"></i> Firma İletişim Bilgileri</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Şirket E-posta <span class="required-star">*</span></label>
                                            <input asp-for="CompanyEmail" class="form-control" type="email" maxlength="150" required />
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Telefon 1</label>
                                            <div class="phone-input-group">
                                                <select class="form-control" id="countryCode1">
                                                    <option value="+90">🇹🇷 +90</option>
                                                    <option value="+1">🇺🇸 +1</option>
                                                    <option value="+44">🇬🇧 +44</option>
                                                    <option value="+49">🇩🇪 +49</option>
                                                </select>
                                                <input asp-for="Phone1" id="Phone1" class="form-control" maxlength="20" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Telefon 2</label>
                                            <div class="phone-input-group">
                                                <select class="form-control" id="countryCode2">
                                                    <option value="+90">🇹🇷 +90</option>
                                                    <option value="+1">🇺🇸 +1</option>
                                                    <option value="+44">🇬🇧 +44</option>
                                                    <option value="+49">🇩🇪 +49</option>
                                                </select>
                                                <input asp-for="Phone2" id="Phone2" class="form-control" maxlength="20" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ADRES -->
                        <div class="card card-section">
                            <div class="card-header bg-secondary text-white">
                                <h6><i class="fas fa-map-marker-alt"></i> Adres Bilgileri</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>İl <span class="required-star">*</span></label>
                                            <select id="citySelect" name="Il" class="form-control" required>
                                                <option value="">İl Seçiniz...</option>
                                                @foreach (var city in cityList)
                                                {
                                                    if (Model.Il == city.Il)
                                                    {
                                                        <option value="@city.Il" selected>@city.Il</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@city.Il">@city.Il</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-8">
                                        <div class="form-group">
                                            <label>İlçe <span class="required-star">*</span></label>
                                            <select name="CityDistrictID" id="districtSelect" class="form-control" required>
                                                <option value="">Önce il seçiniz...</option>
                                                @foreach (var district in districtList)
                                                {
                                                    if (Model.CityDistrictID == district.ID)
                                                    {
                                                        <option value="@district.ID" selected>@district.DisplayText</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@district.ID">@district.DisplayText</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Açık Adres <span class="required-star">*</span></label>
                                    <textarea asp-for="Address" class="form-control" rows="2" maxlength="500"
                                              placeholder="Sokak, Cadde, Bina No, Daire No..." required
                                              data-counter="cntAddress" data-max="500"></textarea>
                                    <small class="text-muted float-right char-counter">
                                        <span id="cntAddress">0</span>/500
                                    </small>
                                </div>
                            </div>
                        </div>

                        <!-- LOGO ENTEGRASYON -->
                        <div class="card card-section">
                            <div class="card-header bg-dark text-white">
                                <h6><i class="fas fa-cogs"></i> Logo Entegrasyon Bilgileri</h6>
                            </div>
                            <div class="card-body">
                                @if (logoProducts.Any())
                                {
                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-box-open mr-1"></i>
                                            Kullandığı Logo Ürünleri <span class="required-star">*</span>
                                        </label>
                                        <small class="text-muted d-block mb-1">En az bir ürün seçilmelidir</small>
                                        <div class="mt-2">
                                            @foreach (var product in logoProducts)
                                            {
                                                bool isChecked = Model.LogoProductIDs?.Contains((int)product.ID) == true;
                                                <div class="logo-product-checkbox">
                                                    <input type="checkbox" name="LogoProductIDs"
                                                           value="@product.ID" id="prod_@product.ID"
                                                           @(isChecked ? "checked" : "") />
                                                    <label for="prod_@product.ID">
                                                        <i class="fas fa-cube mr-1"></i> @product.LogoProductName
                                                    </label>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <hr />
                                }
                                <div class="row">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Web Servis Kullanıcı Adı</label>
                                            <input asp-for="LogoWebServiceUserName" class="form-control" maxlength="100" />
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Web Servis Şifresi</label>
                                            <div class="input-group">
                                                <input type="password" class="form-control" maxlength="256" id="logoWsPass"
                                                       autocomplete="new-password"
                                                       data-real="@Model.LogoWebServicePassword"
                                                       placeholder="@(isEdit && !string.IsNullOrEmpty(Model.LogoWebServicePassword) ? "••••••••" : "")" />
                                                <div class="input-group-append">
                                                    <button type="button" class="btn btn-outline-secondary"
                                                            onclick="togglePassword('logoWsPass', this)">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                    @if (isEdit && !string.IsNullOrEmpty(Model.LogoWebServicePassword))
                                                    {
                                                        <button type="button" class="btn btn-outline-danger"
                                                                onclick="clearPassword('logoWsPass', 'logoWsPassHidden')"
                                                                title="Şifreyi Sil">
                                                            <i class="fas fa-times"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                            <input type="hidden" id="logoWsPassHidden" name="LogoWebServicePassword" value="@Model.LogoWebServicePassword" />
                             
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>SQL Şifresi</label>
