@model List<CRMProjectUI.Models.KnowledgeBaseListDto>
@{
    ViewData["Title"] = "Bilgi Bankası";
    Layout = "~/Views/Shared/_adminLayout.cshtml";

    bool isSuperAdmin = User.IsInRole("SuperAdmin");
    bool isAdmin = User.IsInRole("Admin");
    bool isUser = User.IsInRole("User");
    bool canManage = isAdmin || isSuperAdmin; // Yönetim yetkisi

    var products = ViewBag.Products as List<CRMProjectUI.Models.LogoProductDto> ?? new List<CRMProjectUI.Models.LogoProductDto>();
    var categories = ViewBag.Categories as List<string> ?? new List<string>();

    string? searchVal = ViewBag.Search as string;
    short? productVal = ViewBag.LogoProduct as short?;
    string? categoryVal = ViewBag.Category as string;
    string? successMsg = TempData["Success"] as string ?? ViewBag.SuccessMsg as string;
    string? errorMsg = TempData["Error"] as string ?? ViewBag.ErrorMsg as string;

    int callerUserId = int.TryParse(
        User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value,
        out int cuid) ? cuid : 0;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --ink: #0f1117;
        --ink-soft: #4a4f5e;
        --surface: #f7f8fc;
        --white: #fff;
        --accent: #2563eb;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --purple: #7c3aed;
        --border: #e2e8f0;
        --radius: 12px;
        --shadow-sm: 0 2px 8px rgba(15,17,23,.06);
        --shadow-md: 0 8px 32px rgba(15,17,23,.10);
    }

    .kb-page {
        font-family: 'DM Sans', sans-serif;
    }

    .kb-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: wrap;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 12px 16px;
        margin-bottom: 14px;
        box-shadow: var(--shadow-sm);
    }

    .kb-toolbar-left {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .kb-toolbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .kb-search {
        display: flex;
        align-items: center;
        gap: 7px;
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 20px;
        padding: 6px 14px;
        transition: border-color .2s;
    }

        .kb-search:focus-within {
            border-color: var(--accent);
        }

        .kb-search i {
            color: var(--ink-soft);
            font-size: .82rem;
        }

        .kb-search input {
            border: none;
            background: transparent;
            outline: none;
            font-size: .82rem;
            color: var(--ink);
            width: 180px;
        }

    .kb-select {
        padding: 6px 12px;
        border: 1.5px solid var(--border);
        border-radius: 20px;
        background: var(--surface);
        font-size: .82rem;
        color: var(--ink);
        outline: none;
        cursor: pointer;
        transition: border-color .2s;
    }

        .kb-select:focus {
            border-color: var(--accent);
        }

    .kb-add-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 15px;
        border-radius: 9px;
        background: var(--accent);
        color: #fff;
        font-size: .82rem;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
        box-shadow: 0 3px 10px rgba(37,99,235,.3);
        transition: all .15s;
        border: none;
        cursor: pointer;
    }

        .kb-add-btn:hover {
            background: #1d4ed8;
            color: #fff;
            text-decoration: none;
            transform: translateY(-1px);
        }

    .kb-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 16px;
        margin-bottom: 20px;
    }

    .kb-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: box-shadow .2s, transform .2s;
    }

        .kb-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

    .kb-card-top {
        padding: 16px 18px 12px;
        flex: 1;
    }

    .kb-card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 10px;
    }

    .kb-tag {
        font-size: .67rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 20px;
        white-space: nowrap;
    }

        .kb-tag.product {
            background: #f5f3ff;
            color: var(--purple);
        }

        .kb-tag.category {
            background: #eff6ff;
            color: var(--accent);
        }

        .kb-tag.code {
            background: #f0fdf4;
            color: var(--success);
        }

    .kb-card-title {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: .95rem;
        color: var(--ink);
        margin-bottom: 6px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .kb-card-desc {
        font-size: .8rem;
        color: var(--ink-soft);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .kb-card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 18px;
        border-top: 1px solid var(--border);
        background: var(--surface);
        gap: 8px;
        flex-wrap: wrap;
    }

    .kb-card-info {
        font-size: .72rem;
        color: var(--ink-soft);
    }

    .kb-card-badges {
        display: flex;
        gap: 5px;
        align-items: center;
    }

    .kb-badge {
        font-size: .65rem;
        font-weight: 700;
        padding: 2px 7px;
        border-radius: 8px;
        white-space: nowrap;
    }

        .kb-badge.active {
            background: #f0fdf4;
            color: #166534;
        }

        .kb-badge.passive {
            background: #fef2f2;
            color: #991b1b;
        }

        .kb-badge.public {
            background: #f0fdf4;
            color: #166534;
        }

        .kb-badge.private {
            background: #f1f5f9;
            color: #475569;
        }

    .kb-card-actions {
        display: flex;
        gap: 4px;
        padding: 10px 18px;
        border-top: 1px solid var(--border);
    }

    .kb-btn {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: .75rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        border: 1.5px solid var(--border);
        background: var(--white);
        color: var(--ink-soft);
        transition: all .15s;
    }

        .kb-btn:hover {
            transform: translateY(-1px);
            text-decoration: none;
        }

        .kb-btn.detail:hover {
            background: #eff6ff;
            border-color: var(--accent);
            color: var(--accent);
        }

        .kb-btn.edit:hover {
            background: #f5f3ff;
            border-color: var(--purple);
            color: var(--purple);
        }

        .kb-btn.delete:hover {
            background: #fef2f2;
            border-color: var(--danger);
            color: var(--danger);
        }

    .kb-empty {
        text-align: center;
        padding: 60px 24px;
        color: var(--ink-soft);
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
    }

        .kb-empty i {
            font-size: 3rem;
            opacity: .15;
            display: block;
            margin-bottom: 12px;
        }
</style>

@Html.AntiForgeryToken()

<div class="kb-page">

    <!-- BAŞLIK -->
    <div class="d-flex align-items-center justify-content-between mb-3"
         style="flex-wrap:wrap; gap:10px;">
        <div>
            <h5 style="font-family:'Syne',sans-serif; font-weight:700; margin:0;">
                <i class="fas fa-book-open mr-2 text-primary"></i> Bilgi Bankası
            </h5>
            <small style="color:var(--ink-soft);">@(Model?.Count ?? 0) makale listeleniyor</small>
        </div>
        @if (canManage)
        {
            <a asp-action="Ekle" asp-controller="AdminBilgiBankasi" class="kb-add-btn">
                <i class="fas fa-plus"></i> Yeni Makale
            </a>
        }
    </div>

    <!-- TOOLBAR -->
    <form method="get" asp-action="Liste" asp-controller="AdminBilgiBankasi">
        <div class="kb-toolbar">
            <div class="kb-toolbar-left">
                <div class="kb-search">
                    <i class="fas fa-search"></i>
                    <input type="text" name="search" value="@searchVal"
                           placeholder="Başlık veya içerik ara..." />
                </div>
                <select name="logoProduct" class="kb-select" onchange="this.form.submit()">
                    <option value="">Tüm Ürünler</option>
                    @foreach (var p in products)
                    {
                        <option value="@p.ID" selected="@(productVal == p.ID)">@p.LogoProductName</option>
                    }
                </select>
                <select name="category" class="kb-select" onchange="this.form.submit()">
                    <option value="">Tüm Kategoriler</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c" selected="@(categoryVal == c)">@c</option>
                    }
                </select>
            </div>
            <div class="kb-toolbar-right">
                <button type="submit" class="kb-add-btn"
                        style="background:var(--ink-soft); box-shadow:none;">
                    <i class="fas fa-filter"></i> Filtrele
                </button>
                @if (!string.IsNullOrEmpty(searchVal) || productVal.HasValue || !string.IsNullOrEmpty(categoryVal))
                {
                    <a asp-action="Liste" asp-controller="AdminBilgiBankasi"
                       class="kb-add-btn" style="background:#64748b; box-shadow:none;">
                        <i class="fas fa-times"></i> Temizle
                    </a>
                }
            </div>
        </div>
    </form>

    <!-- KART GRİD -->
    @if (!Model?.Any() == true)
    {
        <div class="kb-empty">
            <i class="fas fa-book-open"></i>
            @if (canManage)
            {
                <p style="font-weight:600; margin-bottom:6px;">Henüz makale yok</p>
                <p style="font-size:.83rem; margin-bottom:16px;">
                    İlk makaleyi oluşturmak için butona tıklayın.
                </p>
                <a asp-action="Ekle" asp-controller="AdminBilgiBankasi"
                   class="kb-add-btn" style="display:inline-flex;">
                    <i class="fas fa-plus"></i> İlk Makaleyi Oluştur
                </a>
            }
            else
            {
                <p style="font-weight:600; margin-bottom:6px;">Henüz makale bulunamadı</p>
                <p style="font-size:.83rem; margin-bottom:0;">
                    Firmanızla ilgili bilgi bankası makaleleri burada görünecek.
                </p>
            }
        </div>
    }
    else
    {
        <div class="kb-grid">
            @foreach (var item in Model!)
            {
                bool canEdit = isSuperAdmin || item.CreatedBy == callerUserId;

                <div class="kb-card">
                    <div class="kb-card-top">
                        <!-- TAGS -->
                        <div class="kb-card-tags">
                            @foreach (var pName in item.ProductNameList)
                            {
                                <span class="kb-tag product">
                                    <i class="fas fa-cube mr-1" style="font-size:.55rem;"></i>@pName
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(item.Category))
                            {
                                <span class="kb-tag category">@item.Category</span>
                            }
                            @if (!string.IsNullOrEmpty(item.CodeLanguage))
                            {
                                <span class="kb-tag code">
                                    <i class="fas fa-code mr-1" style="font-size:.55rem;"></i>@item.CodeLanguage
                                </span>
                            }
                        </div>
                        <!-- BAŞLIK -->
                        <div class="kb-card-title">@item.Title</div>
                        <!-- AÇIKLAMA -->
                        <div class="kb-card-desc">@item.Description</div>
                    </div>

                    <!-- META -->
                    <div class="kb-card-meta">
                        <div>
                            <div class="kb-card-info">
                                <i class="fas fa-user mr-1"></i>@(item.CreatedByName ?? "-")
                            </div>
                            <div class="kb-card-info">
                                <i class="fas fa-calendar mr-1"></i>@item.CreatedDate.ToString("dd.MM.yyyy")
                                @if (item.FileCount > 0)
                                {
                                    <span class="ml-2">
                                        <i class="fas fa-paperclip mr-1"></i>@item.FileCount dosya
                                    </span>
                                }
                            </div>
                        </div>
                        @if (canManage)
                        {
                            <!-- Aktif/Pasif ve Gizli/Açık sadece Admin/SuperAdmin görür -->
                            <div class="kb-card-badges">
                                <span class="kb-badge @(item.IsActive ? "active" : "passive")">
                                    @(item.IsActive ? "Aktif" : "Pasif")
                                </span>
                                <span class="kb-badge @(item.IsPublic ? "public" : "private")">
                                    @(item.IsPublic ? "Müşteri Görebilir" : "Gizli")
                                </span>
                            </div>
                        }
                    </div>

                    <!-- ACTIONS -->
                    <div class="kb-card-actions">
                        <a asp-action="Detay" asp-controller="AdminBilgiBankasi"
                           asp-route-id="@item.ID" class="kb-btn detail">
                            <i class="fas fa-eye"></i> Detay
                        </a>
                        @if (canManage && canEdit)
                        {
                            <a asp-action="Duzenle" asp-controller="AdminBilgiBankasi"
                               asp-route-id="@item.ID" class="kb-btn edit">
                                <i class="fas fa-edit"></i> Düzenle
                            </a>
                            <button type="button" class="kb-btn delete"
                                    onclick="confirmDelete(@item.ID, '@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.Title)')">
                                <i class="fas fa-trash"></i> Sil
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- SİL FORM -->
<form id="deleteForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        var __success = '@Html.Raw(successMsg?.Replace("'", "\\'") ?? "")';
        var __error   = '@Html.Raw(errorMsg?.Replace("'", "\\'") ?? "")';

        if (__success) Swal.fire({ icon:'success', title:'Başarılı!', text:__success, timer:2500, showConfirmButton:false });
        if (__error)   Swal.fire({ icon:'error',   title:'Hata!',     text:__error });

        function confirmDelete(id, title) {
            Swal.fire({
                title: 'Makale Silinsin mi?',
                html: '<b>' + title + '</b><br><small>Bu işlem geri alınamaz, tüm dosyalar da silinir.</small>',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'İptal'
            }).then(function(result) {
                if (result.isConfirmed) {
                    var form = document.getElementById('deleteForm');
                    form.action = '/AdminBilgiBankasi/Sil/' + id;
                    form.submit();
                }
            });
        }
    </script>
}
