                                            <small class="text-muted float-right char-counter"><span id="cntMission">0</span>/1000</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- LOGO & FAVICON -->
                        <div class="card mb-3">
                            <div class="card-header bg-dark text-white">
                                <h6 class="mb-0"><i class="fas fa-image"></i> Logo & Favicon <span class="required-star">*</span></h6>
                            </div>
                            <div class="card-body">
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    Logo ve Favicon yüklemek <strong>zorunludur</strong>.
                                </div>
                                <div class="row">
                                    <!-- Logo -->
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><strong>Logo</strong> <span class="required-star">*</span></label>
                                            @if (!string.IsNullOrEmpty(Model?.LogoPath))
                                            {
                                                <div class="mb-2" id="existingLogoBox">
                                                    <img src="@($"{apiBase}{Model.LogoPath}")" class="img-thumbnail img-hover-zoom"
                                                         style="max-height:80px;" alt="Logo" loading="lazy" />
                                             
                                                    <input type="hidden" id="originalLogoPath" value="@Model.LogoPath" />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="alert alert-danger py-2" id="noLogoAlert">
                                                    <small><i class="fas fa-exclamation-circle"></i> Logo yüklenmemiş!</small>
                                                </div>
                                            }
                                            <input type="file" name="LogoFile" id="LogoFile" class="form-control-file"
                                                   accept=".png,.jpg,.jpeg,.gif,.webp,.svg" />
                                            <small class="text-muted">PNG, JPG, GIF, WEBP, SVG - Max 5MB</small>
                                            <div id="newLogoPreview" class="mt-2" style="display:none;">
                                                <img id="logoPreviewImg" class="img-thumbnail img-hover-zoom" style="max-height:80px;" alt="Yeni Logo" />
                                             
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Favicon -->
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><strong>Favicon</strong> <span class="required-star">*</span></label>
                                            @if (!string.IsNullOrEmpty(Model?.FaviconPath))
                                            {
                                                <div class="mb-2" id="existingFaviconBox">
                                                    <img src="@($"{apiBase}{Model.FaviconPath}")" class="img-thumbnail img-hover-zoom"
                                                         style="max-height:50px;" alt="Favicon" loading="lazy" />
                                                
                                                    <input type="hidden" id="originalFaviconPath" value="@Model.FaviconPath" />

                                                </div>
                                            }
                                            else
                                            {
                                                <div class="alert alert-danger py-2" id="noFaviconAlert">
                                                    <small><i class="fas fa-exclamation-circle"></i> Favicon yüklenmemiş!</small>
                                                </div>
                                            }
                                            <input type="file" name="FaviconFile" id="FaviconFile" class="form-control-file"
                                                   accept=".png,.ico" />
                                            <small class="text-muted">ICO, PNG - 32x32 veya 64x64 önerilir - Max 2MB</small>
                                            <div id="newFaviconPreview" class="mt-2" style="display:none;">
                                                <img id="faviconPreviewImg" class="img-thumbnail img-hover-zoom" style="max-height:50px;" alt="Yeni Favicon" />
                                              
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- BUTONLAR -->
                        <div class="text-right">
                            <a asp-action="Liste" asp-controller="AdminSirket" class="btn btn-secondary">
                                <i class="fas fa-times"></i> İptal
                            </a>
                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                <i class="fas fa-save"></i> Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // TempData Mesajları
     
        // Init
        initCharCounters();
        initPhoneInputs();
    });
    // ==================== TELEFON FORMATLAMA ====================
    var phoneFormats = {
        "+90": { max: 10, pattern: [3, 3, 2, 2] },
        "+1": { max: 10, pattern: [3, 3, 4] },
        "+44": { max: 10, pattern: [4, 3, 3] },
        "+49": { max: 11, pattern: [3, 3, 2, 3] },
        "+33": { max: 9, pattern: [1, 2, 2, 2, 2] },
        "+39": { max: 10, pattern: [3, 3, 4] },
        "+7": { max: 10, pattern: [3, 2, 2, 3] },
        "+86": { max: 11, pattern: [3, 4, 4] },
        "+91": { max: 10, pattern: [4, 3, 3] },
        "+81": { max: 10, pattern: [3, 4, 3] },
        "+82": { max: 10, pattern: [3, 3, 4] },
        "+966": { max: 9, pattern: [2, 3, 4] },
        "+971": { max: 9, pattern: [2, 3, 4] },
        "+20": { max: 10, pattern: [2, 3, 3, 2] },
        "+27": { max: 9, pattern: [2, 3, 4] },
        "+55": { max: 11, pattern: [2, 5, 4] },
        "+52": { max: 10, pattern: [2, 4, 4] },
        "+93": { max: 9, pattern: [2, 3, 4] },
        "+355": { max: 9, pattern: [2, 3, 4] },
        "+213": { max: 9, pattern: [2, 3, 4] },
        "+376": { max: 6, pattern: [3, 3] },
        "+244": { max: 9, pattern: [3, 3, 3] },
        "+54": { max: 10, pattern: [2, 4, 4] },
        "+374": { max: 8, pattern: [2, 3, 3] },
        "+61": { max: 9, pattern: [3, 3, 3] },
        "+43": { max: 10, pattern: [3, 3, 4] },
        "+994": { max: 9, pattern: [2, 3, 4] },
        "+973": { max: 8, pattern: [4, 4] },
        "+32": { max: 9, pattern: [3, 3, 3] },
        "+359": { max: 9, pattern: [3, 3, 3] },
        "+45": { max: 8, pattern: [2, 2, 2, 2] },
        "+358": { max: 10, pattern: [3, 3, 4] },
        "+30": { max: 10, pattern: [3, 3, 4] },
        "+852": { max: 8, pattern: [4, 4] },
        "+36": { max: 9, pattern: [2, 3, 4] },
        "+62": { max: 11, pattern: [3, 4, 4] },
        "+98": { max: 10, pattern: [3, 3, 4] },
        "+964": { max: 10, pattern: [3, 3, 4] },
        "+353": { max: 9, pattern: [3, 3, 3] },
        "+972": { max: 9, pattern: [2, 3, 4] },
        "+962": { max: 9, pattern: [2, 3, 4] },
        "+965": { max: 8, pattern: [4, 4] },
        "+961": { max: 8, pattern: [3, 3, 2] },
        "+60": { max: 10, pattern: [3, 3, 4] },
        "+31": { max: 9, pattern: [3, 3, 3] },
        "+64": { max: 9, pattern: [3, 3, 3] },
        "+47": { max: 8, pattern: [2, 2, 2, 2] },
        "+92": { max: 10, pattern: [3, 3, 4] },
        "+48": { max: 9, pattern: [3, 3, 3] },
        "+351": { max: 9, pattern: [3, 3, 3] },
        "+974": { max: 8, pattern: [4, 4] },
        "+40": { max: 10, pattern: [3, 3, 4] },
        "+65": { max: 8, pattern: [4, 4] },
        "+34": { max: 9, pattern: [3, 3, 3] },
        "+46": { max: 10, pattern: [3, 3, 4] },
        "+41": { max: 9, pattern: [2, 3, 4] },
        "+886": { max: 9, pattern: [3, 3, 3] },
        "+66": { max: 9, pattern: [3, 3, 3] },
        "+380": { max: 9, pattern: [2, 3, 4] },
        "_default": { max: 15, pattern: [3, 3, 3, 3, 3] }
    };
    function formatPhoneNumber(number, code) {
        var config = phoneFormats[code] || phoneFormats._default;
        var digitsOnly = number.replace(/\D/g, '').substring(0, config.max);
        var formattedNumber = code + ' ';
       var position = 0;
        for (var i = 0; i < config.pattern.length; i++) {
            var partLength = config.pattern[i];
            if (position >= digitsOnly.length) break;
            var part = digitsOnly.substr(position, partLength);
            if (part.length > 0) {
                formattedNumber += part + ' ';
                position += partLength;
            }
        }
        return formattedNumber.trim();
    }
    function initPhoneInputs() {
        // Telefon 1
        initSinglePhoneInput('Phone1', 'countryCodeSelect1');
        // Telefon 2
        initSinglePhoneInput('Phone2', 'countryCodeSelect2');
    }
    function initSinglePhoneInput(inputId, selectId) {
        var phoneInput = document.getElementById(inputId);
        var countrySelect = document.getElementById(selectId);
        if (!phoneInput || !countrySelect) return;
        // Mevcut değerden ülke kodunu tespit et
        var currentValue = phoneInput.value.trim();
        if (currentValue) {
            // Ülke kodunu bul
            for (var code in phoneFormats) {
                if (code !== '_default' && currentValue.startsWith(code)) {
                    countrySelect.value = code;
                    break;
                }
            }
        }
        function updateFormattedPhone() {
            var code = countrySelect.value;
            var codeDigits = code.replace(/\D/g, '');
            var currentDigits = phoneInput.value.replace(/\D/g, '');
            // Ülke kodunu çıkar
            if (currentDigits.startsWith(codeDigits)) {
                currentDigits = currentDigits.substring(codeDigits.length);
            }

            phoneInput.value = formatPhoneNumber(currentDigits, code);
        }
        countrySelect.addEventListener('change', function () {
            phoneInput.value = this.value + ' ';
            phoneInput.focus();
        });
        phoneInput.addEventListener('input', function (e) {
            var code = countrySelect.value;
            var codeDigits = code.replace(/\D/g, '');

            if ((e.inputType === 'deleteContentBackward' || e.inputType === 'deleteContentForward') &&
                phoneInput.value.replace(/\D/g, '') === codeDigits) {
                phoneInput.value = code + ' ';
                return;
            }
            updateFormattedPhone();
        });
        phoneInput.addEventListener('focus', function () {
            setTimeout(function () {
                phoneInput.setSelectionRange(phoneInput.value.length, phoneInput.value.length);
            }, 0);
        });
        // Başlangıç değeri
        if (!currentValue || !currentValue.startsWith('+')) {
            phoneInput.value = countrySelect.value + ' ';
        } else {
            updateFormattedPhone();
        }
    }
    // ==================== KARAKTER SAYAÇLARI ====================
    function initCharCounters() {
        var counters = [
            { input: 'CompanyName', counter: 'cntCompanyName', max: 100 },
            { input: 'ShortCompanyName', counter: 'cntShortName', max: 50 },
            { input: 'Slogan', counter: 'cntSlogan', max: 200 },
            { input: 'SectorDescription', counter: 'cntSector', max: 500 },
            { input: 'Address', counter: 'cntAddress', max: 300 },
            { input: 'WebSiteTitle', counter: 'cntWebTitle', max: 100 },
            { input: 'MetaTitle', counter: 'cntMetaTitle', max: 70 },
            { input: 'MetaDescription', counter: 'cntMetaDesc', max: 160 },
            { input: 'AboutUsShort', counter: 'cntAboutShort', max: 500 },
            { input: 'Vision', counter: 'cntVision', max: 1000 },
            { input: 'Mission', counter: 'cntMission', max: 1000 }
        ];
        counters.forEach(function (item) {
            var el = document.querySelector('[name="' + item.input + '"]');
            var cnt = document.getElementById(item.counter);
            if (!el || !cnt) return;
            function update() {
                var len = el.value.length;
                cnt.textContent = len;
                var parent = cnt.closest('.char-counter');
                if (parent) {
                    parent.classList.remove('warning', 'danger');
                    if (len >= item.max * 0.9) parent.classList.add('danger');
                    else if (len >= item.max * 0.75) parent.classList.add('warning');
                }
            }
            el.addEventListener('input', update);
            update();
        });
    }
    // ==================== DOSYA İŞLEMLERİ ====================
    document.getElementById('LogoFile').addEventListener('change', function () {
        var file = this.files[0];
        if (!file) return;
        var validResult = validateFile(file, 'logo');
        if (!validResult.valid) {
            Swal.fire({ icon: 'error', title: 'Hata!', text: validResult.error });
            this.value = '';
            return;
        }
        var reader = new FileReader();
        reader.onload = function (e) {
            document.getElementById('logoPreviewImg').src = e.target.result;
            document.getElementById('newLogoPreview').style.display = 'block';
            var box = document.getElementById('existingLogoBox');
            if (box) box.style.display = 'none';
            var alert = document.getElementById('noLogoAlert');
            if (alert) alert.style.display = 'none';
        };
        reader.readAsDataURL(file);
    });
    document.getElementById('FaviconFile').addEventListener('change', function () {
        var file = this.files[0];
        if (!file) return;
        var validResult = validateFile(file, 'favicon');
        if (!validResult.valid) {
            Swal.fire({ icon: 'error', title: 'Hata!', text: validResult.error });
            this.value = '';
            return;
        }
        var reader = new FileReader();
        reader.onload = function (e) {
            document.getElementById('faviconPreviewImg').src = e.target.result;
            document.getElementById('newFaviconPreview').style.display = 'block';
            var box = document.getElementById('existingFaviconBox');
            if (box) box.style.display = 'none';
            var alert = document.getElementById('noFaviconAlert');
            if (alert) alert.style.display = 'none';
        };
        reader.readAsDataURL(file);
    });
    function validateFile(file, type) {
        var config = {
            logo: {
                maxSize: 5 * 1024 * 1024,
                allowedTypes: ['image/png', 'image/jpeg', 'image/gif', 'image/webp', 'image/svg+xml'],
                allowedExts: ['.png', '.jpg', '.jpeg', '.gif', '.webp', '.svg'],
                errorMsg: 'PNG, JPG, GIF, WEBP, SVG'
            },
            favicon: {
                maxSize: 2 * 1024 * 1024,
                allowedTypes: ['image/png', 'image/x-icon', 'image/vnd.microsoft.icon'],
                allowedExts: ['.png', '.ico'],
                errorMsg: 'PNG, ICO'
            }
        };
        var cfg = config[type];
        var ext = file.name.toLowerCase().substring(file.name.lastIndexOf('.'));
        if (cfg.allowedTypes.indexOf(file.type) === -1 && cfg.allowedExts.indexOf(ext) === -1) {
            return { valid: false, error: 'Geçersiz dosya formatı. İzin verilen: ' + cfg.errorMsg };
        }
        if (file.size > cfg.maxSize) {
            return { valid: false, error: 'Dosya boyutu en fazla ' + (cfg.maxSize / 1024 / 1024) + 'MB olabilir' };
        }
        return { valid: true };
    }
    function removeLogo() {
        Swal.fire({
            title: 'Emin misiniz?',
            text: 'Logo silmek istediğinize emin misiniz? Bu alan zorunludur!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'İptal'
        }).then(function (result) {
            if (result.isConfirmed) {
                var box = document.getElementById('existingLogoBox');
                if (box) box.style.display = 'none';
                document.getElementById('hiddenLogoPath').value = '';
                var alertEl = document.getElementById('noLogoAlert');
                if (alertEl) {
                    alertEl.style.display = 'block';
                } else {
                    var fileInput = document.getElementById('LogoFile');
                    if (fileInput && fileInput.parentElement) {
                        alertEl = document.createElement('div');
                        alertEl.id = 'noLogoAlert';
                        alertEl.className = 'alert alert-danger py-2 mb-2';
                        alertEl.innerHTML = '<small><i class="fas fa-exclamation-circle"></i> Logo yüklenmemiş!</small>';
                        fileInput.parentElement.insertBefore(alertEl, fileInput);
                    }
                }
            }
        });
    }
    function removeFavicon() {
        Swal.fire({
            title: 'Emin misiniz?',
            text: 'Favicon silmek istediğinize emin misiniz? Bu alan zorunludur!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'İptal'
        }).then(function (result) {
            if (result.isConfirmed) {
                var box = document.getElementById('existingFaviconBox');
                if (box) box.style.display = 'none';
                document.getElementById('hiddenFaviconPath').value = '';
                var alertEl = document.getElementById('noFaviconAlert');
                if (alertEl) {
                    alertEl.style.display = 'block';
                } else {
                    var fileInput = document.getElementById('FaviconFile');
                    if (fileInput && fileInput.parentElement) {
                        alertEl = document.createElement('div');
                        alertEl.id = 'noFaviconAlert';
                        alertEl.className = 'alert alert-danger py-2 mb-2';
                        alertEl.innerHTML = '<small><i class="fas fa-exclamation-circle"></i> Favicon yüklenmemiş!</small>';
                        fileInput.parentElement.insertBefore(alertEl, fileInput);
                    }
                }
            }
        });
    }
    function removeNewLogo() {
        document.getElementById('LogoFile').value = '';
        document.getElementById('newLogoPreview').style.display = 'none';
        var box = document.getElementById('existingLogoBox');
        var orig = document.getElementById('originalLogoPath');
        if (box && orig && orig.value) {
            box.style.display = 'block';
            document.getElementById('hiddenLogoPath').value = orig.value;
            var alertEl = document.getElementById('noLogoAlert');
            if (alertEl) alertEl.style.display = 'none';
        } else {
            var alertEl = document.getElementById('noLogoAlert');
            if (alertEl) alertEl.style.display = 'block';
        }
    }
    function removeNewFavicon() {
        document.getElementById('FaviconFile').value = '';
        document.getElementById('newFaviconPreview').style.display = 'none';
        var box = document.getElementById('existingFaviconBox');
        var orig = document.getElementById('originalFaviconPath');
        if (box && orig && orig.value) {
            box.style.display = 'block';
            document.getElementById('hiddenFaviconPath').value = orig.value;
            var alertEl = document.getElementById('noFaviconAlert');
            if (alertEl) alertEl.style.display = 'none';
        } else {
            var alertEl = document.getElementById('noFaviconAlert');
            if (alertEl) alertEl.style.display = 'block';
        }
    }
    // ==================== FORM SUBMIT ====================
    document.getElementById('companyForm').addEventListener('submit', function (e) {
        var logoPath = document.getElementById('hiddenLogoPath').value.trim();
        var faviconPath = document.getElementById('hiddenFaviconPath').value.trim();
        var logoFile = document.getElementById('LogoFile').files[0];
        var faviconFile = document.getElementById('FaviconFile').files[0];
           var phone2Input = document.getElementById('Phone2');
    if (phone2Input) {
        var phone2Value = phone2Input.value.trim();
        if (phone2Value.length < 10) {
            phone2Input.value = '';
        }
    }
        if (!logoPath && !logoFile) {
            e.preventDefault();
            Swal.fire({ icon: 'error', title: 'Logo Zorunlu!', text: 'Lütfen bir logo yükleyin.' });
            var noLogoAlert = document.getElementById('noLogoAlert');
            if (noLogoAlert) noLogoAlert.style.display = 'block';
            return false;
        }
        if (!faviconPath && !faviconFile) {
            e.preventDefault();
            Swal.fire({ icon: 'error', title: 'Favicon Zorunlu!', text: 'Lütfen bir favicon yükleyin.' });
            var noFaviconAlert = document.getElementById('noFaviconAlert');
            if (noFaviconAlert) noFaviconAlert.style.display = 'block';
            return false;
        }

            sessionStorage.setItem('updated', '1');  // ← SADECE BU EKLENDI
        document.getElementById('loadingOverlay').classList.add('show');
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('submitBtn').innerHTML = '<i class="fas fa-spinner fa-spin"></i> Kaydediliyor...';
    });
    // ==================== HARİTA ÖNİZLEME ====================
    function previewMap() {
        var code = document.getElementById('GoogleMapsEmbed').value;
        var preview = document.getElementById('mapPreview');

        if (code && code.indexOf('<iframe') !== -1 && code.indexOf('google.com/maps') !== -1) {
            preview.innerHTML = code;
            preview.style.display = 'block';
        } else {
            Swal.fire({ icon: 'warning', title: 'Geçersiz Kod', text: 'Lütfen geçerli bir Google Maps iframe kodu girin.' });
        }
    }
</script>