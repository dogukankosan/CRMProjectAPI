                                                </select>
                                                <input asp-for="Phone" id="Phone1" class="form-control" maxlength="25" required />
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Telefon 2 -->
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>İkinci Telefon</label>
                                            <div class="phone-input-group">
                                                <select class="form-control" id="countryCodeSelect2">
                                                    <option value="+90" selected>🇹🇷 Türkiye (+90)</option>
                                                    <option value="+93">🇦🇫 Afganistan (+93)</option>
                                                    <option value="+355">🇦🇱 Arnavutluk (+355)</option>
                                                    <option value="+213">🇩🇿 Cezayir (+213)</option>
                                                    <option value="+376">🇦🇩 Andorra (+376)</option>
                                                    <option value="+244">🇦🇴 Angola (+244)</option>
