@model CRMProjectUI.Models.CompanyDto
@{
    ViewData["Title"] = "Şirket Bilgileri Güncelleme";
    Layout = "~/Views/Shared/_adminLayout.cshtml";
}
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    string apiBase = Config["ApiSettings:BaseUrl"] ?? "";
}
<style>
    .img-hover-zoom {
        transition: transform 0.3s ease;
        cursor: pointer;
    }

        .img-hover-zoom:hover {
            transform: scale(2.5);
            z-index: 1000;
            position: relative;
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }

    .loading-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }

        .loading-overlay.show {
            display: flex;
        }

    .char-counter {
        font-size: 0.8rem;
    }

        .char-counter.warning {
            color: #ffc107;
        }

        .char-counter.danger {
            color: #dc3545;
        }

    .required-star {
        color: #dc3545;
        font-weight: bold;
    }

    .phone-input-group {
        display: flex;
        gap: 10px;
    }

        .phone-input-group select {
            width: 180px;
            flex-shrink: 0;
        }

        .phone-input-group input {
            flex: 1;
        }
</style>
<!-- Loading Overlay -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="text-center text-white">
        <div class="spinner-border" style="width: 3rem; height: 3rem;" role="status">
            <span class="sr-only">Yükleniyor...</span>
        </div>
        <p class="mt-2">Kaydediliyor...</p>
    </div>
</div>
<div class="section-body">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3><u>Şirket Bilgileri Güncelle</u></h3>
                    <a asp-action="Liste" asp-controller="AdminSirket" class="btn btn-sm btn-secondary">
                        <i class="fas fa-arrow-left"></i> Listeye Dön
                    </a>
                </div>
                <div class="card-body">
                    <form asp-action="Guncelle" asp-controller="AdminSirket" method="post" enctype="multipart/form-data" id="companyForm">
                       @Html.AntiForgeryToken()
                        <!-- Hidden Fields -->
                        <input type="hidden" name="LogoPath" id="hiddenLogoPath" value="@Model?.LogoPath" />
                        <input type="hidden" name="FaviconPath" id="hiddenFaviconPath" value="@Model?.FaviconPath" />
                        <!-- Validation Summary -->
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                <strong><i class="fas fa-exclamation-triangle"></i> Lütfen hataları düzeltin:</strong>
                                <ul class="mb-0 mt-2">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }
@if (TempData["Warning"] != null)
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i>
                                @Html.Raw(TempData["Warning"])
                            </div>
                        }
                        @if (ViewBag.MsgType != null)
                        {
                            <div class="alert alert-@(ViewBag.MsgType == "error" ? "danger" : ViewBag.MsgType)">
                                <i class="fas fa-exclamation-triangle"></i>
                                @Html.Raw(ViewBag.MsgText)
                            </div>
                        }
                        <!-- GENEL BİLGİLER -->
                        <div class="card mb-3">
                            <div class="card-header bg-primary text-white">
                                <h6 class="mb-0"><i class="fas fa-building"></i> Genel Bilgiler</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Şirket Tam Adı <span class="required-star">*</span></label>
                                            <input asp-for="CompanyName" class="form-control" maxlength="100" required />
                                            <small class="text-muted float-right char-counter"><span id="cntCompanyName">0</span>/100</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Kısa Adı <span class="required-star">*</span></label>
                                            <input asp-for="ShortCompanyName" class="form-control" maxlength="50" required />
                                            <small class="text-muted float-right char-counter"><span id="cntShortName">0</span>/50</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="form-group">
                                            <label>Slogan</label>
                                            <input asp-for="Slogan" class="form-control" maxlength="200" />
                                            <small class="text-muted float-right char-counter"><span id="cntSlogan">0</span>/200</small>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label>Kuruluş Yılı</label>
                                            <select asp-for="FoundedYear" class="form-control">
                                                <option value="">Seçiniz...</option>
                                                @for (int y = DateTime.Now.Year; y >= 1900; y--)
                                                {
                                                    <option value="@y">@y</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Sektör Açıklaması</label>
                                    <textarea asp-for="SectorDescription" class="form-control" rows="2" maxlength="500"></textarea>
                                    <small class="text-muted float-right char-counter"><span id="cntSector">0</span>/500</small>
                                </div>
                                <div class="form-group">
                                    <label>Çalışma Saatleri</label>
                                    <input asp-for="WorkingHours" class="form-control" maxlength="200" placeholder="Örn: Pazartesi-Cuma 09:00-18:00" />
                                </div>
                            </div>
                        </div>
                        <!-- İLETİŞİM -->
