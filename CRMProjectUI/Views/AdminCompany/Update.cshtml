                                                </select>
                                                <input asp-for="Phone2" id="Phone2" class="form-control" maxlength="20" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Adres <span class="required-star">*</span></label>
                                    <textarea asp-for="Address" class="form-control" rows="2" maxlength="300" required></textarea>
                                    <small class="text-muted float-right char-counter"><span id="cntAddress">0</span>/300</small>
                                </div>
                                <div class="form-group">
                                    <label>Google Maps Embed</label>
                                    <textarea asp-for="GoogleMapsEmbed" id="GoogleMapsEmbed" class="form-control" rows="2" maxlength="1000" 
                                              placeholder='<iframe src="https://www.google.com/maps/embed?..." ...></iframe>'></textarea>
                                    <small class="text-muted">Google Maps'ten iframe kodunu yapıştırın.</small>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-info" onclick="previewMap()">
                                    <i class="fas fa-eye"></i> Haritayı Önizle
                                </button>
                                <div id="mapPreview" class="mt-2 border rounded p-2" style="display:none;"></div>
                            </div>
                        </div>
                        <!-- SEO -->
                        <div class="card mb-3">
                            <div class="card-header bg-success text-white">
                                <h6 class="mb-0"><i class="fas fa-search"></i> SEO Ayarları</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Web Sitesi Başlığı <span class="required-star">*</span></label>
                                            <input asp-for="WebSiteTitle" class="form-control" maxlength="100" required />
                                            <small class="text-muted float-right char-counter"><span id="cntWebTitle">0</span>/100</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Meta Başlık <span class="badge badge-info">SEO</span></label>
                                            <input asp-for="MetaTitle" class="form-control" maxlength="70" />
                                            <small class="text-muted float-right char-counter"><span id="cntMetaTitle">0</span>/70</small>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>Meta Açıklama <span class="badge badge-info">SEO</span></label>
                                    <textarea asp-for="MetaDescription" class="form-control" rows="2" maxlength="160"></textarea>
                                    <small class="text-muted float-right char-counter"><span id="cntMetaDesc">0</span>/160</small>
                                </div>
                                <div class="form-group">
                                    <label>Meta Anahtar Kelimeler</label>
                                    <input asp-for="MetaKeywords" class="form-control" maxlength="300" placeholder="kelime1, kelime2, kelime3" />
                                </div>
                                <div class="form-group">
                                    <label>Canonical URL</label>
                                    <input asp-for="CanonicalUrl" class="form-control" type="url" maxlength="200" />
                                </div>
                            </div>
                        </div>
                        <!-- SOSYAL MEDYA -->
                        <div class="card mb-3">
                            <div class="card-header bg-warning">
                                <h6 class="mb-0"><i class="fas fa-share-alt"></i> Sosyal Medya</h6>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="fab fa-instagram text-danger"></i> Instagram</label>
                                            <input asp-for="InstagramLink" class="form-control" type="url" maxlength="200" placeholder="https://instagram.com/..." />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>
                                                <i class="fab fa-linkedin"></i>  LinkedIn
                                            </label>
                                            <input asp-for="LinkedinLink" class="form-control" type="url" maxlength="200" placeholder="https://linkedin.com/..." />
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="fab fa-youtube text-danger"></i> YouTube</label>
                                            <input asp-for="YoutubeLink" class="form-control" type="url" maxlength="200" placeholder="https://youtube.com/..." />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="fas fa-external-link-alt"></i> Harici Link</label>
                                            <input asp-for="ExternalWebLink" class="form-control" type="url" maxlength="200" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- HAKKIMIZDA -->
                        <div class="card mb-3">
                            <div class="card-header bg-secondary text-white">
                                <h6 class="mb-0"><i class="fas fa-file-alt"></i> Hakkımızda</h6>
                            </div>
                            <div class="card-body">
                                <div class="form-group">
                                    <label>Kısa Hakkımızda</label>
                                    <textarea asp-for="AboutUsShort" class="form-control" rows="2" maxlength="500"></textarea>
                                    <small class="text-muted float-right char-counter"><span id="cntAboutShort">0</span>/500</small>
                                </div>
                                <div class="form-group">
                                    <label>Hakkımızda (Detaylı)</label>
                                    <textarea asp-for="AboutUs" class="form-control" rows="5"></textarea>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label><i class="fas fa-eye text-primary"></i> Vizyon</label>
                                            <textarea asp-for="Vision" class="form-control" rows="3" maxlength="1000"></textarea>
                                            <small class="text-muted float-right char-counter"><span id="cntVision">0</span>/1000</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
