                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>E-posta <span class="required-star">*</span></label>
                                            <input asp-for="Email" class="form-control" type="email" maxlength="100" required />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>Web Sitesi <span class="required-star">*</span></label>
                                            <input asp-for="WebSiteLink" class="form-control" type="url" maxlength="150" required placeholder="https://" />
                                        </div>
                                    </div>
                                </div>
