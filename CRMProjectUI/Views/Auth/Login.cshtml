@model CRMProjectUI.Controllers.LoginViewModel
@inject CRMProjectUI.APIService.CompanyApiService CompanyService
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
    var company = await CompanyService.GetCompanyAsync();
    string apiBase = Config["ApiSettings:BaseUrl"] ?? "";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@(company?.WebSiteTitle ?? "CRM") - Giriş</title>
    <link rel="shortcut icon" type="image/x-icon" href="@(string.IsNullOrEmpty(company?.FaviconPath) ? "/adminThema/assets/img/favicon.ico" : $"{apiBase}{company.FaviconPath}")" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --or1: #ff6b00;
            --or2: #ff9500;
            --or3: #ffb347;
            --dark: #0d0d14;
            --dark2: #13131f;
            --dark3: #1a1a2a;
            --white: #ffffff;
            --muted: rgba(255,255,255,.7);
            --muted-light: rgba(255,255,255,.5);
            --border: rgba(255,255,255,.1);
            --inp: rgba(255,255,255,.05);
            --danger: #ff4757;
        }

        html, body {
            height: 100%;
        }

        body {
            min-height: 100vh;
            min-height: -webkit-fill-available;
            background: linear-gradient(rgba(13,13,20,.9), rgba(13,13,20,.98)), url('/images/login-bg.png') center/cover no-repeat fixed;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', system-ui, sans-serif;
            padding: 16px;
            position: relative;
            overflow-x: hidden;
            overflow-y: auto;
            -webkit-text-size-adjust: 100%;
        }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background: radial-gradient(ellipse 60% 50% at 50% -10%, rgba(255,107,0,.15) 0%, transparent 70%);
                pointer-events: none;
                z-index: 0;
            }

        .card {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 440px;
            background: var(--dark2);
            border: 1px solid var(--border);
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(0,0,0,.7), 0 0 0 1px rgba(255,107,0,.05);
            margin: auto;
        }

        .card-topbar {
            height: 4px;
            background: linear-gradient(90deg, var(--or1), var(--or2), var(--or3));
            flex-shrink: 0;
        }

        .logo-section {
            padding: 36px 40px 28px;
            text-align: center;
            background: radial-gradient(circle at center, rgba(255,107,0,0.05) 0%, transparent 70%);
            border-bottom: 1px solid var(--border);
        }

        .logo-wrap {
            width: 120px;
            height: 120px;
            margin: 0 auto 16px;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #ffffff;
            border-radius: 50%;
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 15px 40px rgba(0,0,0,.4), inset 0 0 10px rgba(0,0,0,.03);
            transition: transform .4s ease;
        }

            .logo-wrap:hover {
                transform: scale(1.05);
            }

            .logo-wrap img {
                max-width: 80px;
                max-height: 80px;
                width: auto;
                height: auto;
                object-fit: contain;
                filter: drop-shadow(0 4px 10px rgba(0,0,0,.15));
            }

        .company-name {
            font-family: 'Syne', sans-serif;
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--white);
            margin-top: 10px;
            letter-spacing: -0.2px;
            text-transform: uppercase;
            text-shadow: 0 4px 12px rgba(0,0,0,.4);
        }

        .company-slogan {
            font-size: .83rem;
            color: var(--or2);
            font-weight: 500;
            margin-top: 4px;
            opacity: .9;
        }

        .form-section {
            padding: 30px 40px 36px;
        }

        .form-title {
            font-family: 'Syne', sans-serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--white);
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            font-size: .72rem;
            font-weight: 700;
            color: var(--white);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: .05em;
            opacity: .8;
        }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,.3);
            font-size: .95rem;
            pointer-events: none;
        }

        .form-input {
            width: 100%;
            padding: 14px 16px 14px 46px;
            background: var(--inp);
            border: 1px solid var(--border);
            border-radius: 14px;
            font-size: 1rem; /* 16px — iOS'ta zoom'u önler */
            color: var(--white);
            outline: none;
            transition: all .25s ease;
            -webkit-appearance: none;
            appearance: none;
        }

            .form-input::placeholder {
                color: rgba(255,255,255,.25);
            }

            .form-input:focus {
                border-color: var(--or2);
                background: rgba(255,149,0,.08);
                box-shadow: 0 0 0 4px rgba(255,107,0,.1);
            }

        .pass-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(255,255,255,.3);
            cursor: pointer;
            background: none;
            border: none;
            padding: 6px;
            line-height: 1;
            transition: color .2s;
        }

            .pass-toggle:hover {
                color: rgba(255,255,255,.6);
            }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 22px 0;
        }

            .remember-row input[type="checkbox"] {
                width: 18px;
                height: 18px;
                accent-color: var(--or1);
                cursor: pointer;
                flex-shrink: 0;
            }

            .remember-row label {
                font-size: .88rem;
                color: var(--muted);
                cursor: pointer;
                user-select: none;
            }

        .login-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--or1) 0%, var(--or2) 100%);
            color: #fff;
            border: none;
            border-radius: 14px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            box-shadow: 0 10px 25px rgba(255,107,0,.3);
            transition: all .3s ease;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
        }

            .login-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 15px 35px rgba(255,107,0,.45);
                filter: brightness(1.1);
            }

            .login-btn:active {
                transform: translateY(0);
            }

            .login-btn:disabled {
                opacity: .7;
                cursor: not-allowed;
                transform: none;
            }

        .error-box {
            background: rgba(255,71,87,.15);
            border: 1px solid rgba(255,71,87,.4);
            border-radius: 12px;
            padding: 13px 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: #ff4757;
            font-size: .88rem;
        }

        .card-footer {
            padding: 20px 32px 24px;
            border-top: 1px solid var(--border);
            background: rgba(0,0,0,.1);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
        }

        .footer-link {
            font-size: .78rem;
            color: var(--muted);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: color .2s;
            white-space: nowrap;
        }

            .footer-link:hover {
                color: var(--white);
            }

        .footer-sep {
            color: rgba(255,255,255,.2);
            font-size: .7rem;
        }

        .footer-copy {
            width: 100%;
            text-align: center;
            font-size: .72rem;
            color: rgba(255,255,255,.35);
            margin-top: 8px;
        }

        .spinner {
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .7s linear infinite;
            display: none;
            flex-shrink: 0;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        ::selection {
            background-color: var(--or1);
            color: #fff;
        }

        ::-moz-selection {
            background-color: var(--or1);
            color: #fff;
        }

        /* ── MOBİL ── */
        @@media (max-width: 480px) {
            body {
                padding: 12px;
                align-items: flex-start;
                padding-top: 20px;
                padding-bottom: 20px;
            }

            .card {
                border-radius: 22px;
                max-width: 100%;
            }

            .logo-section {
                padding: 28px 24px 22px;
            }

            .logo-wrap {
                width: 100px;
                height: 100px;
            }

                .logo-wrap img {
                    max-width: 66px;
                    max-height: 66px;
                }

            .company-name {
                font-size: 1.15rem;
            }

            .form-section {
                padding: 24px 24px 28px;
            }

            .form-title {
                font-size: 1.1rem;
                margin-bottom: 16px;
            }

            .form-input {
                padding: 13px 14px 13px 44px;
                border-radius: 12px;
            }

            .login-btn {
                padding: 15px;
                border-radius: 12px;
            }

            .card-footer {
                padding: 16px 20px 20px;
                gap: 10px;
            }

            .footer-link {
                font-size: .75rem;
            }
        }

        @@media (max-width: 360px) {
            .logo-wrap {
                width: 88px;
                height: 88px;
            }

                .logo-wrap img {
                    max-width: 58px;
                    max-height: 58px;
                }

            .company-name {
                font-size: 1rem;
            }

            .form-section {
                padding: 20px 18px 24px;
            }
        }

        /* Landscape modda çok küçük ekranlar */
        @@media (max-height: 600px) and (orientation: landscape) {
            .logo-wrap {
                width: 72px;
                height: 72px;
            }

                .logo-wrap img {
                    max-width: 48px;
                    max-height: 48px;
                }

            .logo-section {
                padding: 18px 24px 14px;
            }

            .company-name {
                font-size: 1rem;
                margin-top: 8px;
            }

            .form-section {
                padding: 18px 32px 22px;
            }

            .remember-row {
                margin: 14px 0;
            }
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-topbar"></div>

        <div class="logo-section">
            @if (!string.IsNullOrEmpty(company?.LogoPath))
            {
                <div class="logo-wrap">
                    <img src="@($"{apiBase}{company.LogoPath}")" alt="@company.WebSiteTitle" />
                </div>
            }
            else
            {
                <div style="width:80px;height:80px;background:linear-gradient(135deg,var(--or1),var(--or2));border-radius:20px;margin:0 auto 14px;display:flex;align-items:center;justify-content:center;box-shadow:0 10px 25px rgba(255,107,0,.3);">
                    <i class="fas fa-layer-group" style="color:#fff;font-size:2rem;"></i>
                </div>
            }
            <div class="company-name">@(company?.ShortCompanyName ?? "CRM") CRM</div>
            @if (!string.IsNullOrEmpty(company?.Slogan))
            {
                <div class="company-slogan">@company.Slogan</div>
            }
        </div>

        <div class="form-section">
            <div class="form-title">Giriş Yap</div>

            <form asp-action="Login" asp-controller="Auth" method="post" id="loginForm" autocomplete="on">
                @Html.AntiForgeryToken()
                @if (!string.IsNullOrEmpty(ViewBag.ReturnUrl as string))
                {
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                }

                @{
                    var errorMsg = ViewData.ModelState[""]?.Errors.FirstOrDefault()?.ErrorMessage;
                }
                @if (!string.IsNullOrEmpty(errorMsg))
                {
                    <div class="error-box">
                        <i class="fas fa-circle-exclamation" style="flex-shrink:0;"></i>
                        <span>@errorMsg</span>
                    </div>
                }

                <div class="form-group">
                    <label class="form-label" for="Username">Kullanıcı Adı</label>
                    <div class="input-wrap">
                        <i class="fas fa-user input-icon"></i>
                        <input type="text" id="Username" name="Username" class="form-input"
                               value="@Model?.Username"
                               placeholder="Kullanıcı adınız"
                               autocomplete="username"
                               required autofocus />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="Password">Şifre</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" id="Password" name="Password" class="form-input"
                               placeholder="••••••••"
                               autocomplete="current-password"
                               required />
                        <button type="button" class="pass-toggle" onclick="togglePassword()" tabindex="-1" aria-label="Şifreyi göster/gizle">
                            <i class="fas fa-eye" id="passIcon"></i>
                        </button>
                    </div>
                </div>

                <div class="remember-row">
                    <input type="hidden" name="RememberMe" value="false" />
                    <input type="checkbox" id="RememberMe" name="RememberMe" value="true" />
                    <label for="RememberMe">Beni hatırla (7 gün)</label>
                </div>

                <button type="submit" class="login-btn" id="loginBtn">
                    <span id="btnText">Ateşle 🔥</span>
                    <div class="spinner" id="btnSpinner"></div>
                </button>
            </form>
        </div>

        <div class="card-footer">
            @{
                var footerItems = new List<(string? value, string href, string icon, string label)>();
                if (!string.IsNullOrEmpty(company?.Phone))
                    footerItems.Add((company.Phone, $"tel:{company.Phone}", "fa-phone", company.Phone));
                if (!string.IsNullOrEmpty(company?.Phone2))
                    footerItems.Add((company.Phone2, $"tel:{company.Phone2}", "fa-phone", company.Phone2));
                if (!string.IsNullOrEmpty(company?.WebSiteLink))
                    footerItems.Add((company.WebSiteLink, company.WebSiteLink, "fa-globe", "Web Sitesi"));
                if (!string.IsNullOrEmpty(company?.Email))
                    footerItems.Add((company.Email, $"mailto:{company.Email}", "fa-envelope", company.Email));
            }
            @for (int i = 0; i < footerItems.Count; i++)
            {
                var item = footerItems[i];
                var isExternal = item.href.StartsWith("http");
                <a href="@item.href" class="footer-link" @(isExternal ? "target=\"_blank\" rel=\"noopener\"" : "")>
                    <i class="fas @item.icon"></i> @item.label
                </a>
                @if (i < footerItems.Count - 1)
                {
                    <span class="footer-sep">·</span>
                }
            }
            <div class="footer-copy">
                &copy; @DateTime.Now.Year @(company?.CompanyName ?? "CRM") &mdash; Tüm hakları saklıdır
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            var input = document.getElementById('Password');
            var icon  = document.getElementById('passIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }

        document.getElementById('loginForm').addEventListener('submit', function () {
            var btn = document.getElementById('loginBtn');
            btn.disabled = true;
            document.getElementById('btnText').style.display    = 'none';
            document.getElementById('btnSpinner').style.display = 'block';
        });
    </script>
</body>
</html>