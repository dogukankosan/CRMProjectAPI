@model CRMProjectUI.Models.AdminPersonalDashboardDto
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_adminLayout.cshtml";

    var stats = Model?.Stats;
    var myOpenTickets = Model?.MyOpenTickets ?? new List<CRMProjectUI.Models.TicketListDto>();
    var recentResolved = Model?.RecentResolved ?? new List<CRMProjectUI.Models.TicketListDto>();

    string fullName = User.FindFirst("FullName")?.Value ?? "Admin";
    string tarih = DateTime.Now.ToString("dddd, dd MMMM yyyy",
                          new System.Globalization.CultureInfo("tr-TR"));
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --ink: #0f1117;
        --ink-soft: #4a4f5e;
        --surface: #f7f8fc;
        --white: #fff;
        --accent: #2563eb;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --purple: #7c3aed;
        --border: #e2e8f0;
        --radius: 12px;
        --shadow-sm: 0 2px 8px rgba(15,17,23,.06);
        --shadow-md: 0 8px 32px rgba(15,17,23,.10);
    }

    .db-page {
        font-family: 'DM Sans', sans-serif;
    }

    .db-banner {
        background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
        border-radius: 16px;
        padding: 22px 28px;
        color: #fff;
        margin-bottom: 20px;
        box-shadow: 0 8px 32px rgba(14,165,233,.2);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
    }

        .db-banner h5 {
            font-family: 'Syne',sans-serif;
            font-weight: 800;
            margin: 0;
            font-size: 1.15rem;
        }

        .db-banner p {
            opacity: .8;
            margin: 0;
            font-size: .83rem;
            margin-top: 3px;
        }

    .db-banner-stats {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    .db-banner-stat {
        text-align: center;
    }

    .db-banner-stat-val {
        font-family: 'Syne',sans-serif;
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1;
    }

    .db-banner-stat-lbl {
        font-size: .7rem;
        opacity: .75;
        margin-top: 2px;
    }

    .db-stats {
        display: flex;
        gap: 12px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .db-stat {
        flex: 1;
        min-width: 120px;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 14px 16px;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 12px;
        transition: box-shadow .2s, transform .2s;
    }

        .db-stat:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

    .db-stat-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .88rem;
        flex-shrink: 0;
    }

        .db-stat-icon.blue {
            background: #eff6ff;
            color: var(--accent);
        }

        .db-stat-icon.indigo {
            background: #eef2ff;
            color: #4f46e5;
        }

        .db-stat-icon.green {
            background: #f0fdf4;
            color: var(--success);
        }

        .db-stat-icon.red {
            background: #fef2f2;
            color: var(--danger);
        }

        .db-stat-icon.amber {
            background: #fffbeb;
            color: var(--warning);
        }

    .db-stat-label {
        font-size: .67rem;
        color: var(--ink-soft);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 2px;
    }

    .db-stat-value {
        font-family: 'Syne',sans-serif;
        font-size: 1.35rem;
        font-weight: 800;
        color: var(--ink);
        line-height: 1;
    }

    .db-perf-row {
        display: flex;
        gap: 12px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .db-perf-card {
        flex: 1;
        min-width: 140px;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 18px;
        box-shadow: var(--shadow-sm);
        text-align: center;
    }

    .db-perf-val {
        font-family: 'Syne',sans-serif;
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 4px;
    }

    .db-perf-lbl {
        font-size: .72rem;
        color: var(--ink-soft);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .db-perf-sub {
        font-size: .7rem;
        color: var(--ink-soft);
        margin-top: 2px;
    }

    .db-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        margin-bottom: 18px;
        overflow: hidden;
    }

    .db-card-header {
        padding: 13px 18px;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .db-card-header h6 {
            margin: 0;
            font-weight: 700;
            font-size: .88rem;
            color: var(--ink);
            display: flex;
            align-items: center;
            gap: 7px;
        }

    .db-table {
        width: 100%;
        border-collapse: collapse;
    }

        .db-table thead th {
            font-size: .67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: var(--ink-soft);
            padding: 9px 12px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .db-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .15s;
            cursor: pointer;
        }

            .db-table tbody tr:last-child {
                border-bottom: none;
            }

            .db-table tbody tr:hover {
                background: #f8fafd;
            }

        .db-table tbody td {
            padding: 9px 12px;
            vertical-align: middle;
            font-size: .82rem;
        }

    .b-status {
        font-size: .68rem;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        white-space: nowrap;
    }

        .b-status::before {
            content: '';
            width: 5px;
            height: 5px;
            border-radius: 50%;
            flex-shrink: 0;
        }

    .bs-0 {
        background: #f1f5f9;
        color: #475569;
    }

        .bs-0::before {
            background: #94a3b8;
        }

    .bs-1 {
        background: #eef2ff;
        color: #3730a3;
    }

        .bs-1::before {
            background: #4f46e5;
        }

    .bs-2 {
        background: #f0fdf4;
        color: #166534;
    }

        .bs-2::before {
            background: var(--success);
        }

    .bs-3 {
        background: #fef2f2;
        color: #991b1b;
    }

        .bs-3::before {
            background: var(--danger);
        }

    .bs-4 {
        background: #fffbeb;
        color: #92400e;
    }

        .bs-4::before {
            background: var(--warning);
        }

    .bs-5 {
        background: #f5f3ff;
        color: #5b21b6;
    }

        .bs-5::before {
            background: var(--purple);
        }

    .b-priority {
        font-size: .67rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 6px;
        white-space: nowrap;
    }

    .bp-1 {
        background: #f0fdf4;
        color: #166534;
    }

    .bp-2 {
        background: #eff6ff;
        color: #1e40af;
    }

    .bp-3 {
        background: #fffbeb;
        color: #92400e;
    }

    .bp-4 {
        background: #fef2f2;
        color: #991b1b;
    }

    .db-empty {
        text-align: center;
        padding: 28px;
        color: var(--ink-soft);
    }

        .db-empty i {
            font-size: 2rem;
            opacity: .2;
            display: block;
            margin-bottom: 8px;
        }
</style>

<div class="db-page">

    <!-- BANNER -->
    <div class="db-banner">
        <div>
            <h5><i class="fas fa-user-tie mr-2"></i>Merhaba, @fullName!</h5>
            <p>@tarih — Kişisel performans özeti</p>
        </div>
        <div class="db-banner-stats">
            <div class="db-banner-stat">
                <div class="db-banner-stat-val">@(stats?.Total ?? 0)</div>
                <div class="db-banner-stat-lbl">Toplam Kayıt</div>
            </div>
            <div class="db-banner-stat">
                <div class="db-banner-stat-val">@(stats?.Resolved ?? 0)</div>
                <div class="db-banner-stat-lbl">Çözülen</div>
            </div>
            <div class="db-banner-stat">
                <div class="db-banner-stat-val">@(stats?.AvgWorkingDisplay ?? "-")</div>
                <div class="db-banner-stat-lbl">Ort. Çözüm Süresi</div>
            </div>
        </div>
    </div>

    @if (Model == null)
    {
        <div class="alert alert-warning" style="border-radius:var(--radius);">
            <i class="fas fa-exclamation-triangle mr-2"></i>
            Dashboard verileri yüklenemedi. Lütfen sayfayı yenileyin.
        </div>
    }
    else
    {
        <!-- STAT CARDS -->
        <div class="db-stats">
            <div class="db-stat">
                <div class="db-stat-icon blue"><i class="fas fa-ticket-alt"></i></div>
                <div><div class="db-stat-label">Toplam</div><div class="db-stat-value">@(stats?.Total ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon indigo"><i class="fas fa-folder-open"></i></div>
                <div><div class="db-stat-label">Açık</div><div class="db-stat-value" style="color:#4f46e5;">@(stats?.OpenCount ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon green"><i class="fas fa-check-circle"></i></div>
                <div><div class="db-stat-label">Çözülen</div><div class="db-stat-value" style="color:var(--success);">@(stats?.Resolved ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon red"><i class="fas fa-times-circle"></i></div>
                <div><div class="db-stat-label">Çözülemedi</div><div class="db-stat-value" style="color:var(--danger);">@(stats?.Failed ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon amber"><i class="fas fa-stopwatch"></i></div>
                <div><div class="db-stat-label">Ort. Süre</div><div class="db-stat-value" style="color:var(--warning); font-size:1rem;">@(stats?.AvgWorkingDisplay ?? "-")</div></div>
            </div>
        </div>

        <!-- PERFORMANS KARTLARI -->
        <div class="db-perf-row">
            <div class="db-perf-card">
                <div class="db-perf-val" style="color:var(--success);">@(stats?.TodayResolved ?? 0)</div>
                <div class="db-perf-lbl">Bugün Çözülen</div>
                <div class="db-perf-sub">@DateTime.Now.ToString("dd MMMM", new System.Globalization.CultureInfo("tr-TR"))</div>
            </div>
            <div class="db-perf-card">
                <div class="db-perf-val" style="color:#4f46e5;">@(stats?.ThisWeekResolved ?? 0)</div>
                <div class="db-perf-lbl">Bu Hafta Çözülen</div>
                <div class="db-perf-sub">Son 7 gün</div>
            </div>
            <div class="db-perf-card">
                <div class="db-perf-val" style="color:var(--accent);">@(stats?.ThisMonthResolved ?? 0)</div>
                <div class="db-perf-lbl">Bu Ay Çözülen</div>
                <div class="db-perf-sub">@DateTime.Now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</div>
            </div>
            <div class="db-perf-card">
                <div class="db-perf-val" style="color:var(--danger);">@(stats?.Failed ?? 0)</div>
                <div class="db-perf-lbl">Çözülemedi</div>
                <div class="db-perf-sub">Toplam</div>
            </div>
            <div class="db-perf-card">
                <div class="db-perf-val" style="color:var(--warning); font-size:1.4rem;">@(stats?.AvgWorkingDisplay ?? "-")</div>
                <div class="db-perf-lbl">Ortalama Süre</div>
                <div class="db-perf-sub">Tüm zamanlar</div>
            </div>
        </div>

        <!-- TABLOLAR -->
        <div class="row">
            <div class="col-md-7 mb-3">
                <div class="db-card">
                    <div class="db-card-header">
                        <h6><i class="fas fa-tasks" style="color:var(--accent);"></i> Üzerimdeki Açık Ticketlar</h6>
                        <a asp-action="Liste" asp-controller="AdminTicket"
                           style="font-size:.76rem; color:var(--accent); text-decoration:none; font-weight:600;">
                            Tümünü Gör <i class="fas fa-arrow-right ml-1"></i>
                        </a>
                    </div>
                    @if (!myOpenTickets.Any())
                    {
                        <div class="db-empty">
                            <i class="fas fa-check-circle" style="color:var(--success); opacity:1;"></i>
                            Üzerinizde açık ticket yok 🎉
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="db-table">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Başlık</th>
                                        <th>Müşteri</th>
                                        <th>Öncelik</th>
                                        <th>Durum</th>
                                        <th>Geçen Süre</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in myOpenTickets)
                                    {
                                        string pClass = $"bp-{t.Priority}";
                                        string sClass = $"bs-{t.Status}";
                                        <tr onclick="window.location='/AdminTicket/Detay/@t.ID'">
                                            <td style="font-family:monospace; font-size:.76rem; color:var(--ink-soft);">@t.TicketNo</td>
                                            <td>
                                                <span style="font-weight:600; font-size:.82rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; display:block; max-width:160px;" title="@t.Title">
                                                    @(t.Title.Length > 28 ? t.Title.Substring(0, 28) + "…" : t.Title)
                                                </span>
                                            </td>
                                            <td style="font-size:.78rem;">@t.CustomerName</td>
                                            <td><span class="b-priority @pClass">@t.PriorityText</span></td>
                                            <td><span class="b-status @sClass">@t.StatusText</span></td>
                                            <td style="font-size:.75rem; color:var(--ink-soft);">@t.ElapsedText</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-5 mb-3">
                <div class="db-card">
                    <div class="db-card-header">
                        <h6><i class="fas fa-history" style="color:var(--success);"></i> Son Çözülen Ticketlar</h6>
                    </div>
                    @if (!recentResolved.Any())
                    {
                        <div class="db-empty">
                            <i class="fas fa-inbox"></i>
                            Henüz çözülen ticket yok
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="db-table">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Başlık</th>
                                        <th>Durum</th>
                                        <th>Süre</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in recentResolved)
                                    {
                                        string sClass = $"bs-{t.Status}";
                                        <tr onclick="window.location='/AdminTicket/Detay/@t.ID'">
                                            <td style="font-family:monospace; font-size:.76rem; color:var(--ink-soft);">@t.TicketNo</td>
                                            <td>
                                                <span style="font-weight:600; font-size:.82rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; display:block; max-width:130px;" title="@t.Title">
                                                    @(t.Title.Length > 22 ? t.Title.Substring(0, 22) + "…" : t.Title)
                                                </span>
                                                <span style="font-size:.72rem; color:var(--ink-soft);">@t.CustomerName</span>
                                            </td>
                                            <td><span class="b-status @sClass">@t.StatusText</span></td>
                                            <td style="font-size:.75rem; color:var(--ink-soft);">@t.WorkingMinuteDisplay</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
