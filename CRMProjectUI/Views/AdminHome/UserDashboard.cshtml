@model CRMProjectUI.Models.UserPersonalDashboardDto
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_adminLayout.cshtml";

    var companyStats = Model?.CompanyStats;
    var myStats = Model?.MyStats;
    var myOpenTickets = Model?.MyOpenTickets ?? new List<CRMProjectUI.Models.TicketListDto>();
    var companyOpenTickets = Model?.CompanyOpenTickets ?? new List<CRMProjectUI.Models.TicketListDto>();

    string fullName = User.FindFirst("FullName")?.Value ?? "Kullanıcı";
    string tarih = DateTime.Now.ToString("dddd, dd MMMM yyyy",
                          new System.Globalization.CultureInfo("tr-TR"));
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --ink: #0f1117;
        --ink-soft: #4a4f5e;
        --surface: #f7f8fc;
        --white: #fff;
        --accent: #2563eb;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --purple: #7c3aed;
        --border: #e2e8f0;
        --radius: 12px;
        --shadow-sm: 0 2px 8px rgba(15,17,23,.06);
        --shadow-md: 0 8px 32px rgba(15,17,23,.10);
    }

    .db-page {
        font-family: 'DM Sans', sans-serif;
    }

    .db-banner {
        background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
        border-radius: 16px;
        padding: 22px 28px;
        color: #fff;
        margin-bottom: 20px;
        box-shadow: 0 8px 32px rgba(14,165,233,.2);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
    }

        .db-banner h5 {
            
            font-weight: 800;
            margin: 0;
            font-size: 1.15rem;
        }

        .db-banner p {
            opacity: .8;
            margin: 0;
            font-size: .83rem;
            margin-top: 3px;
        }

    .db-banner-stats {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    .db-banner-stat {
        text-align: center;
    }

    .db-banner-stat-val {
        
        font-size: 1.6rem;
        font-weight: 800;
        line-height: 1;
    }

    .db-banner-stat-lbl {
        font-size: .7rem;
        opacity: .75;
        margin-top: 2px;
    }

    .db-section-title {
        font-family: 'Syne', sans-serif;
        font-size: .8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: var(--ink-soft);
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .db-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

    .db-stats {
        display: flex;
        gap: 12px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .db-stat {
        flex: 1;
        min-width: 110px;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 13px 15px;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 11px;
        transition: box-shadow .2s, transform .2s;
    }

        .db-stat:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }

    .db-stat-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        flex-shrink: 0;
    }

        .db-stat-icon.blue {
            background: #eff6ff;
            color: var(--accent);
        }

        .db-stat-icon.indigo {
            background: #eef2ff;
            color: #4f46e5;
        }

        .db-stat-icon.green {
            background: #f0fdf4;
            color: var(--success);
        }

        .db-stat-icon.red {
            background: #fef2f2;
            color: var(--danger);
        }

        .db-stat-icon.amber {
            background: #fffbeb;
            color: var(--warning);
        }

        .db-stat-icon.purple {
            background: #f5f3ff;
            color: var(--purple);
        }

    .db-stat-label {
        font-size: .66rem;
        color: var(--ink-soft);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 2px;
    }

    .db-stat-value {
        
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--ink);
        line-height: 1;
    }

    .db-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow-sm);
        margin-bottom: 18px;
        overflow: hidden;
    }

    .db-card-header {
        padding: 13px 18px;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .db-card-header h6 {
            margin: 0;
            font-weight: 700;
            font-size: .88rem;
            color: var(--ink);
            display: flex;
            align-items: center;
            gap: 7px;
        }

    .db-table {
        width: 100%;
        border-collapse: collapse;
    }

        .db-table thead th {
            font-size: .67rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: var(--ink-soft);
            padding: 9px 12px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            white-space: nowrap;
        }

        .db-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .15s;
            cursor: pointer;
        }

            .db-table tbody tr:last-child {
                border-bottom: none;
            }

            .db-table tbody tr:hover {
                background: #f8fafd;
            }

        .db-table tbody td {
            padding: 9px 12px;
            vertical-align: middle;
            font-size: .82rem;
        }

    .b-status {
        font-size: .68rem;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 3px;
        white-space: nowrap;
    }

        .b-status::before {
            content: '';
            width: 5px;
            height: 5px;
            border-radius: 50%;
            flex-shrink: 0;
        }

    .bs-0 {
        background: #f1f5f9;
        color: #475569;
    }

        .bs-0::before {
            background: #94a3b8;
        }

    .bs-1 {
        background: #eef2ff;
        color: #3730a3;
    }

        .bs-1::before {
            background: #4f46e5;
        }

    .bs-2 {
        background: #f0fdf4;
        color: #166534;
    }

        .bs-2::before {
            background: var(--success);
        }

    .bs-3 {
        background: #fef2f2;
        color: #991b1b;
    }

        .bs-3::before {
            background: var(--danger);
        }

    .bs-4 {
        background: #fffbeb;
        color: #92400e;
    }

        .bs-4::before {
            background: var(--warning);
        }

    .bs-5 {
        background: #f5f3ff;
        color: #5b21b6;
    }

        .bs-5::before {
            background: var(--purple);
        }

    .b-priority {
        font-size: .67rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 6px;
        white-space: nowrap;
    }

    .bp-1 {
        background: #f0fdf4;
        color: #166534;
    }

    .bp-2 {
        background: #eff6ff;
        color: #1e40af;
    }

    .bp-3 {
        background: #fffbeb;
        color: #92400e;
    }

    .bp-4 {
        background: #fef2f2;
        color: #991b1b;
    }

    .db-open-item {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 10px 18px;
        border-bottom: 1px solid var(--border);
        transition: background .15s;
        cursor: pointer;
        gap: 10px;
    }

        .db-open-item:last-child {
            border-bottom: none;
        }

        .db-open-item:hover {
            background: #f8fafd;
        }

    .db-open-title {
        font-size: .82rem;
        font-weight: 600;
        color: var(--ink);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 220px;
    }

    .db-open-sub {
        font-size: .72rem;
        color: var(--ink-soft);
        margin-top: 2px;
    }

    .db-new-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 8px;
        background: var(--accent);
        color: #fff;
        font-size: .78rem;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
        box-shadow: 0 2px 8px rgba(37,99,235,.3);
        transition: background .2s;
    }

        .db-new-btn:hover {
            background: #1d4ed8;
            color: #fff;
            text-decoration: none;
        }

    .db-empty {
        text-align: center;
        padding: 28px 16px;
        color: var(--ink-soft);
    }

        .db-empty i {
            font-size: 2rem;
            opacity: .2;
            display: block;
            margin-bottom: 8px;
        }
</style>

<div class="db-page">

    <!-- BANNER -->
    <div class="db-banner">
        <div>
            <h5><i class="fas fa-hand-sparkles mr-2"></i>Merhaba, @fullName!</h5>
            <p>@tarih — Destek taleplerinizin özeti</p>
        </div>
        <div class="db-banner-stats">
            <div class="db-banner-stat">
                <div class="db-banner-stat-val">@(companyStats?.Total ?? 0)</div>
                <div class="db-banner-stat-lbl">Firma Toplam</div>
            </div>
            <div class="db-banner-stat">
                <div class="db-banner-stat-val">@(companyStats?.Resolved ?? 0)</div>
                <div class="db-banner-stat-lbl">Çözülen</div>
            </div>
            <div class="db-banner-stat">
                <div class="db-banner-stat-val">@(myStats?.Total ?? 0)</div>
                <div class="db-banner-stat-lbl">Benim Taleplerim</div>
            </div>
        </div>
    </div>

    @if (Model == null)
    {
        <div class="alert alert-warning" style="border-radius:var(--radius);">
            <i class="fas fa-exclamation-triangle mr-2"></i>
            Dashboard verileri yüklenemedi. Lütfen sayfayı yenileyin.
        </div>
    }
    else
    {
        <!-- FİRMA İSTATİSTİKLERİ -->
        <div class="db-section-title">
            <i class="fas fa-building" style="color:var(--accent);"></i> Firma İstatistikleri
        </div>
        <div class="db-stats">
            <div class="db-stat">
                <div class="db-stat-icon blue"><i class="fas fa-ticket-alt"></i></div>
                <div><div class="db-stat-label">Toplam</div><div class="db-stat-value">@(companyStats?.Total ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon indigo"><i class="fas fa-folder-open"></i></div>
                <div><div class="db-stat-label">Açık</div><div class="db-stat-value" style="color:#4f46e5;">@(companyStats?.OpenCount ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon green"><i class="fas fa-check-circle"></i></div>
                <div><div class="db-stat-label">Çözülen</div><div class="db-stat-value" style="color:var(--success);">@(companyStats?.Resolved ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon red"><i class="fas fa-times-circle"></i></div>
                <div><div class="db-stat-label">Çözülemedi</div><div class="db-stat-value" style="color:var(--danger);">@(companyStats?.Failed ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon amber"><i class="fas fa-calendar-alt"></i></div>
                <div><div class="db-stat-label">Bu Ay Açılan</div><div class="db-stat-value" style="color:var(--warning);">@(companyStats?.ThisMonthOpened ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon purple"><i class="fas fa-calendar-check"></i></div>
                <div><div class="db-stat-label">Bu Ay Çözülen</div><div class="db-stat-value" style="color:var(--purple);">@(companyStats?.ThisMonthResolved ?? 0)</div></div>
            </div>
        </div>

        <!-- KİŞİSEL İSTATİSTİKLER -->
        <div class="db-section-title">
            <i class="fas fa-user" style="color:var(--purple);"></i> Kişisel İstatistiklerim
        </div>
        <div class="db-stats">
            <div class="db-stat">
                <div class="db-stat-icon blue"><i class="fas fa-ticket-alt"></i></div>
                <div><div class="db-stat-label">Açtığım</div><div class="db-stat-value">@(myStats?.Total ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon indigo"><i class="fas fa-folder-open"></i></div>
                <div><div class="db-stat-label">Açık</div><div class="db-stat-value" style="color:#4f46e5;">@(myStats?.OpenCount ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon green"><i class="fas fa-check-circle"></i></div>
                <div><div class="db-stat-label">Çözülen</div><div class="db-stat-value" style="color:var(--success);">@(myStats?.Resolved ?? 0)</div></div>
            </div>
            <div class="db-stat">
                <div class="db-stat-icon amber"><i class="fas fa-calendar-alt"></i></div>
                <div><div class="db-stat-label">Bu Ay Açtım</div><div class="db-stat-value" style="color:var(--warning);">@(myStats?.ThisMonthOpened ?? 0)</div></div>
            </div>
        </div>

        <!-- TABLOLAR -->
        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="db-card">
                    <div class="db-card-header">
                        <h6><i class="fas fa-list-ul" style="color:var(--accent);"></i> Açık Taleplerim</h6>
                        <a asp-action="Ekle" asp-controller="AdminTicket" class="db-new-btn">
                            <i class="fas fa-plus"></i> Yeni Talep
                        </a>
                    </div>
                    @if (!myOpenTickets.Any())
                    {
                        <div class="db-empty">
                            <i class="fas fa-check-circle" style="color:var(--success); opacity:1;"></i>
                            <p style="margin:0 0 12px;">Açık talebiniz yok 🎉</p>
                            <a asp-action="Ekle" asp-controller="AdminTicket" class="db-new-btn">
                                <i class="fas fa-plus"></i> Talep Oluştur
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="db-table">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Başlık / Ürün</th>
                                        <th>Öncelik</th>
                                        <th>Durum</th>
                                        <th>Atanan</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in myOpenTickets)
                                    {
                                        string pClass = $"bp-{t.Priority}";
                                        string sClass = $"bs-{t.Status}";
                                        <tr onclick="window.location='/AdminTicket/Detay/@t.ID'">
                                            <td style="font-family:monospace; font-size:.76rem; color:var(--ink-soft);">@t.TicketNo</td>
                                            <td>
                                                <div style="font-weight:600; font-size:.82rem; max-width:170px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="@t.Title">@t.Title</div>
                                                @if (!string.IsNullOrEmpty(t.LogoProductName))
                                                {
                                                    <div style="font-size:.72rem; color:var(--ink-soft);">
                                                        <i class="fas fa-cube mr-1" style="font-size:.6rem;"></i>@t.LogoProductName
                                                    </div>
                                                }
                                            </td>
                                            <td><span class="b-priority @pClass">@t.PriorityText</span></td>
                                            <td><span class="b-status @sClass">@t.StatusText</span></td>
                                            <td style="font-size:.78rem; color:var(--ink-soft);">
                                                @(string.IsNullOrEmpty(t.AssignedToName) ? "-" : t.AssignedToName)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-6 mb-3">
                <div class="db-card">
                    <div class="db-card-header">
                        <h6><i class="fas fa-building" style="color:var(--purple);"></i> Firmanın Açık Talepleri</h6>
                        <span style="font-size:.75rem; color:var(--ink-soft);">@companyOpenTickets.Count kayıt</span>
                    </div>
                    @if (!companyOpenTickets.Any())
                    {
                        <div class="db-empty">
                            <i class="fas fa-check-circle" style="color:var(--success); opacity:1;"></i>
                            <p style="margin:0;">Bekleyen talep yok 🎉</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var t in companyOpenTickets)
                        {
                            string pClass = $"bp-{t.Priority}";
                            string sClass = $"bs-{t.Status}";
                            <div class="db-open-item" onclick="window.location='/AdminTicket/Detay/@t.ID'">
                                <div style="flex:1; min-width:0;">
                                    <div style="display:flex; gap:5px; flex-wrap:wrap; margin-bottom:3px;">
                                        <span class="b-priority @pClass">@t.PriorityText</span>
                                        <span class="b-status @sClass">@t.StatusText</span>
                                    </div>
                                    <div class="db-open-title" title="@t.Title">@t.Title</div>
                                    <div class="db-open-sub">
                                        @t.TicketNo
                                        @if (!string.IsNullOrEmpty(t.CreatedByName))
                                        {
                                            <span> · <i class="fas fa-user" style="font-size:.6rem;"></i> @t.CreatedByName</span>
                                        }
                                        @if (!string.IsNullOrEmpty(t.AssignedToName))
                                        {
                                            <span> · <i class="fas fa-user-check" style="font-size:.6rem;"></i> @t.AssignedToName</span>
                                        }
                                    </div>
                                </div>
                                <span style="font-size:.72rem; color:var(--ink-soft); white-space:nowrap; flex-shrink:0;">@t.ElapsedText</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>
